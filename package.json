{
  "name": "athar-archive",
  "version": "1.0.0",
  "description": "أهل الأثر — Islamic knowledge archive",
  "scripts": {
    "dev": "astro dev",
    "new": "node scripts/new-content.mjs",
    "build": "pnpm validate:content && astro build && pagefind --site dist && tsx scripts/gen-redirects.ts && node scripts/gen-headers.mjs",
    "preview": "astro preview",
    "validate": "astro check",
    "validate:content": "tsx scripts/validate-content.ts",
    "search:index": "pagefind --site dist",
    "a11y": "node scripts/a11y-audit.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "check:links": "node scripts/check-links.mjs",
    "perf:budget": "node scripts/perf-budget.mjs",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "astro": "^6.4.8",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "axe-core": "^4.12.1",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.5.2",
    "playwright-core": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
