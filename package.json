{
  "name": "athar-archive",
  "version": "1.0.0",
  "description": "أهل الأثر — Islamic knowledge archive",
  "scripts": {
    "dev": "astro dev",
    "new": "node scripts/new-content.mjs",
    "import:epub": "tsx scripts/epub-import.ts",
    "build": "pnpm validate:content && tsx scripts/gen-takhrij.ts && astro build && node scripts/copy-content-assets.mjs && tsx scripts/gen-tafsir-frags.ts && tsx scripts/gen-book-chapters.ts && tsx scripts/gen-redirects.ts && node scripts/gen-headers.mjs",
    "preview": "astro preview",
    "validate": "astro check",
    "validate:content": "tsx scripts/validate-content.ts",
    "a11y": "node scripts/a11y-audit.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "check:links": "node scripts/check-links.mjs",
    "perf:budget": "node scripts/perf-budget.mjs",
    "perf:gen": "node scripts/gen-perf-content.mjs",
    "perf:clean": "node scripts/gen-perf-content.mjs --clean",
    "perf:bench": "node scripts/perf-bench.mjs",
    "test": "vitest run",
    "search:gen": "tsx scripts/gen-search-index.ts",
    "search:hashes": "wrangler d1 execute athar-search --remote -y --command \"SELECT url, hash FROM doc_hash\" --json > .search-hashes.json || echo '[]' > .search-hashes.json",
    "search:index": "pnpm search:hashes && pnpm search:gen && for f in dist/search-index/*.sql; do wrangler d1 execute athar-search --remote -y --file \"$f\" || exit 1; done",
    "search:index:local": "pnpm search:gen && for f in dist/search-index/*.sql; do wrangler d1 execute athar-search --local -y --file \"$f\" || exit 1; done",
    "r2:upload": "node scripts/upload-r2-assets.mjs",
    "deploy": "pnpm r2:upload && wrangler deploy -c dist/server/wrangler.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "astro": "^7.0.6",
    "force-graph": "^1.51.4",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.0.0",
    "axe-core": "^4.12.1",
    "gray-matter": "^4.0.3",
    "playwright-core": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  }
}
