---
import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import "../styles/extracted.css"; // generated from former inline styles — must load AFTER global.css
import { config } from "../../ahlalathar.config";
import { toArabicDigits } from "../lib/display";

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  searchScope?: { type?: string; in?: string; person?: string; label?: string };
  noindex?: boolean;
  ogType?: string;
  jsonLd?: unknown;
  readingPage?: boolean; // font/theme/width/تشكيل settings only make sense on actual reading content
}
const { title, description, activeNav, searchScope, noindex, ogType = "website", jsonLd, readingPage = false } = Astro.props;
const canonical = new URL(Astro.url.pathname.replace(/\/$/, "") || "/", config.siteUrl).href;

// Search affordance: links to /search, carrying the current page's scope (Part D).
const searchHref = (() => {
  if (!searchScope) return "/search";
  const p = new URLSearchParams();
  if (searchScope.in) { p.set("in", searchScope.in); if (searchScope.label) p.set("label", searchScope.label); }
  else if (searchScope.person) { p.set("person", searchScope.person); if (searchScope.label) p.set("label", searchScope.label); }
  else if (searchScope.type) { p.set("scope", searchScope.type); }
  const qs = p.toString();
  return qs ? `/search?${qs}` : "/search";
})();

// Top nav (RTL: first item renders rightmost, last renders leftmost) —
// الكتب / القرآن / الحديث / الشعر / الأعلام / المقالات / المسائل / كُناشة
const nav = [
  { id: "books", label: "الكتب", href: "/books" },
  { id: "quran", label: "القرآن", href: "/quran" },
  { id: "hadith", label: "الحديث", href: "/hadith" },
  { id: "poems", label: "الشعر", href: "/poems" },
  { id: "people", label: "التراجم والأعلام", href: "/people" },
  { id: "articles", label: "مقالات ومحاضرات", href: "/articles" },
  { id: "questions", label: "المسائل", href: "/questions" },
  { id: "benefits", label: "كُناشة", href: "/benefits" },
];
// Drawer keeps extra pages reachable (الموضوعات, معجم, etc.). شبكة المعرفة
// dropped from nav for now (heavy force-graph canvas) — /graph route still works.
const navAll = [
  ...nav,
  { id: "subjects", label: "الموضوعات", href: "/subjects" },
];

// In-bar search filter: type checkboxes + a specific-عَلَم picker (both backed by
// the D1 (FTS5) search index via /api/search). Person values are the display
// names the index stores.
const searchTypes = [
  { id: "book", label: "كتاب" },
  { id: "poem", label: "منظومة" },
  { id: "lesson", label: "درس" },
  { id: "question", label: "مسائل" },
  { id: "benefit", label: "كُناشة" },
  { id: "article", label: "مقالة" },
];
const filterPersons = (await getCollection("person"))
  .filter((p) => p.data.status === "published")
  .map((p) => p.data.title)
  .sort((a, b) => a.localeCompare(b, "ar"));
const filterSubjects = (await getCollection("subject"))
  .filter((s) => s.data.status === "published")
  .map((s) => s.data.title)
  .sort((a, b) => a.localeCompare(b, "ar"));

// Quran juz/page jump (topbar-level so it's reachable from any /quran/* page,
// not just the mushaf hub) — shown/hidden by reader.ts based on activeNav.
const quranSurahs = (await getCollection("quran")).sort((a, b) => (a.data.number as number) - (b.data.number as number));
const JUZ_START_PAGE = [1, 22, 42, 62, 82, 102, 121, 142, 162, 182, 201, 222, 242, 262, 282, 302, 322, 342, 362, 382, 402, 422, 442, 462, 482, 502, 522, 542, 562, 582];
const surahPages = quranSurahs.map((s) => ({ id: s.id, start: s.data.start_page as number }));
const pageHref = (page: number) => {
  let s = surahPages[0];
  for (const cand of surahPages) { if (cand.start <= page) s = cand; else break; }
  return `/quran/${s.id}#p${page}`;
};
const juzOptions = JUZ_START_PAGE.map((page, i) => ({ n: i + 1, href: pageHref(page) }));

const fullTitle = title.includes("أهل الأثر") ? title : `${title} · أهل الأثر`;

// Mobile reading-page compact header (design 1c): back to the section hub +
// the work's title, with the chapter (if any) as a subtitle. Chapter pages
// format title as "chapter · work" — split on that; single-page reading
// views (whole book/poem/article/question) have no " · " and no subtitle.
const readerHref = navAll.find((n) => n.id === activeNav)?.href ?? "/";
const [readerSub, readerMain] = title.includes(" · ") ? title.split(" · ") : [undefined, title];
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    {noindex ? <meta name="robots" content="noindex" /> : <link rel="canonical" href={canonical} />}

    <!-- Open Graph / Twitter -->
    <meta property="og:site_name" content="أهل الأثر" />
    <meta property="og:locale" content="ar_AR" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <ClientRouter />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#2c4a3e" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload" as="style"
      href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Amiri+Quran&family=Noto+Naskh+Arabic:wght@400;500;600;700&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Amiri+Quran&family=Noto+Naskh+Arabic:wght@400;500;600;700&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap" /></noscript>
    <!-- pre-paint: apply saved theme/scale/prefs before first paint to avoid flash -->
    <script is:inline>
      (() => {
        document.documentElement.classList.add("has-js"); // JS path: annotations show in the sheet, not inline
        try {
          const t = localStorage.getItem("aa-theme");
          if (t === "noir" || t === "mono") document.documentElement.setAttribute("data-theme", t);
          const s = localStorage.getItem("aa-scale");
          if (s) document.documentElement.style.setProperty("--reading-scale", s);
          if (localStorage.getItem("aa-sidebar") === "hidden") document.documentElement.setAttribute("data-sidebar", "hidden");
          if (localStorage.getItem("aa-vnums") === "0") document.documentElement.classList.add("hide-vnums");
          const w = localStorage.getItem("aa-width");
          if (w === "narrow" || w === "wide") document.documentElement.setAttribute("data-width", w);
        } catch (e) {}
      })();
    </script>
    {import.meta.env.PUBLIC_CF_BEACON && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${import.meta.env.PUBLIC_CF_BEACON}"}`}></script>
    )}
  </head>
  <body>
    <header class="topbar" data-reading={readingPage ? "1" : undefined} transition:persist>
      <div class="topbar-bar">
      <!-- mobile-only reading header (design 1c): back to hub + work title
           (+ chapter subtitle) + jump-to-chapter-list, replaces the brand row -->
      <div class="wrap topbar-reading-row">
        <a href={readerHref} class="icon-btn" aria-label="عودة">
          <svg width="12" height="20" viewBox="0 0 12 20" fill="none" aria-hidden="true"><path d="M10 2l-8 8 8 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
        </a>
        <div class="topbar-reading-title">
          <span class="topbar-reading-main">{readerMain}</span>
          {readerSub && <span class="topbar-reading-sub">{readerSub}</span>}
        </div>
        <button class="icon-btn" data-action="sidebar:mobile-toggle" aria-label="فهرس الفصول">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16M4 12h10M4 18h13"></path></svg>
        </button>
      </div>
      <div class="wrap topbar-row">
        <button class="hamburger" data-action="menu:toggle" aria-label="القائمة" aria-expanded="false" aria-controls="mobile-drawer">
          <span aria-hidden="true">☰</span> <span class="hamburger-label">القائمة</span>
        </button>

        <a href="/" class="brand" aria-label="أهل الأثر — الصفحة الرئيسية">
          <span class="brand-name">أهل الأثر</span>
          <span class="brand-sub">الأرشيف العلمي</span>
        </a>

        <!-- mobile-only: jump to the chapter list popup (ReaderSidebar.astro's
             <details>) — desktop always shows the sidebar now, no toggle needed -->
        <div class="topbar-sidebar-tools">
          <button class="icon-btn" data-action="sidebar:mobile-toggle" aria-label="فهرس الفصول" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="14" y2="18"></line></svg>
          </button>
        </div>

        <nav class="topnav" aria-label="التصفّح">
          {nav.map((n) => (
            <a href={n.href} data-nav={n.id} aria-current={activeNav === n.id ? "page" : undefined}>{n.label}</a>
          ))}
        </nav>

        <div class="topbar-tools">
          <!-- mobile app header (design 1a): search icon button — desktop hides it -->
          <a class="icon-btn mobile-search-btn" href={searchHref} aria-label="البحث">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="M20 20l-3.5-3.5"></path></svg>
          </a>
          <!-- top-bar search removed: search now lives per-section (listing pages),
               on the home hero, and in the drawer. -->
          <!-- Quran juz/page jump: only shown on /quran/* pages (reader.ts onPage) -->
          <div class="quran-jump" data-quran-jump hidden>
            <select data-quran-jump-juz aria-label="الانتقال إلى جزء">
              <option value="">الجزء</option>
              {juzOptions.map((j) => <option value={j.href}>{toArabicDigits(j.n)}</option>)}
            </select>
            <input type="number" min="1" max="604" placeholder="صفحة" data-quran-jump-page aria-label="الانتقال إلى صفحة" />
          </div>
          <script type="application/json" data-quran-surah-pages set:html={JSON.stringify(surahPages)} />
          <!-- theme cycle: always visible (not just reading pages) — one click steps
               paper → noir → mono → paper; icon swaps to match (reader.ts syncThemeButtons) -->
          <button class="icon-btn" data-action="theme:cycle" aria-label="تبديل السمة">
            <span data-theme-icon="paper"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg></span>
            <span data-theme-icon="noir" hidden><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg></span>
            <span data-theme-icon="mono" hidden><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M12 3a9 9 0 0 0 0 18z" fill="currentColor" stroke="none"></path></svg></span>
          </button>
          <!-- downloaded-for-offline manager — a real page (/downloads), not a
               popover: scales past a handful of entries -->
          <a class="icon-btn" href="/downloads" aria-label="التنزيلات">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"></path><path d="M7 10l5 5 5-5"></path><path d="M4 19h16"></path></svg>
          </a>
          <!-- reading-page-only tools: hidden by marks.ts/reader.ts unless the
               page has a .prose/.verse (or sidebar) to act on -->
          <button class="icon-btn" data-action="page:find" aria-label="بحث في الصفحة" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="20" y1="20" x2="16.65" y2="16.65"></line></svg>
          </button>
          <button class="icon-btn" data-action="settings:toggle" aria-label="إعدادات القراءة" aria-expanded="false" hidden={!readingPage}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06-.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
          </button>
        </div>
      </div>

      <!-- search filter popover (type + specific عَلَم) -->
      <div class="popover filter-pop" data-filter-pop hidden>
        <div class="pop-title">تصفية البحث</div>
        <fieldset class="pop-types" data-filter-types>
          <legend>النوع</legend>
          {searchTypes.map((t) => (
            <label class="pop-check"><input type="checkbox" value={t.id} /><span>{t.label}</span></label>
          ))}
        </fieldset>
        <div class="pop-field">
          <span>الأعلام</span>
          <input type="search" class="pop-search" data-filter-person-search placeholder="ابحثْ عن عَلَم…" aria-label="ابحث عن عَلَم" autocomplete="off" />
          <div class="pop-checklist" data-filter-person>
            {filterPersons.map((p) => (
              <label class="pop-check" data-name={p}><input type="checkbox" value={p} /><span>{p}</span></label>
            ))}
          </div>
        </div>
        {filterSubjects.length > 0 && (
          <div class="pop-field">
            <span>الموضوعات</span>
            <input type="search" class="pop-search" data-filter-subject-search placeholder="ابحثْ عن موضوع…" aria-label="ابحث عن موضوع" autocomplete="off" />
            <div class="pop-checklist" data-filter-subject>
              {filterSubjects.map((s) => (
                <label class="pop-check" data-name={s}><input type="checkbox" value={s} /><span>{s}</span></label>
              ))}
            </div>
          </div>
        )}
        <button type="button" class="btn-accent pop-apply" data-action="search:apply">تطبيق البحث</button>
      </div>

      <!-- reading-settings popover -->
      <div class="popover settings-pop" data-settings-pop hidden>
        <div class="theme-swatches">
          <button type="button" class="theme-swatch theme-swatch-paper" data-theme-btn="paper" data-action="theme:paper" aria-pressed="true" aria-label="سمة ورقية (سيبيا)" title="سيبيا"></button>
          <button type="button" class="theme-swatch theme-swatch-noir" data-theme-btn="noir" data-action="theme:noir" aria-pressed="false" aria-label="سمة داكنة بالأسود والذهبي" title="أسود وذهبي"></button>
          <button type="button" class="theme-swatch theme-swatch-mono" data-theme-btn="mono" data-action="theme:mono" aria-pressed="false" aria-label="سمة بيضاء نظيفة" title="أبيض وأسود"></button>
        </div>
        <div class="pop-row">
          <span class="pop-label">حجم الخط</span>
          <div class="pop-btns">
            <button class="icon-btn" data-action="font:dec" aria-label="تصغير الخط">أ−</button>
            <button class="icon-btn" data-action="font:inc" aria-label="تكبير الخط">أ+</button>
          </div>
        </div>
        <div class="pop-row">
          <span class="pop-label">عرض النص</span>
          <div class="pop-btns pop-width-btns">
            <button class="icon-btn" data-width-btn="narrow" data-action="width:narrow" aria-pressed="false" aria-label="عمود ضيق" title="ضيق">ضيق</button>
            <button class="icon-btn" data-width-btn="normal" data-action="width:normal" aria-pressed="true" aria-label="عمود عادي" title="عادي">عادي</button>
            <button class="icon-btn" data-width-btn="wide" data-action="width:wide" aria-pressed="false" aria-label="عمود عريض" title="عريض">عريض</button>
          </div>
        </div>
        <button class="toggle-btn pop-toggle" data-toggle="tashkeel" data-action="toggle:tashkeel" aria-pressed="true"><span class="toggle-dot"></span>التشكيل</button>
        <button class="toggle-btn pop-toggle" data-toggle="verseNums" data-action="toggle:verseNums" aria-pressed="true"><span class="toggle-dot"></span>ترقيم الأبيات</button>
        <button class="toggle-btn pop-toggle" data-toggle="pages" data-action="toggle:pages" aria-pressed="true"><span class="toggle-dot"></span>عرض الصفحات</button>
        <button class="toggle-btn pop-toggle" data-toggle="footnotes" data-action="toggle:footnotes" aria-pressed="true"><span class="toggle-dot"></span>الحواشي والتخريج</button>
      </div>

      <div class="progress-track"><div class="progress-bar" data-progress></div></div>
      </div>
    </header>

    <!-- mobile nav: compact anchored dropdown (HANDOFF.md §3.5) — not a full-height drawer -->
    <div class="drawer-backdrop" data-drawer-backdrop transition:persist></div>
    <aside class="drawer" id="mobile-drawer" data-drawer aria-label="القائمة" transition:persist>
      <a href={searchHref} class="drawer-search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="20" y1="20" x2="16.65" y2="16.65"></line></svg>
        <span>البحث</span>
      </a>
      {navAll.map((n) => <a href={n.href} data-nav={n.id} aria-current={activeNav === n.id ? "page" : undefined}>{n.label}</a>)}
      <div class="drawer-swatches theme-swatches">
        <button type="button" class="theme-swatch theme-swatch-paper" data-theme-btn="paper" data-action="theme:paper" aria-pressed="true" aria-label="سمة ورقية (سيبيا)" title="سيبيا"></button>
        <button type="button" class="theme-swatch theme-swatch-noir" data-theme-btn="noir" data-action="theme:noir" aria-pressed="false" aria-label="سمة داكنة بالأسود والذهبي" title="أسود وذهبي"></button>
        <button type="button" class="theme-swatch theme-swatch-mono" data-theme-btn="mono" data-action="theme:mono" aria-pressed="false" aria-label="سمة بيضاء نظيفة" title="أبيض وأسود"></button>
      </div>
      <!-- persistent re-entry point in case the install banner was dismissed
           by mistake — hidden by install-banner.ts unless install is possible -->
      <button type="button" class="btn install-drawer-btn" data-action="install:reopen" hidden>تثبيت التطبيق</button>
    </aside>

    <main data-active-nav={activeNav} data-reading={readingPage ? "1" : undefined}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap-mid">
        <div class="footer-grid">
          <div class="footer-brand">
            <div class="brand-name">أهل الأثر</div>
            <p class="footer-blurb">متونٌ ومنظوماتٌ وتراجمٌ وأسانيدُ — في تجربةِ قراءةٍ هادئة.</p>
          </div>
          <nav class="footer-col" aria-label="التصفّح">
            <div class="footer-col-h">التصفّح</div>
            <a href="/books">الكتب</a>
            <a href="/quran">القرآن</a>
            <a href="/hadith">الحديث</a>
            <a href="/poems">الشعر</a>
            <a href="/subjects">الموضوعات</a>
            <a href="/people">التراجم والأعلام</a>
          </nav>
          <nav class="footer-col" aria-label="الأرشيف">
            <div class="footer-col-h">الأرشيف</div>
            <a href="/benefits">كُناشة</a>
            <a href="/articles">المقالات</a>
            <a href="/questions">المسائل</a>
            <a href="/roadmap">طريق طلب العلم</a>
          </nav>
          <nav class="footer-col" aria-label="الموقع">
            <div class="footer-col-h">الموقع</div>
            <a href="/about">عن الموقع</a>
            <a href="/about#contact">تواصل</a>
          </nav>
        </div>
        <div class="footer-strip">
          <span class="footer-orn" aria-hidden="true">۞</span>
          <span>أهل الأثر · ١٤٤٧هـ</span>
        </div>
      </div>
    </footer>

    <!-- mobile app tab bar (Claude Design "Athar Mobile" 1a/1c) — ≤640px only.
         Reading pages swap tabs for reading tools per the design. -->
    <nav class="tabbar" aria-label="التنقل السفلي">
      {readingPage ? (
        <>
          <button data-action="sidebar:mobile-toggle" aria-label="فهرس الفصول">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16M4 12h10M4 18h13"></path></svg>
            <span>الفهرس</span>
          </button>
          <button data-action="settings:toggle" aria-label="إعدادات العرض">
            <span class="tab-aa" aria-hidden="true">أ<small>أ</small></span>
            <span>العرض</span>
          </button>
          <button data-action="page:share" aria-label="مشاركة الصفحة">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="12" r="2.5"></circle><circle cx="18" cy="6" r="2.5"></circle><circle cx="18" cy="18" r="2.5"></circle><path d="M8.2 10.8l7.6-3.6M8.2 13.2l7.6 3.6"></path></svg>
            <span>مشاركة</span>
          </button>
          <button data-action="menu:toggle" aria-label="القائمة">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
            <span>المزيد</span>
          </button>
        </>
      ) : (
        <>
          <a href="/" aria-current={Astro.url.pathname === "/" ? "page" : undefined}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10.5L12 3l9 7.5"></path><path d="M5 9.5V21h14V9.5"></path></svg>
            <span>الرئيسية</span>
          </a>
          <a href="/books" aria-current={activeNav === "books" ? "page" : undefined}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h9a3 3 0 013 3v13a3 3 0 00-3-3H4z"></path><path d="M20 4h-4v13h4z"></path></svg>
            <span>الكتب</span>
          </a>
          <a href="/quran" aria-current={activeNav === "quran" ? "page" : undefined}>
            <span class="tab-orn" aria-hidden="true">۞</span>
            <span>القرآن</span>
          </a>
          <a href={searchHref} aria-current={Astro.url.pathname.startsWith("/search") ? "page" : undefined}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="M20 20l-3.5-3.5"></path></svg>
            <span>البحث</span>
          </a>
          <button data-action="menu:toggle" aria-label="القائمة">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
            <span>المزيد</span>
          </button>
        </>
      )}
    </nav>

    <!-- page-transition loader: top progress bar + center seal, only shown if
         navigation actually takes a moment (see wirePageLoader in reader.ts) -->
    <div class="page-progress" data-page-progress transition:persist>
      <div class="page-progress-bar" data-page-progress-bar></div>
    </div>
    <div class="page-loader" data-page-loader transition:persist>
      <div class="page-loader-seal">
        <div class="page-loader-ring-outer"></div>
        <div class="page-loader-ring-spin"></div>
        <span class="page-loader-orn" aria-hidden="true">۞</span>
      </div>
      <div class="page-loader-label">
        <span>جارٍ التحميل</span>
        <span class="page-loader-dots"><span></span><span></span><span></span></span>
      </div>
    </div>

    <!-- PWA install prompt: hidden until install-banner.ts decides it's
         eligible (beforeinstallprompt fired, or iOS Safari not yet installed)
         and the user hasn't dismissed it before -->
    <div class="install-banner" data-install-banner hidden>
      <span data-install-text></span>
      <div class="install-banner-actions">
        <button type="button" class="btn-accent" data-action="install:accept" hidden>تثبيت</button>
        <button type="button" class="icon-btn" data-action="install:dismiss" aria-label="إغلاق">✕</button>
      </div>
    </div>

    <script>
      import "../scripts/reader.ts";
      import "../scripts/marks.ts";
      import "../scripts/install-banner.ts";
      // dynamic, not static: keeps this out of the site-wide critical bundle
      // (render-budget gate) — it's a whole feature (Cache API + SW + a
      // popover), not something every page needs synchronously on load.
      import("../scripts/downloads.ts");
    </script>
  </body>
</html>
