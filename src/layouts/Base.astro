---
import "../styles/global.css";
import "../styles/extracted.css"; // generated from former inline styles — must load AFTER global.css
import { config } from "../../ahlalathar.config";

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  searchMeta?: { title: string; type: string; person?: string; era?: string; id?: string; matn?: boolean; aliases?: string[] };
  searchScope?: { type?: string; in?: string; person?: string; label?: string };
  noindex?: boolean;
  ogType?: string;
  jsonLd?: unknown;
}
const { title, description, activeNav, searchMeta, searchScope, noindex, ogType = "website", jsonLd } = Astro.props;
const canonical = new URL(Astro.url.pathname.replace(/\/$/, "") || "/", config.siteUrl).href;

// Search affordance: links to /search, carrying the current page's scope (Part D).
const searchHref = (() => {
  if (!searchScope) return "/search";
  const p = new URLSearchParams();
  if (searchScope.in) { p.set("in", searchScope.in); if (searchScope.label) p.set("label", searchScope.label); }
  else if (searchScope.person) { p.set("person", searchScope.person); if (searchScope.label) p.set("label", searchScope.label); }
  else if (searchScope.type) { p.set("scope", searchScope.type); }
  const qs = p.toString();
  return qs ? `/search?${qs}` : "/search";
})();

// Pagefind facets emitted on indexable pages: type + (author) person + era + id + matn.
// Each filter needs its own element (one comma-joined attribute only registers the first).
const pagefindFilters = searchMeta
  ? [
      `type:${searchMeta.type}`,
      searchMeta.person ? `person:${searchMeta.person}` : null,
      searchMeta.era ? `era:${searchMeta.era}` : null,
      searchMeta.id ? `id:${searchMeta.id}` : null,
      searchMeta.matn ? `matn:نعم` : null,
    ].filter(Boolean) as string[]
  : [];

const nav = [
  { id: "home", label: "الرئيسية", href: "/" },
  { id: "books", label: "الكتب", href: "/books" },
  { id: "poems", label: "المنظومات", href: "/poems" },
  { id: "subjects", label: "الموضوعات", href: "/subjects" },
  { id: "series", label: "الدروس", href: "/series" },
  { id: "questions", label: "المسائل", href: "/questions" },
  { id: "benefits", label: "الفوائد", href: "/benefits" },
  { id: "articles", label: "المقالات", href: "/articles" },
  { id: "people", label: "الأعلام", href: "/people" },
];
const fullTitle = title === "أهل الأثر" ? title : `${title} · أهل الأثر`;
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    {noindex ? <meta name="robots" content="noindex" /> : <link rel="canonical" href={canonical} />}

    <!-- Open Graph / Twitter -->
    <meta property="og:site_name" content="أهل الأثر" />
    <meta property="og:locale" content="ar_AR" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=Reem+Kufi:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- pre-paint: apply saved theme/scale/prefs before first paint to avoid flash -->
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem("aa-theme");
          if (t && t !== "light") document.documentElement.setAttribute("data-theme", t);
          const s = localStorage.getItem("aa-scale");
          if (s) document.documentElement.style.setProperty("--reading-scale", s);
          if (localStorage.getItem("aa-vnums") === "0") document.documentElement.classList.add("hide-vnums");
          const md = localStorage.getItem("aa-mode");
          if (md && md !== "qiraa") document.documentElement.setAttribute("data-mode", md);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="topbar" data-pagefind-ignore>
      <div class="wrap topbar-brandrow">
        <div class="uf5e88b2">
          <button class="icon-btn hamburger u660e442" data-action="menu:toggle" aria-label="القائمة" >
            <span class="u8e79aed"></span>
          </button>
        </div>
        <a href="/" class="brand">
          <span class="brand-name">أهل الأثر</span>
          <span class="brand-sub">الأرشيف العلمي</span>
        </a>
        <div class="ub5c9733">
          <a class="icon-btn" href={searchHref} aria-label="البحث">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="20" y1="20" x2="16.65" y2="16.65"></line></svg>
          </a>
          <button class="icon-btn theme-cycle ue705c71" data-action="theme:cycle" aria-label="السمة" >◑</button>
        </div>
      </div>

      <nav class="wrap topnav" aria-label="التصفّح">
        {nav.map((n) => (
          <a href={n.href} aria-current={activeNav === n.id ? "page" : undefined}>{n.label}</a>
        ))}
      </nav>

      <div class="wrap settings-row">
        <div class="ctl-group">
          <div class="u8f813ee">
            <button class="icon-btn" data-action="font:dec" title="تصغير الخط">أ−</button>
            <button class="icon-btn ude00808" data-action="font:inc" title="تكبير الخط" >أ+</button>
          </div>
          <button class="toggle-btn" data-toggle="tashkeel" data-action="toggle:tashkeel" aria-pressed="true">
            <span class="toggle-dot"></span>تشكيل
          </button>
          <button class="toggle-btn" data-toggle="verseNums" data-action="toggle:verseNums" aria-pressed="true">ترقيم الأبيات</button>
        </div>
        <div class="theme-switch">
          <button data-theme-btn="light" data-action="theme:light" aria-pressed="true">فاتح</button>
          <button data-theme-btn="sepia" data-action="theme:sepia" aria-pressed="false">ورقي</button>
          <button data-theme-btn="dark" data-action="theme:dark" aria-pressed="false">داكن</button>
        </div>
      </div>

      <div class="progress-track"><div class="progress-bar" data-progress></div></div>
    </header>

    <!-- mobile drawer -->
    <div class="drawer-backdrop" data-drawer-backdrop data-pagefind-ignore></div>
    <aside class="drawer" data-drawer aria-label="القائمة" data-pagefind-ignore>
      <div class="drawer-head">
        <span class="brand-name u94aa034" >أهل الأثر</span>
        <button class="icon-btn u5f04d9d" data-action="menu:close" aria-label="إغلاق" >×</button>
      </div>
      <a href={searchHref} class="drawer-search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="20" y1="20" x2="16.65" y2="16.65"></line></svg>
        <span>البحث</span>
      </a>
      <div class="drawer-section-label">التصفّح</div>
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      <div class="drawer-section-label u816b4ed" >القراءة</div>
      <div class="uea49063">
        <span class="muted u433de30" >حجم الخط</span>
        <div class="u49cd092">
          <button class="icon-btn u6745888" data-action="font:dec" >أ−</button>
          <button class="icon-btn ud575b29" data-action="font:inc" >أ+</button>
        </div>
      </div>
      <button class="toggle-btn u9375847" data-toggle="tashkeel" data-action="toggle:tashkeel" aria-pressed="true" ><span class="toggle-dot"></span>التشكيل</button>
      <button class="toggle-btn u4a27002" data-toggle="verseNums" data-action="toggle:verseNums" aria-pressed="true" >ترقيم الأبيات</button>
      <div class="drawer-section-label u816b4ed" >السمة</div>
      <div class="u49cd092">
        <button class="btn u2069fa5" data-theme-btn="light" data-action="theme:light" >فاتح</button>
        <button class="btn u2069fa5" data-theme-btn="sepia" data-action="theme:sepia" >ورقي</button>
        <button class="btn u2069fa5" data-theme-btn="dark" data-action="theme:dark" >داكن</button>
      </div>
    </aside>

    <main
      data-pagefind-body={searchMeta ? "" : undefined}
      data-pagefind-ignore={searchMeta ? undefined : ""}
      data-pagefind-meta={searchMeta ? `title:${searchMeta.title}` : undefined}
    >
      {pagefindFilters.map((f) => <span class="sr-only" data-pagefind-filter={f}></span>)}
      {searchMeta?.aliases?.length ? <span class="sr-only">{searchMeta.aliases.join("، ")}</span> : null}
      <slot />
    </main>

    <footer class="site-footer" data-pagefind-ignore>
      <div class="wrap-mid">
        <div class="footer-grid">
          <div>
            <div class="brand-name ub9199e2" >أهل الأثر</div>
            <p class="muted u5a151a3" >
              المتونُ والمنظوماتُ والدروسُ، محقَّقةً ومُشكَّلةً. المحتوى هو الأصل، والتقنيةُ طبقةٌ قابلةٌ للاستبدال.
            </p>
          </div>
          <nav class="footer-links" aria-label="روابط">
            <a href="/books">الكتب</a>
            <a href="/poems">المنظومات</a>
            <a href="/series">الدروس</a>
            <a href="/topics">الموضوعات</a>
            <a href="/people">الأعلام</a>
            <a href="/benefits">الفوائد</a>
            <a href="/articles">المقالات</a>
            <a href="/questions">المسائل</a>
            <a href="/about">عن الموقع</a>
            <a href="/contact">تواصل</a>
          </nav>
        </div>
      </div>
    </footer>

    <script>
      import "../scripts/reader.ts";
    </script>
  </body>
</html>
