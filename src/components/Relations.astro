---
// «ما يشير إلى هذا» — reverse references (backlinks), grouped by relation.
// Collapsible and at page end: keeps connectivity out of the reading flow
// (clean-UI gate). Items are precomputed (backlinksList) in getStaticPaths.
import { toArabicDigits } from "../lib/display";
import type { BacklinkItem } from "../lib/site";

interface Props { items: BacklinkItem[] }
const { items } = Astro.props;

const groups = new Map<string, BacklinkItem[]>();
for (const it of items) {
  const g = groups.get(it.relation);
  if (g) g.push(it);
  else groups.set(it.relation, [it]);
}
---
{items.length > 0 && (
  <details class="relations wrap-mid">
    <summary>ما يشير إلى هذا <span class="rel-count">{toArabicDigits(items.length)}</span></summary>
    <div class="rel-body">
      {[...groups].map(([relation, list]) => (
        <div class="rel-group">
          <div class="rel-label">{relation}</div>
          <ul class="rel-list">
            {list.map((it) => (
              <li><a href={it.href}>{it.title}</a>{it.sub && <span class="faint"> — {it.sub}</span>}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </details>
)}
<style>
  .relations {
    margin: 2.5rem auto 1rem;
    border-top: 1px solid var(--rule);
    padding-top: 1.25rem;
  }
  .relations > summary {
    cursor: pointer; list-style: none;
    font-family: var(--font-mono);
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); opacity: 0.9;
  }
  .relations > summary::-webkit-details-marker { display: none; }
  .relations[open] > summary { margin-bottom: 1rem; }
  .rel-count {
    font-family: var(--font-mono); font-size: 10px;
    background: var(--gold-soft); color: var(--gold);
    border-radius: 999px; padding: 1px 7px; margin-inline-start: 6px;
  }
  .rel-body { display: grid; gap: 1rem; }
  .rel-group {}
  .rel-label {
    font-family: var(--font-ui); font-size: 11.5px;
    color: var(--ink-faint); margin-bottom: 0.35rem;
  }
  .rel-list { margin: 0; padding-inline-start: 1.2rem; }
  .rel-list li { margin: 0.2rem 0; }
  .rel-list a {
    font-family: var(--font-display); font-size: 15px; font-weight: 700;
    color: var(--ink); text-decoration: none;
    transition: color 0.15s;
  }
  .rel-list a:hover { color: var(--accent); }
</style>
