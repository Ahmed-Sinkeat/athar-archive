---
// One <details> per note KIND (شرح/تخريج/حكم…), grouping multiple sources
// under a small tab picker instead of stacking a separate <details> per
// source. Long bodies clamp with a "المزيد" expander. Pure CSS (radio/
// checkbox peers) + one delegated listener in reader.ts for the tab switch.
import { markdownToSafeHtml } from "../lib/sanitize";

export interface InlineNote {
  kind: string;
  body: string;
  sourceLabel?: string; // shown as the tab/summary label when there's one source
  sourceHref?: string;
  sourceHrefText?: string; // defaults to "اقرأ في موضعه: ⟨sourceLabel⟩"
}

interface Props {
  notes: InlineNote[];
  kindOrder: string[];
  kindClass: Record<string, string>;
  longThreshold?: number;
}

const { notes, kindOrder, kindClass, longThreshold = 500 } = Astro.props;

const groups = new Map<string, InlineNote[]>();
for (const n of notes) {
  if (!groups.has(n.kind)) groups.set(n.kind, []);
  groups.get(n.kind)!.push(n);
}
const sortedKinds = [...groups.keys()].sort((a, b) => kindOrder.indexOf(a) - kindOrder.indexOf(b));
---
{sortedKinds.map((kind, gi) => {
  const items = groups.get(kind)!;
  return (
    <details class={`inline-note k-${kindClass[kind] ?? "sharh"}`}>
      <summary>{kind}{items.length === 1 && items[0].sourceLabel ? ` — ${items[0].sourceLabel}` : ""}</summary>
      {items.length > 1 && (
        <div class="inline-note-tabs">
          {items.map((it, i) => (
            <>
              <input type="radio" name={`inote-${kind}-${gi}`} id={`inote-${kind}-${gi}-${i}`} class="inline-note-tab-input" checked={i === 0} />
              <label for={`inote-${kind}-${gi}-${i}`} class="inline-note-tab">{it.sourceLabel}</label>
            </>
          ))}
        </div>
      )}
      {items.map((it, i) => {
        const long = it.body.length > longThreshold;
        return (
          <div class="inline-note-pane" data-pane={`inote-${kind}-${gi}-${i}`} hidden={items.length > 1 && i !== 0}>
            {long && <input type="checkbox" id={`inote-more-${kind}-${gi}-${i}`} class="inline-note-more-toggle" hidden />}
            <div class:list={["inline-note-body", { clamp: long }]} data-ar set:html={markdownToSafeHtml(it.body)} />
            {long && <label for={`inote-more-${kind}-${gi}-${i}`} class="inline-note-more">إظهار المزيد ↓</label>}
            {it.sourceHref && <a class="ann-source-link" href={it.sourceHref}>{it.sourceHrefText || `اقرأ في موضعه${it.sourceLabel ? `: ${it.sourceLabel}` : ""}`} ←</a>}
          </div>
        );
      })}
    </details>
  );
})}
