---
// Per-section search bar for listing pages. Shows live results inline via
// /api/search as you type; Enter/submit still goes to /search (full page,
// same scope) for the complete result set.
interface Props { scope?: string; placeholder?: string }
const { scope = "", placeholder = "ابحث في هذا القسم…" } = Astro.props;
---
<form class="section-search" action="/search" method="get" role="search" data-section-search>
  <div class="section-search-box">
    <input type="search" name="q" class="section-search-input" placeholder={placeholder} aria-label={placeholder} autocomplete="off" />
    {scope && <input type="hidden" name="scope" value={scope} />}
    <div class="section-search-drop" data-section-search-drop hidden></div>
  </div>
  <button type="submit" class="btn-accent section-search-go">بحث</button>
</form>

<style>
  .section-search-box { position: relative; flex: 1; }
  .section-search-drop {
    position: absolute; inset-inline: 0; top: calc(100% + 6px); z-index: 30;
    background: var(--surface); border: 1px solid var(--rule-strong); border-radius: 10px;
    box-shadow: 0 12px 34px rgba(20,16,12,0.16); overflow: hidden; max-height: 60vh; overflow-y: auto;
  }
  .section-search-hit {
    display: block; padding: 10px 14px; text-decoration: none; color: var(--ink);
    border-bottom: 1px solid var(--rule); font-family: var(--font-ui);
  }
  .section-search-hit:last-of-type { border-bottom: none; }
  .section-search-hit:hover { background: var(--paper-2); }
  .section-search-hit-title { font-size: 12.5px; font-weight: 600; color: var(--accent); margin-bottom: 3px; }
  .section-search-hit-snippet { font-size: 14px; color: var(--ink-soft); font-family: var(--font-serif); line-height: 1.7; }
  .section-search-hit-snippet mark { background: var(--gold-soft); color: inherit; border-radius: 3px; padding: 0 2px; }
  .section-search-more { display: block; padding: 9px 14px; text-align: center; font-size: 12.5px; color: var(--accent); text-decoration: none; background: var(--paper-2); }
  .section-search-empty { padding: 12px 14px; font-size: 13px; color: var(--ink-faint); }
</style>

<script is:inline data-astro-rerun>
  (() => {
    document.querySelectorAll("[data-section-search]").forEach((form) => {
      if (form.dataset.wired) return;
      form.dataset.wired = "1";
      const input = form.querySelector(".section-search-input");
      const drop = form.querySelector("[data-section-search-drop]");
      const scope = form.querySelector('input[name="scope"]')?.value || "";
      const esc = (s) => s.replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));
      let seq = 0;
      let t;
      const hide = () => { drop.hidden = true; };
      const go = async () => {
        const q = input.value.trim();
        const my = ++seq;
        if (!q) { hide(); return; }
        const p = new URLSearchParams({ q });
        if (scope) p.set("type", scope);
        const res = await fetch("/api/search?" + p).catch(() => null);
        if (my !== seq) return;
        const hits = res && res.ok ? (await res.json()).hits : null;
        if (my !== seq) return;
        if (!hits) { hide(); return; }
        const seeAll = `/search?${new URLSearchParams({ q, ...(scope ? { scope } : {}) })}`;
        drop.innerHTML = hits.length
          ? hits.slice(0, 6).map((h) =>
              `<a class="section-search-hit" href="${esc(h.url)}">` +
              `<p class="section-search-hit-title">${esc(h.title)}</p>` +
              `<p class="section-search-hit-snippet">${esc(h.snippet).replaceAll("&lt;mark&gt;", "<mark>").replaceAll("&lt;/mark&gt;", "</mark>")}</p>` +
              `</a>`).join("") + `<a class="section-search-more" href="${seeAll}">كل النتائج ←</a>`
          : `<p class="section-search-empty">لا نتائج.</p>`;
        drop.hidden = false;
      };
      input.addEventListener("input", () => { clearTimeout(t); t = setTimeout(go, 220); });
      input.addEventListener("focus", () => { if (input.value.trim()) go(); });
      document.addEventListener("click", (e) => { if (!form.contains(e.target)) hide(); });
      input.addEventListener("keydown", (e) => { if (e.key === "Escape") hide(); });
    });
  })();
</script>
