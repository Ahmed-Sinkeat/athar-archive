---
// Client-side title-only filter for list pages (books/poems/matn/people/...).
// Replaces the old per-page SectionSearch (a live /api/search dropdown) which
// duplicated the header's global search and confused "two searches on one
// page" — this one only narrows the cards already on screen, by title, no
// network request. Deep full-text search still lives in the header search.
import { searchHrefFor, type SearchScope } from "../lib/display";
interface Props { placeholder?: string; scope?: SearchScope }
const { placeholder = "تصفية حسب العنوان…", scope } = Astro.props;
// base query string (scope only, no q=) — the client script appends q= as
// the visitor types, so the fallback lands on this same page's slice of the
// index instead of a generic sitewide search
const searchBase = searchHrefFor(scope);
---
<div class="title-filter">
  <input type="search" class="title-filter-input" placeholder={placeholder} aria-label={placeholder} autocomplete="off" data-title-filter />
  <p class="title-filter-empty faint" data-title-filter-empty hidden>
    لا نتائج مطابقة في هذه الصفحة — <a href={searchBase} data-title-filter-search-link data-search-base={searchBase}>جرّب البحث الشامل</a>
  </p>
</div>

<style>
  .title-filter { margin-bottom: 18px; }
  .title-filter-input {
    width: 100%; font-family: var(--font-ui); font-size: 15px; color: var(--ink);
    background: var(--surface); border: 1px solid var(--rule-strong); border-radius: 10px;
    padding: 10px 14px;
  }
  .title-filter-empty { padding: 10px 2px 0; font-size: 13px; }
</style>

<script is:inline data-astro-rerun>
  (() => {
    document.querySelectorAll("[data-title-filter]").forEach((input) => {
      if (input.dataset.wired) return;
      input.dataset.wired = "1";
      const scope = input.closest(".title-filter").parentElement;
      const empty = scope.querySelector("[data-title-filter-empty]");
      const searchLink = empty.querySelector("[data-title-filter-search-link]");
      // strip tashkeel, then fold hamza-alef/ya/ta-marbuta variants so
      // "الألبيري" matches a search for "الالبيري" (and vice versa) — common
      // spelling drift in Arabic text, not a real difference to the reader
      const norm = (s) => s.normalize("NFKD").replace(/[ً-ٰٟ]/g, "")
        .replace(/[إأآٱ]/g, "ا").replace(/ة/g, "ه").replace(/ى/g, "ي")
        .toLowerCase();
      input.addEventListener("input", () => {
        const q = norm(input.value.trim());
        const items = scope.querySelectorAll("[data-title]");
        let shown = 0;
        items.forEach((el) => {
          const match = !q || norm(el.dataset.title || "").includes(q);
          el.hidden = !match;
          if (match) shown++;
        });
        // collapse now-empty subject/topic groups (shared markup across the
        // browse/masail grouped views) so filtering doesn't leave bare headers
        scope.querySelectorAll(".century-node, .masail-subject, .masail-topic").forEach((g) => {
          const kids = g.querySelectorAll("[data-title]");
          if (kids.length === 0) return;
          g.hidden = q !== "" && ![...kids].some((k) => !k.hidden);
        });
        empty.hidden = shown > 0 || !q;
        if (searchLink) {
          const base = searchLink.dataset.searchBase || "/search";
          const sep = base.includes("?") ? "&" : "?";
          searchLink.href = `${base}${sep}q=${encodeURIComponent(input.value.trim())}`;
        }
      });
    });
  })();
</script>
