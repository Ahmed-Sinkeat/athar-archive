---
import { toArabicDigits } from "../lib/display";

interface Source {
  url: string;
  format?: "opus" | "mp3";
  duration?: string | null;
  sizeBytes?: number | null;
  label?: string | null;
}
interface Props {
  sources: Source[];
  label?: string;
}
const { sources, label = "الاستماع" } = Astro.props;
const list = sources.filter((s) => s?.url);
const cur = list[0];
const mime = (f?: "opus" | "mp3") => (f === "mp3" ? "audio/mpeg" : "audio/ogg; codecs=opus");
const meta = (s: Source) =>
  [s.duration, s.sizeBytes ? `${toArabicDigits((s.sizeBytes / 1_048_576).toFixed(1))} م.ب` : null].filter(Boolean).join(" · ");
---
{cur && (
  <figure class="audio" data-audio>
    <figcaption class="audio-caption">
      <span>{label}</span>
      {/* multiple recitations → a small native dropdown (the arrow) to switch; single → just metadata */}
      {list.length > 1 ? (
        <select class="audio-pick" data-audio-pick aria-label="اختر التسجيل">
          {list.map((s, i) => (
            <option value={i} data-url={s.url} data-type={mime(s.format)} data-meta={meta(s)}>
              {s.label || `تسجيل ${i + 1}`}
            </option>
          ))}
        </select>
      ) : (
        <span class="faint u6cb285c" data-audio-meta>{meta(cur)}</span>
      )}
    </figcaption>
    <!-- native controls: fully usable without our JS, keyboard + screen-reader friendly -->
    <audio controls preload="metadata" data-audio-el>
      <source src={cur.url} type={mime(cur.format)} data-audio-source />
      <a href={cur.url}>تنزيل الملف الصوتي</a>
    </audio>
    <div class="audio-tools">
      <div class="audio-speed" data-audio-speed role="group" aria-label="سرعة التشغيل">
        {["0.75", "1", "1.25", "1.5", "2"].map((r) => (
          <button type="button" data-speed={r} aria-pressed={r === "1" ? "true" : "false"}>{r}×</button>
        ))}
      </div>
      <!-- href stays as a same-origin-download fallback (no-JS, or blob fetch failing e.g. CORS) -->
      <a class="btn u8e0fa20" href={cur.url} download data-audio-dl>تحميل</a>
    </div>
  </figure>
)}
