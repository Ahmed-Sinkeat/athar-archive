---
// Persistent audio player — fixed to the viewport bottom so play/pause/seek/
// speed stay reachable without scrolling back to the top. Real playback runs
// on a hidden native <audio> (data-audio-el); reader.ts drives the custom
// bar/FAB UI off its play/pause/timeupdate/ended events. Progressive
// enhancement: no-JS still gets a plain, fully-usable native <audio controls>
// (data-audio-fallback), hidden once JS confirms it can render the bar.
import { toArabicDigits, reciterOf } from "../lib/display";

interface Source {
  url: string;
  format?: "opus" | "mp3";
  duration?: string | null;
  sizeBytes?: number | null;
  label?: string | null;
}
interface Props {
  sources: Source[];
  title: string;
  subtitle?: string;
  initial?: number; // preselected track (lesson matching the current chapter)
  loopByVerse?: boolean; // page has per-bayt timing (.verses[data-timing]) — show the "loop from bayt to bayt" control
}
const { sources, title, subtitle, initial = 0, loopByVerse = false } = Astro.props;
const list = sources.filter((s) => s?.url);
const cur = list[initial] ?? list[0];
const curIdx = list[initial] ? initial : 0;
const mime = (f?: "opus" | "mp3") => (f === "mp3" ? "audio/mpeg" : "audio/ogg; codecs=opus");
// multi-track (lesson series): reader.ts swaps the <source> from this JSON and
// auto-advances on `ended`
const tracks = list.length > 1 ? JSON.stringify(list.map((s) => ({ url: s.url, format: s.format ?? "opus", label: s.label ?? "", sizeBytes: s.sizeBytes ?? null }))) : undefined;
// Prefer the reciter's name whenever this track's own title encodes one
// ("العمل — القارئ" — see reciterOf); otherwise fall back to whatever this
// slot showed before: the raw label for a multi-track lesson series (it's
// really "which chapter/lesson is this", not a person, but still useful to
// show), or the work's author for a single, unlabeled track.
const curSubtitle = reciterOf(cur?.label) ?? (tracks ? cur?.label : subtitle);
const sizeLabel = cur?.sizeBytes
  ? cur.sizeBytes < 1024 * 1024
    ? `${Math.round(cur.sizeBytes / 1024)} KB`
    : `${(cur.sizeBytes / (1024 * 1024)).toFixed(1)} MB`
  : null;
---
<!-- No transition:persist here: this Astro version only accepts a compile-time
     string literal for that directive (a runtime expression like {cur.url}
     renders literally as the text "(cur.url)"), which would give every page's
     player the same key and wrongly persist the wrong audio across navigation.
     reader.ts instead carries the playback position + resume-or-not across
     astro:before-swap keyed by the audio URL, so continuity only happens when
     it's really the same track (e.g. a book's landing page → its chapters). -->
{cur && (
  <div data-audio data-audio-tracks={tracks} data-audio-index={tracks ? String(curIdx) : undefined}>
    <!-- crossorigin: CORS-mode media requests give the SW readable (non-opaque)
         responses — Android Chrome rejects opaque range responses through a SW
         (desktop is lenient), which silently killed playback on phones -->
    <audio preload="metadata" crossorigin="anonymous" data-audio-el hidden>
      <source src={cur.url} type={mime(cur.format)} data-audio-source />
    </audio>

    <noscript>
      <figure class="audio">
        <figcaption class="audio-caption">{title}{subtitle && ` — ${subtitle}`}</figcaption>
        <audio controls preload="none" crossorigin="anonymous">
          <source src={cur.url} type={mime(cur.format)} />
          <a href={cur.url}>تنزيل الملف الصوتي</a>
        </audio>
      </figure>
    </noscript>

    <button type="button" class="audio-fab" data-audio-fab hidden aria-label="فتح المشغّل">
      <span class="audio-fab-inner">
        <span data-audio-icon-play><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M7 5l12 7-12 7V5z"></path></svg></span>
        <span data-audio-icon-pause hidden><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"></rect><rect x="14" y="5" width="4" height="14" rx="1"></rect></svg></span>
      </span>
    </button>

    <div class="audio-bar" data-audio-bar hidden>
      <div class="audio-rail" data-audio-rail>
        <div class="audio-rail-fill" data-audio-fill></div>
        <div class="audio-rail-handle" data-audio-handle></div>
      </div>
      <div class="audio-row">
        <button type="button" class="audio-toggle" data-audio-toggle aria-label="تشغيل / إيقاف">
          <span data-audio-icon-play><svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M7 5l12 7-12 7V5z"></path></svg></span>
          <span data-audio-icon-pause hidden><svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1"></rect><rect x="14" y="5" width="4" height="14" rx="1"></rect></svg></span>
        </button>
        <div class="audio-info">
          <p class="audio-title">{title}</p>
          <p class="audio-subtitle" data-audio-track-label hidden={!curSubtitle}>{curSubtitle}</p>
        </div>
        <span class="audio-time" dir="ltr" data-audio-time>0:00 / 0:00</span>
        {tracks && (
          <span class="audio-speed-wrap">
            <button type="button" class="audio-speed" data-audio-list-toggle aria-label="قائمة المقاطع">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h10"></path></svg>
            </button>
            <div class="audio-speed-menu audio-track-menu" data-audio-list-menu hidden>
              {list.map((s, i) => (
                <button type="button" data-track={i} aria-pressed={i === curIdx ? "true" : "false"}>{s.label || toArabicDigits(i + 1)}</button>
              ))}
            </div>
          </span>
        )}
        <span class="audio-speed-wrap">
          <button type="button" dir="ltr" class="audio-speed" data-audio-speed-toggle>×1</button>
          <div class="audio-speed-menu" data-audio-speed-menu hidden>
            {["2", "1.5", "1.25", "1", "0.75"].map((r) => (
              <button type="button" dir="ltr" data-speed={r} aria-pressed={r === "1" ? "true" : "false"}>×{r}</button>
            ))}
          </div>
        </span>
        {loopByVerse && (
          <span class="audio-speed-wrap">
            <button type="button" class="audio-speed" data-loop-toggle aria-pressed="false" aria-label="تكرار مقطع من الأبيات" title="تكرار مقطع من الأبيات">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 1l4 4-4 4"></path><path d="M3 11V9a4 4 0 014-4h14"></path><path d="M7 23l-4-4 4-4"></path><path d="M21 13v2a4 4 0 01-4 4H3"></path></svg>
              <span data-loop-status></span>
            </button>
            <div class="audio-speed-menu audio-loop-menu" data-loop-menu hidden>
              <label>من بيت <input type="number" min="1" inputmode="numeric" data-loop-from /></label>
              <label>إلى بيت <input type="number" min="1" inputmode="numeric" data-loop-to /></label>
              <label>عدد مرّات التكرار <input type="number" min="1" value="3" inputmode="numeric" data-loop-count /></label>
              <button type="button" class="audio-loop-start" data-loop-start>ابدأ التكرار</button>
            </div>
          </span>
        )}
        <button type="button" class="audio-dl" data-audio-dl data-action="download:toggle" data-dl-kind="audio" data-dl-id={cur.url}
          data-dl-title={cur.label ? `${title} — ${cur.label}` : title} data-dl-path={Astro.url.pathname}
          aria-pressed="false" title={sizeLabel ? `تحميل (${sizeLabel})` : "تحميل"} aria-label={sizeLabel ? `تحميل (${sizeLabel})` : "تحميل"}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16"></path></svg>
          <span class="audio-dl-size" dir="ltr">{sizeLabel}</span>
        </button>
        <button type="button" class="audio-minimize" data-audio-minimize title="تصغير" aria-label="تصغير">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 9l6 6 6-6"></path></svg>
        </button>
      </div>
    </div>
  </div>
)}
