---
import { toArabicDigits } from "../lib/display";

interface Att {
  label: string;
  url: string;
  format?: string;
  size_bytes?: number;
}
interface Props {
  items?: Att[];
  heading?: string;
}
const { items = [], heading = "تحميلات" } = Astro.props;
---
{
  items.length > 0 && (
    <div data-pagefind-ignore>
      <div class="toc-label" style="font-size:11.5px;letter-spacing:.16em;margin:24px 0 10px">{heading}</div>
      <div class="downloads">
        {items.map((a) => (
          <a class="download-link" href={a.url} download>
            <span>{a.label}</span>
            {a.format && <span class="fmt">{a.format}</span>}
            {a.size_bytes && <span class="faint" style="font-size:11px">{toArabicDigits((a.size_bytes / 1_048_576).toFixed(1))}م.ب</span>}
          </a>
        ))}
      </div>
    </div>
  )
}
