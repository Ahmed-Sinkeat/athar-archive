---
// Collapsible تصنيف → موضوع → cards browse, shared by the card index pages.
// Default view is the flat list; grouped accordion is the secondary option.
import EntityCard from "./EntityCard.astro";
import SortableList from "./SortableList.astro";
import { toArabicDigits } from "../lib/display";
import type { SubjectGroup, TopicGroup } from "../lib/browse";
import type { ContentEntry } from "../lib/types";

interface Props {
  groups: SubjectGroup[];
  uncategorized: ContentEntry[];
  card: (e: ContentEntry) => Record<string, any>;
  unit?: string;
  otherLabel?: string;
  personNames?: Map<string, string>; // optional: enables person filter dropdown
}
const { groups, uncategorized, card, unit = "", otherLabel = "موضوعاتٌ أخرى", personNames } = Astro.props;
const count = (n: number) => `${toArabicDigits(n)}${unit ? ` ${unit}` : ""}`;

// Flat de-duped list of every item (for the flat/sortable view — default).
const allItems: ContentEntry[] = (() => {
  const seen = new Set<string>();
  const out: ContentEntry[] = [];
  const add = (it: ContentEntry) => { if (!seen.has(it.id)) { seen.add(it.id); out.push(it); } };
  for (const g of groups) for (const t of g.topics) for (const it of t.items) add(it);
  for (const it of uncategorized) add(it);
  return out;
})();

// Build person filter options from allItems (only when personNames provided)
const personOptions: { id: string; name: string }[] = personNames
  ? [...new Map(
      allItems
        .filter((it) => it.data.person)
        .map((it) => [it.data.person as string, personNames.get(it.data.person as string) ?? (it.data.person as string)])
    ).entries()]
    .map(([id, name]) => ({ id, name }))
    .sort((a, b) => a.name.localeCompare(b.name, "ar"))
  : [];

// Build topic filter options from groups
const topicMap = new Map<string, string>();
for (const g of groups) for (const t of g.topics) topicMap.set(t.id, t.title);
const topicOptions = [...topicMap.entries()].map(([id, title]) => ({ id, title })).sort((a, b) => a.title.localeCompare(b.title, "ar"));

// Build kind filter options from allItems
const kindOptions = [...new Set(
  allItems.map((it) => (it.data.kind as string | undefined)).filter(Boolean) as string[]
)].sort((a, b) => a.localeCompare(b, "ar"));
---
<div class="browse show-flat" data-browse>
  <div class="browse-toolbar">
    <div class="browse-view-toggle" role="group" aria-label="طريقة العرض">
      <button type="button" data-flat-toggle="grouped" aria-pressed="false">مُجمَّع</button>
      <button type="button" data-flat-toggle="flat" aria-pressed="true">قائمة</button>
    </div>
  </div>
  {(kindOptions.length > 1 || personOptions.length > 1 || topicOptions.length > 1) && (
    <div class="browse-filter-bar">
      <span class="browse-filter-label">تصفية:</span>
      <div class="browse-filters">
        {kindOptions.length > 1 && (
          <select class="browse-filter" data-filter-key="kind" aria-label="فلترة بالنوع">
            <option value="">كل الأنواع</option>
            {kindOptions.map((k) => <option value={k}>{k}</option>)}
          </select>
        )}
        {personOptions.length > 1 && (
          <>
            <input type="text" list="browse-person-list" class="browse-filter browse-filter-text" data-filter-key="person" aria-label="فلترة بالعَلَم" placeholder="كل الأعلام" />
            <datalist id="browse-person-list">
              {personOptions.map((p) => <option value={p.name} />)}
            </datalist>
          </>
        )}
        {topicOptions.length > 1 && (
          <select class="browse-filter" data-filter-key="topic" aria-label="فلترة بالموضوع">
            <option value="">كل الموضوعات</option>
            {topicOptions.map((t) => <option value={t.id}>{t.title}</option>)}
          </select>
        )}
      </div>
    </div>
  )}
  <div class="browse-flat"><SortableList items={allItems} card={card} /></div>
  <div class="masail-tree browse-grouped">
  {groups.map((g: SubjectGroup) => (
    <details class="masail-subject">
      <summary>
        <span class="masail-subject-name">{g.title}</span>
        <span class="faint masail-count">{count(g.count)}</span>
      </summary>
      <div class="masail-topics">
        {g.topics.map((t: TopicGroup) => (
          <details class="masail-topic">
            <summary>
              <span>{t.title}</span>
              <span class="faint masail-count">{toArabicDigits(t.items.length)}</span>
            </summary>
            <ol class="flat-list browse-cards">
              {t.items.map((it: ContentEntry) => <li><EntityCard {...card(it)} /></li>)}
            </ol>
          </details>
        ))}
      </div>
    </details>
  ))}

  {uncategorized.length > 0 && (
    <details class="masail-subject">
      <summary>
        <span class="masail-subject-name">{otherLabel}</span>
        <span class="faint masail-count">{toArabicDigits(uncategorized.length)}</span>
      </summary>
      <ol class="flat-list browse-cards">
        {uncategorized.map((it: ContentEntry) => <li><EntityCard {...card(it)} /></li>)}
      </ol>
    </details>
  )}
  </div>
</div>
