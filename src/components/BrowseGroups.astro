---
// Collapsible تصنيف → موضوع → cards browse, shared by the card index pages
// (books, poems, articles, series). Reuses the masail-tree accordion (native
// <details>, no JS). Owns only the shell; each page passes a `card()` that maps
// an entry to EntityCard props, so per-type card richness stays on the page.
// المسائل keeps its own list-style accordion (links, not cards).
import EntityCard from "./EntityCard.astro";
import { toArabicDigits } from "../lib/display";
import type { SubjectGroup } from "../lib/browse";
import type { ContentEntry } from "../lib/types";

interface Props {
  groups: SubjectGroup[];
  uncategorized: ContentEntry[];
  card: (e: ContentEntry) => Record<string, any>;
  unit?: string; // counter word after a subject's item count
  otherLabel?: string;
}
const { groups, uncategorized, card, unit = "", otherLabel = "موضوعاتٌ أخرى" } = Astro.props;
const count = (n: number) => `${toArabicDigits(n)}${unit ? ` ${unit}` : ""}`;
---
<div class="masail-tree">
  {groups.map((g) => (
    <details class="masail-subject">
      <summary>
        <span class="masail-subject-name">{g.title}</span>
        <span class="faint masail-count">{count(g.count)}</span>
      </summary>
      <div class="masail-topics">
        {g.topics.map((t) => (
          <details class="masail-topic">
            <summary>
              <span>{t.title}</span>
              <span class="faint masail-count">{toArabicDigits(t.items.length)}</span>
            </summary>
            <div class="card-grid browse-cards">
              {t.items.map((it) => <EntityCard {...card(it)} />)}
            </div>
          </details>
        ))}
      </div>
    </details>
  ))}

  {uncategorized.length > 0 && (
    <details class="masail-subject">
      <summary>
        <span class="masail-subject-name">{otherLabel}</span>
        <span class="faint masail-count">{toArabicDigits(uncategorized.length)}</span>
      </summary>
      <div class="card-grid browse-cards">
        {uncategorized.map((it) => <EntityCard {...card(it)} />)}
      </div>
    </details>
  )}
</div>
