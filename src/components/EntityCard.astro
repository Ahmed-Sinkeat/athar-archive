---
import { eraLabel } from "../lib/display";
interface Props {
  href: string;
  title: string;
  kind?: string;
  kindColor?: string; // "tag-accent" | "tag-verdigris"
  corner?: string;
  sub?: string;
  cta?: string;
  filterKey?: string;
  audio?: boolean;    // render a صوت badge (has a linked audio entry)
  era?: string;       // العصر — canonical value; badge shows eraLabel(), data-era filters
}
const { href, title, kind, kindColor = "tag-accent", corner, sub, cta = "ادخل ←", filterKey, audio, era } = Astro.props;
const hasRow = kind || corner || audio || era;
---
<a class="card" href={href} data-kind={filterKey} data-era={era}>
  {
    hasRow && (
      <div class="card-kindrow">
        <span class="card-kindrow-tags">
          {kind ? <span class:list={["pill", kindColor]}>{kind}</span> : <span />}
          {audio && <span class="badge-matn">صوت</span>}
          {era && <span class="pill tag-verdigris">{eraLabel(era)}</span>}
        </span>
        {corner && <span class="faint u6cb285c" >{corner}</span>}
      </div>
    )
  }
  <div class="card-title">{title}</div>
  {sub && <div class="card-sub">{sub}</div>}
  {cta && <div class="card-cta">{cta}</div>}
</a>
