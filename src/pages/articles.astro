---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import EntityCard from "../components/EntityCard.astro";
import { personNameMap, publishedSorted } from "../lib/site";
import { hrefFor } from "../lib/display";

const articles = await publishedSorted("article");
const names = await personNameMap();
---
<Base title="المقالات" description="مقالاتٌ علميةٌ محرَّرةٌ في مسائل العلم وأصوله." activeNav="articles">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "المقالات" }]} />
  <div class="wrap-mid" style="padding-block:18px 96px">
    <h1 class="page-title">المقالات</h1>
    <p class="page-intro">مقالاتٌ علميةٌ محرَّرةٌ، بعضُها مصحوبٌ بتسجيلٍ صوتيٍّ.</p>
    <div class="card-grid">
      {articles.map((e) => (
        <EntityCard
          href={hrefFor("article", e.id)}
          title={e.data.title}
          kind="مقالة"
          kindColor="tag-verdigris"
          sub={names.get(e.data.person)}
          cta="اقرأ ←"
        />
      ))}
    </div>
  </div>
</Base>
