---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import BrowseGroups from "../components/BrowseGroups.astro";
import TitleFilter from "../components/TitleFilter.astro";
import { personNameMap, loadGraph } from "../lib/site";
import { hrefFor } from "../lib/display";
import { buildSubjectGroups } from "../lib/browse";
import { collectionLd } from "../lib/structured-data";

const graph = await loadGraph();
const names = await personNameMap();
const { groups, uncategorized } = buildSubjectGroups("article", graph);
const card = (it: any) => ({
  href: hrefFor("article", it.id),
  title: it.data.title,
  kind: "مقالة",
  kindColor: "tag-verdigris",
  sub: it.data.person ? names.get(it.data.person) ?? "" : "",
  cta: "اقرأ ←",
  dlKind: "article",
  dlId: it.id,
});
---
<Base title="مقالات ومحاضرات" description="مقالاتٌ علميةٌ محرَّرةٌ في مسائل العلم وأصوله." activeNav="articles" jsonLd={collectionLd({ title: "مقالات ومحاضرات", path: "/articles", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "مقالات ومحاضرات", path: "/articles" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "مقالات ومحاضرات" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">مقالات ومحاضرات</h1>
    <TitleFilter placeholder="تصفية حسب العنوان…" />
    <BrowseGroups groups={groups} uncategorized={uncategorized} card={card} unit="مقالة" personNames={names} />
  </div>
</Base>
