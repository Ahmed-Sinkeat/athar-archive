---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { toArabicDigits, hrefFor, eraLabel, eraHref, labelFor } from "../lib/display";
import { analyzePoem } from "../lib/chunk";
import { readBody } from "../lib/read-body";
import { websiteLd } from "../lib/structured-data";
import { loadGraph, personEraMap } from "../lib/site";

const pub = (c: any[]) => c.filter((e) => e.data.status === "published");

const [people, books, poems, articles, benefits, announcements, highlights, questions, subjects, quranSurahs] = await Promise.all([
  getCollection("person"),
  getCollection("book"),
  getCollection("poem"),
  getCollection("article"),
  getCollection("benefit"),
  getCollection("announcement"),
  getCollection("highlight"),
  getCollection("question"),
  getCollection("subject"),
  getCollection("quran"),
]);
const hadithBooks = books.filter((b) => (b.data as any).genre === "حديث" && b.data.status === "published");

// مختارات الأسبوع: one published آية / حديث / بيت per kind, rotating by week index.
// ponytail: build-time pick (stable within a week); refreshes on each rebuild/deploy.
const wk = Math.floor(Date.now() / 6.048e8);
const pickWeekly = (kind: string) => {
  const arr = pub(highlights).filter((h) => h.data.kind === kind);
  return arr.length ? arr[wk % arr.length] : null;
};
const weekly = ["آية", "حديث", "بيت"].map((kind) => ({ kind, entry: pickWeekly(kind) })).filter((w) => w.entry);
// each text tradition gets its own dress (kicker accent + body font), per HANDOFF §5
const weeklyDress: Record<string, { cls: string; textCls: string; label: string }> = {
  "آية": { cls: "k-gold", textCls: "weekly-text-quran", label: "آية الأسبوع" },
  "حديث": { cls: "k-green", textCls: "weekly-text-hadith", label: "حديث الأسبوع" },
  "بيت": { cls: "k-copper", textCls: "", label: "من المنظومات" },
};

// Resolve a highlight's source link, and (for a بيت) its era + subject pills.
const graph = await loadGraph();
const eras = await personEraMap();
const subjectsOf = (topicIds: string[] | undefined) => {
  const out: { title: string; href: string }[] = [];
  const seen = new Set<string>();
  for (const tid of topicIds ?? []) {
    const sid = graph.getById("topic", tid)?.data.subject as string | undefined;
    if (!sid || seen.has(sid)) continue;
    const s = graph.getById("subject", sid);
    if (s && s.data.status === "published") { seen.add(sid); out.push({ title: s.data.title as string, href: hrefFor("subject", sid) }); }
  }
  return out;
};
const weeklyMeta = (entry: any) => {
  const st = entry.data.source_type as string | undefined;
  const si = entry.data.source_id as string | undefined;
  const src = st && si ? graph.getById(st, si) : null;
  const srcHref = src ? hrefFor(st!, si!) : null;
  let era: string | null = null, eraLink: string | undefined;
  let subjects: { title: string; href: string }[] = [];
  if (entry.data.kind === "بيت" && src) {
    const pid = src.data.person as string | undefined;
    const ev = pid ? eras.get(pid) : undefined;
    if (ev) { era = eraLabel(ev); eraLink = eraHref(ev); }
    subjects = subjectsOf(src.data.topics as string[] | undefined);
  }
  return { srcHref, era, eraLink, subjects };
};

const personName = new Map(people.map((p) => [p.id, p.data.title]));

const stats = [
  { num: pub(books).length, label: "كتابًا" },
  { num: pub(poems).length, label: "منظومة" },
  // ponytail: lesson count removed — دروس are now books with audio
  { num: pub(articles).length, label: "مقالة" },
  { num: pub(questions).length, label: "مسألة" },
  { num: pub(people).length, label: "من الأعلام" },
];

const anns = pub(announcements).sort((a, b) => (b.data.priority ?? 5) - (a.data.priority ?? 5)).slice(0, 3);

// featured: first published poem, with its opening verses
const featured = pub(poems)[0];
const featuredVerses = featured ? analyzePoem(await readBody(featured)).verses.slice(0, 2) : [];

// latest across materials by published_at — متن/مصدر أصلي get the accent type-badge (HANDOFF §4)
const SOURCE_KINDS = new Set(["متن", "مصدر أصلي"]);
const latest = [
  ...pub(books).map((e) => { const kind = labelFor("book", e.data); return { e, kind, isSource: SOURCE_KINDS.has(kind) }; }),
  ...pub(poems).map((e) => ({ e, kind: "منظومة", isSource: false })),
  ...pub(articles).map((e) => ({ e, kind: "مقالة", isSource: false })),
  ...pub(benefits).map((e) => ({ e, kind: "فائدة", isSource: false })),
]
  .sort((a, b) => +new Date(b.e.data.published_at) - +new Date(a.e.data.published_at))
  .slice(0, 5);
---
<Base title="أهل الأثر | الأرشيف العلمي للمتون والمنظومات الإسلامية" description="الأرشيف العلمي لأهل السنة والجماعة: متونٌ ومنظوماتٌ ودروسٌ محقَّقةً ومُشكَّلةً، في تجربة قراءة هادئة." activeNav="home" jsonLd={websiteLd()}>
  <section class="hero">
    <div class="plate-outer">
      <div class="plate-inner">
        <div class="hero-inner">
          <div class="hero-eyebrow">الأرشيفُ العلميُّ للمتونِ والمنظوماتِ الإسلامية</div>
          <h1 class="hero-title">أهل الأثر</h1>

          {/* One asset, re-tinted via the data-theme CSS filter below — the site's
              theme (paper/noir/mono) is independent of the OS's prefers-color-scheme,
              so a <picture><source media="prefers-color-scheme"> swap would show the
              wrong variant whenever the two disagree (e.g. OS dark + site "paper"). */}
          <img
            src="/calligraphy/logo_light.webp"
            alt=""
            class="hero-calligraphy hero-calligraphy-img"
            width="380"
            height="312"
            loading="eager"
            decoding="async"
          />

          <p class="hero-lede">متونٌ ومنظوماتٌ وتراجمٌ وأسانيد — في تجربة قراءة هادئة.</p>

          <div class="divider-orn" aria-hidden="true">۞</div>

          <form action="/search" method="get" class="u5fbcbc5">
            <div class="u537b78d">
              <input name="q" type="text" placeholder="ابحث في المتون والمنظومات والدروس والفوائد…" class="u38ae86c" />
              <button type="button" class="icon-btn hero-filter" data-action="search:filter" aria-label="تصفية البحث" aria-expanded="false">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
              </button>
              <button class="btn-accent u4964676" type="submit">بحث</button>
            </div>
          </form>

          <div class="hero-pills">
            <a class="ghost-pill" href="/graph">شبكة المعرفة</a>
            <a class="ghost-pill" href="/benefits">كُناشة الفوائد</a>
            <a class="ghost-pill" href="/roadmap">طريق طلب العلم</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="home-section">
    <div class="section-head"><h2>تصفّح الأرشيف</h2><div class="rule-fill"></div></div>
    <div class="browse4-grid">
      <a class="browse4-card accent-brand" href="/books">
        <div class="browse4-card-head"><span class="browse4-card-title">الكتب</span><span class="browse4-card-meta">{toArabicDigits(pub(books).length)} كتابًا</span></div>
        <p class="browse4-card-sub">متونٌ ومراجعُ ومجاميعُ محقَّقةٌ مُشكَّلةٌ، مرتَّبةٌ حسب الفنِّ.</p>
      </a>
      <a class="browse4-card accent-gold" href="/quran">
        <div class="browse4-card-head"><span class="browse4-card-title">القرآن</span><span class="browse4-card-meta">{toArabicDigits(pub(quranSurahs).length)} سورة</span></div>
        <p class="browse4-card-sub">التفاسيرُ وعلومُ القرآنِ والقراءات.</p>
      </a>
      <a class="browse4-card accent-green" href="/hadith">
        <div class="browse4-card-head"><span class="browse4-card-title">الحديث</span><span class="browse4-card-meta">{toArabicDigits(hadithBooks.length)} كتب</span></div>
        <p class="browse4-card-sub">متونُ الحديثِ وتخاريجُه وعلَلُه.</p>
      </a>
      <a class="browse4-card accent-copper" href="/poems">
        <div class="browse4-card-head"><span class="browse4-card-title">الشعر</span><span class="browse4-card-meta">{toArabicDigits(pub(poems).length)} منظومة</span></div>
        <p class="browse4-card-sub">منظوماتٌ علميةٌ محقَّقةٌ مُشكَّلةٌ مع الشروح والتخريج.</p>
      </a>
    </div>
    <div class="browse-pills">
      <a class="ghost-pill" href="/people">التراجم والأعلام <span class="browse-pills-count">· {toArabicDigits(pub(people).length)}</span></a>
      <a class="ghost-pill" href="/subjects">الموضوعات <span class="browse-pills-count">· {toArabicDigits(pub(subjects).length)} فنًّا</span></a>
      <a class="ghost-pill" href="/questions">المسائل <span class="browse-pills-count">· {toArabicDigits(pub(questions).length)}</span></a>
      <a class="ghost-pill" href="/articles">المقالات</a>
    </div>
  </div>

  {anns.length > 0 && (
    <div class="home-section">
      <div class="section-head"><h2>إعلانات</h2><div class="rule-fill"></div></div>
      <div class="ann-cards">
        {anns.map((a) => (
          <div class="ann-card">
            <span class="badge tag-verdigris u3a19426" >جديد</span>
            <h3>{a.data.title}</h3>
            {a.body && <p>{a.body}</p>}
          </div>
        ))}
      </div>
    </div>
  )}

  {featured && (
    <div class="home-section">
      <div class="section-head"><h2>منظومة مختارة</h2><div class="rule-fill"></div></div>
      <div class="u0ef5d25">
        <div>
          <div class="eyebrow u57e29a5" >منظومة · {personName.get(featured.data.person)}</div>
          <h3 class="reader-title u8bd951d" >{featured.data.title}</h3>
          {featured.data.description && <p class="prose u86de7ac" ><span class="u515ff4e">{featured.data.description}</span></p>}
          <a class="btn btn-accent u8a77e5a"  href={hrefFor("poem", featured.id)}>اقرأ المنظومة ←</a>
        </div>
        <div class="u474572a" data-ar>
          {featuredVerses.map((v) => (
            <div class="ud8c0226">
              <div class="sadr u881f70f" >{v.sadr}</div>
              {v.ajz && <div class="ajz u881f70f" >{v.ajz}</div>}
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  {weekly.length > 0 && (
    <div class="home-section">
      <div class="section-head"><h2>مختارات الأسبوع</h2><div class="rule-fill"></div></div>
      <div class="weekly-grid">
        {weekly.map(({ kind, entry }) => {
          const m = weeklyMeta(entry);
          const dress = weeklyDress[kind] ?? { cls: "", textCls: "", label: kind };
          return (
          <div class={`weekly-card ${dress.cls}`}>
            {kind === "بيت" && (m.era || m.subjects.length) ? (
              <div class="weekly-pills">
                <span class={`weekly-kicker ${dress.cls}`}>{dress.label}</span>
                {m.eraLink && <a class="pill tag-verdigris pill-link" href={m.eraLink}>{m.era}</a>}
                {m.subjects.map((s) => <a class="pill tag-accent pill-link" href={s.href}>{s.title}</a>)}
              </div>
            ) : (
              <div class={`weekly-kicker ${dress.cls}`}>{dress.label}</div>
            )}
            <p class={`weekly-text ${dress.textCls}`} data-ar>{entry!.body.trim()}</p>
            {entry!.data.reference && (
              <div class="weekly-foot">
                <span class="faint">{entry!.data.reference}</span>
                {m.srcHref && <a class="weekly-ref" href={m.srcHref}>اقرأ في موضعه ←</a>}
              </div>
            )}
          </div>
          );
        })}
      </div>
    </div>
  )}

  {latest.length > 0 && (
    <div class="home-section u3a4c3ff" >
      <div class="section-head"><h2>أحدث الإضافات</h2><div class="rule-fill"></div><a class="section-link" href="/books">كل الكتب ←</a></div>
      {latest.map(({ e, kind, isSource }) => (
        <a class="latest-row" href={hrefFor(e.collection, e.id, { series: e.data.series })}>
          <span class:list={["type-badge", { accent: isSource }]}>{kind}</span>
          <span class="latest-name">{e.data.title}</span>
          {e.data.person && <span class="faint u5e0faad" >{personName.get(e.data.person)}</span>}
          <span class="latest-arrow">←</span>
        </a>
      ))}
    </div>
  )}

  <div class="home-section stats-section">
    <div class="stats-strip">
      {stats.map((s) => (
        <div class="stat"><div class="stat-num">{toArabicDigits(s.num)}</div><div class="stat-label">{s.label}</div></div>
      ))}
    </div>
  </div>
</Base>
