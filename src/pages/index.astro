---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { toArabicDigits, hrefFor, labelFor } from "../lib/display";
import { analyzePoem } from "../lib/chunk";
import { websiteLd } from "../lib/structured-data";

const pub = (c: any[]) => c.filter((e) => e.data.status === "published");

const [people, books, poems, series, lessons, articles, benefits, announcements] = await Promise.all([
  getCollection("person"),
  getCollection("book"),
  getCollection("poem"),
  getCollection("series"),
  getCollection("lesson"),
  getCollection("article"),
  getCollection("benefit"),
  getCollection("announcement"),
]);

const personName = new Map(people.map((p) => [p.id, p.data.title]));

const stats = [
  { num: pub(books).length, label: "كتابًا" },
  { num: pub(poems).length, label: "منظومة" },
  { num: pub(lessons).length, label: "درسًا مفرَّغًا" },
  { num: pub(people).length, label: "من الأعلام" },
];

const anns = pub(announcements).sort((a, b) => (b.data.priority ?? 5) - (a.data.priority ?? 5)).slice(0, 3);

// featured: first published poem, with its opening verses
const featured = pub(poems)[0];
const featuredVerses = featured ? analyzePoem(featured.body ?? "").verses.slice(0, 2) : [];

// latest across materials by published_at
const latest = [
  ...pub(books).map((e) => ({ e, kind: labelFor("book", e.data), color: "tag-accent" })),
  ...pub(poems).map((e) => ({ e, kind: "منظومة", color: "tag-accent" })),
  ...pub(series).map((e) => ({ e, kind: "سلسلة", color: "tag-verdigris" })),
  ...pub(articles).map((e) => ({ e, kind: "مقالة", color: "tag-verdigris" })),
  ...pub(benefits).map((e) => ({ e, kind: "فائدة", color: "tag-accent" })),
]
  .sort((a, b) => +new Date(b.e.data.published_at) - +new Date(a.e.data.published_at))
  .slice(0, 5);
---
<Base title="أهل الأثر" description="الأرشيف العلمي لأهل السنة والجماعة: متونٌ ومنظوماتٌ ودروسٌ محقَّقةً ومُشكَّلةً، في تجربة قراءة هادئة." activeNav="home" jsonLd={websiteLd()}>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">أرشيفٌ علميٌّ طويلُ العُمر</div>
      <h1 class="hero-title">أهل الأثر</h1>
      <p class="hero-lede">المتونُ والمنظوماتُ والدروسُ، مُحقَّقةً ومُشكَّلةً، في تجربةِ قراءةٍ هادئةٍ تجعلُ المعرفةَ هي الأصل.</p>

      <form action="/search" method="get" class="u5fbcbc5">
        <div class="u537b78d">
          <input name="q" type="text" placeholder="ابحث في المتون والمنظومات والدروس والفوائد…" class="u38ae86c" />
          <button class="btn-accent u4964676" type="submit" >بحث</button>
        </div>
      </form>

      <div class="u40e95b5">
        <a class="btn btn-accent" href="/books">تصفّح الكتب</a>
        {featured && <a class="btn" href={hrefFor("poem", featured.id)}>ابدأ بـ{featured.data.title}</a>}
      </div>

      <div class="divider-orn"><span class="line"></span><span class="dot">۞</span><span class="line"></span></div>
    </div>
  </section>

  <div class="wrap-mid u4260ebe" >
    <div class="stats-strip">
      {stats.map((s) => (
        <div class="stat"><div class="stat-num">{toArabicDigits(s.num)}</div><div class="stat-label">{s.label}</div></div>
      ))}
    </div>
    <div class="review-today u-center-text" data-review-home hidden>لديك <span data-review-home-n></span> موضعًا يحتاج مراجعة — تابِعْ حفظك</div>
  </div>

  {anns.length > 0 && (
    <div class="home-section">
      <div class="section-label">إعلانات</div>
      <div class="ann-cards">
        {anns.map((a) => (
          <div class="ann-card">
            <span class="badge tag-verdigris u3a19426" >جديد</span>
            <h3>{a.data.title}</h3>
            {a.body && <p>{a.body}</p>}
          </div>
        ))}
      </div>
    </div>
  )}

  {featured && (
    <div class="home-section">
      <div class="section-label">مختارُ هذا الأسبوع</div>
      <div class="u0ef5d25">
        <div>
          <div class="eyebrow u57e29a5" >منظومة · {personName.get(featured.data.person)}</div>
          <h2 class="reader-title u8bd951d" >{featured.data.title}</h2>
          {featured.data.description && <p class="prose u86de7ac" ><span class="u515ff4e">{featured.data.description}</span></p>}
          <a class="btn btn-accent u8a77e5a"  href={hrefFor("poem", featured.id)}>اقرأ المنظومة ←</a>
        </div>
        <div class="u474572a" data-ar>
          {featuredVerses.map((v) => (
            <div class="ud8c0226">
              <div class="sadr u881f70f" >{v.sadr}</div>
              {v.ajz && <div class="ajz u881f70f" >{v.ajz}</div>}
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <div class="home-section">
    <div class="section-label">تصفّح الأرشيف</div>
    <div class="card-grid u8bffae7" >
      <a class="card" href="/books"><div class="ufa5a688">ا</div><div class="card-title ua3ba3b1" >الكتب</div><p class="card-sub uf04e97f" >المتونُ والمراجعُ محقَّقةً ومُشكَّلةً، مرتَّبةً حسب الفنِّ.</p><span class="card-cta">تصفّح ←</span></a>
      <a class="card" href="/poems"><div class="ufa5a688">ب</div><div class="card-title ua3ba3b1" >المنظومات</div><p class="card-sub uf04e97f" >منظوماتٌ علميةٌ مُشكَّلةٌ مُرقَّمةُ الأبيات، مع الشروح والتخريج.</p><span class="card-cta">تصفّح ←</span></a>
      <a class="card" href="/series"><div class="ufa5a688">ج</div><div class="card-title ua3ba3b1" >الدروس</div><p class="card-sub uf04e97f" >سلاسلُ شرحِ المتونِ، مفرَّغةً نصاً مع الصوت والفوائد المستخرجة.</p><span class="card-cta">تصفّح ←</span></a>
      <a class="card" href="/people"><div class="ufa5a688">د</div><div class="card-title ua3ba3b1" >الأعلام</div><p class="card-sub uf04e97f" >تراجمُ الناظمين والمصنِّفين والشُّرّاح، وما لكلٍّ منهم في الأرشيف.</p><span class="card-cta">تصفّح ←</span></a>
    </div>
  </div>

  <div class="wrap-mid u508c612" >
    <div class="quote-band">
      <div class="ornament u4ee229d" >۞</div>
      <p data-ar>المحتوى هو الأصل، والتقنيةُ طبقةٌ قابلةٌ للاستبدال.</p>
      <div class="faint u7ad698b" >من مبادئ أهل الأثر</div>
    </div>
  </div>

  {latest.length > 0 && (
    <div class="home-section u3a4c3ff" >
      <div class="section-label">أحدث الإضافات</div>
      {latest.map(({ e, kind, color }) => (
        <a class="latest-row" href={hrefFor(e.collection, e.id, { series: e.data.series })}>
          <span class:list={[...["pill", color], "uac6ea07"]} >{kind}</span>
          <span class="latest-name">{e.data.title}</span>
          {e.data.person && <span class="faint u5e0faad" >{personName.get(e.data.person)}</span>}
        </a>
      ))}
    </div>
  )}
</Base>
