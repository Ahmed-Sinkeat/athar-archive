---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import BrowseGroups from "../components/BrowseGroups.astro";
import SectionSearch from "../components/SectionSearch.astro";
import { personNameMap, loadGraph } from "../lib/site";
import { hrefFor, labelFor } from "../lib/display";
import { buildSubjectGroups } from "../lib/browse";
import { collectionLd } from "../lib/structured-data";

const graph = await loadGraph();
const names = await personNameMap();
const { groups, uncategorized } = buildSubjectGroups("book", graph);
const card = (it: any) => ({
  href: hrefFor("book", it.id),
  title: it.data.title,
  kind: labelFor("book", it.data),
  sub: it.data.person ? names.get(it.data.person) ?? "" : "",
  cta: "ادخل القراءة ←",
});
---
<Base title="الكتب" description="متونٌ ومراجعُ ومجاميعُ محقَّقةٌ مُشكَّلةٌ، مرتَّبةٌ حسب الفنِّ." activeNav="books" searchScope={{ type: "book" }} jsonLd={collectionLd({ title: "الكتب", path: "/books", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الكتب", path: "/books" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الكتب" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">الكتب</h1>
    <SectionSearch scope="book" placeholder="ابحث في الكتب…" />
    <BrowseGroups groups={groups} uncategorized={uncategorized} card={card} unit="كتابًا" personNames={names} />
  </div>
</Base>
