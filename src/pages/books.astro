---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import EntityCard from "../components/EntityCard.astro";
import { personNameMap, isPub } from "../lib/site";
import { hrefFor, labelFor } from "../lib/display";

const books = (await getCollection("book")).filter(isPub);
const names = await personNameMap();

const items = books
  .map((e) => ({
    kind: labelFor("book", e.data),
    filterKey: (e.data as any).kind ?? "متن",
    href: hrefFor("book", e.id),
    title: e.data.title,
    sub: `${names.get(e.data.person) ?? ""}`,
  }))
  .sort((a, b) => a.title.localeCompare(b.title, "ar"));
---
<Base title="الكتب" description="متونٌ ومراجعُ ومجاميعُ محقَّقةٌ مُشكَّلةٌ، مرتَّبةٌ حسب الفنِّ." activeNav="books" searchScope={{ type: "book" }}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الكتب" }]} />
  <div class="wrap-mid uf5db21c" >
    <h1 class="page-title">الكتب</h1>
    <p class="page-intro">المتونُ والمراجعُ والمجاميعُ، مُحقَّقةٌ مُشكَّلةٌ. اختر كتاباً للدخول في وضع القراءة.</p>

    <div class="u1b7f0c1" data-filterbar>
      <button class="chip" data-filter="all" aria-pressed="true">الكل</button>
      <button class="chip" data-filter="متن" aria-pressed="false">المتون</button>
      <button class="chip" data-filter="مرجع" aria-pressed="false">المراجع</button>
      <button class="chip" data-filter="مجموع" aria-pressed="false">المجاميع</button>
    </div>

    <div class="card-grid">
      {items.map((it) => (
        <EntityCard href={it.href} title={it.title} kind={it.kind} sub={it.sub} filterKey={it.filterKey} cta="ادخل القراءة ←" />
      ))}
    </div>
  </div>

  <script is:inline>
    (() => {
      const bar = document.querySelector("[data-filterbar]");
      if (!bar) return;
      const cards = [...document.querySelectorAll(".card[data-kind]")];
      bar.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-filter]");
        if (!btn) return;
        const f = btn.dataset.filter;
        bar.querySelectorAll("[data-filter]").forEach((b) => b.setAttribute("aria-pressed", String(b === btn)));
        cards.forEach((c) => { c.style.display = f === "all" || c.dataset.kind === f ? "" : "none"; });
      });
    })();
  </script>
</Base>
