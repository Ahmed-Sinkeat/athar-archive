---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import BrowseGroups from "../components/BrowseGroups.astro";
import { personNameMap, loadGraph } from "../lib/site";
import { hrefFor, labelFor } from "../lib/display";
import { buildSubjectGroups } from "../lib/browse";
import { collectionLd } from "../lib/structured-data";

// الحديث: متونه، تخاريجه، علله وسؤالاته. Numbered-hadith units + grading come
// in a later phase; for now this is the books carrying genre:حديث.
const graph = await loadGraph();
const names = await personNameMap();
const { groups, uncategorized } = buildSubjectGroups("book", graph, (e) => (e.data as any).genre === "حديث");
const has = groups.length > 0 || uncategorized.length > 0;
const card = (it: any) => ({
  href: hrefFor("book", it.id),
  title: it.data.title,
  kind: labelFor("book", it.data),
  sub: it.data.person ? names.get(it.data.person) ?? "" : "",
  cta: "ادخل القراءة ←",
});
---
<Base title="الحديث" description="متونُ الحديثِ وتخاريجُه وعلَلُه." activeNav="hadith" jsonLd={collectionLd({ title: "الحديث", path: "/hadith", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الحديث", path: "/hadith" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الحديث" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">الحديث</h1>
    {has
      ? <BrowseGroups groups={groups} uncategorized={uncategorized} card={card} unit="كتابًا" personNames={names} />
      : <p class="faint">لا توجد موادُّ في هذا القسم بعد.</p>}
  </div>
</Base>
