---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import BrowseGroups from "../components/BrowseGroups.astro";
import { personNameMap, loadGraph } from "../lib/site";
import { hrefFor, labelFor } from "../lib/display";
import { buildSubjectGroups } from "../lib/browse";
import { collectionLd } from "../lib/structured-data";
import { getCollection } from "astro:content";

const graph = await loadGraph();
const names = await personNameMap();
const { groups, uncategorized } = buildSubjectGroups("book", graph, (e) => (e.data as any).genre === "حديث");

const hadithBooks = (await getCollection("book")).filter(b => (b.data as any).genre === "حديث" && (b.data as any).status !== "draft");
const categoryCounts: Record<string, number> = {};
for (const b of hadithBooks) {
  const cat = (b.data as any).hadith_category;
  if (cat) categoryCounts[cat] = (categoryCounts[cat] ?? 0) + 1;
}
const catOrder = ["امهات الكتب", "كتب الآثار", "أجزاء حديثية", "تخريج", "علل", "عام"];
const cats = catOrder.filter((c) => categoryCounts[c]);

// Grading facet: count تخريج annotations that carry a grade
const allAnnotations = await getCollection("annotation");
const gradeCounts: Record<string, number> = {};
for (const ann of allAnnotations) {
  if ((ann.data as any).kind === "تخريج" && (ann.data as any).grade) {
    const g = (ann.data as any).grade as string;
    gradeCounts[g] = (gradeCounts[g] ?? 0) + 1;
  }
}
const gradeOrder = ["صحيح", "حسن", "ضعيف", "موضوع"];
const grades = gradeOrder.filter((g) => gradeCounts[g]);
const has = groups.length > 0 || uncategorized.length > 0;
const card = (it: any) => ({
  href: hrefFor("book", it.id),
  title: it.data.title,
  kind: labelFor("book", it.data),
  audio: graph.audioForSource("book", it.id).length > 0,
  sub: it.data.person ? names.get(it.data.person) ?? "" : "",
  cta: "ادخل القراءة ←",
});
---
<Base title="الحديث" description="متونُ الحديثِ وتخاريجُه وعلَلُه." activeNav="hadith" jsonLd={collectionLd({ title: "الحديث", path: "/hadith", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الحديث", path: "/hadith" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الحديث" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">الحديث</h1>
    {grades.length > 0 && (
      <div class="grade-facet">
        {grades.map((g) => <span class={`grade grade-${g}`}>{g} ({gradeCounts[g]})</span>)}
      </div>
    )}
    {cats.length > 0 && (
      <div class="grade-facet" style="margin-top: 0.5rem; margin-bottom: 1rem;">
        {cats.map((c) => <span class="pill" style="font-size: 0.8em;">{c} ({categoryCounts[c]})</span>)}
      </div>
    )}
    {has
      ? <BrowseGroups groups={groups} uncategorized={uncategorized} card={card} unit="كتابًا" personNames={names} />
      : <p class="faint">لا توجد موادُّ في هذا القسم بعد.</p>}
  </div>
</Base>
