---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { personNameMap, loadGraph } from "../lib/site";
import { hrefFor, labelFor, toArabicDigits } from "../lib/display";
import { collectionLd } from "../lib/structured-data";
import { getCollection } from "astro:content";
import hadithIndex from "../data/hadith-index.json";

const graph = await loadGraph();
const names = await personNameMap();

const hadithBooks = (await getCollection("book")).filter(
  (b) => (b.data as any).genre === "حديث" && b.data.status === "published"
);

// hadith count per matn: index keys are `slug:N`
const hadithCounts: Record<string, number> = {};
for (const key of Object.keys(hadithIndex as Record<string, unknown>)) {
  const slug = key.slice(0, key.lastIndexOf(":"));
  hadithCounts[slug] = (hadithCounts[slug] ?? 0) + 1;
}
const sharhCountLabel = (n: number) =>
  n === 1 ? "شرحٌ واحد" : n === 2 ? "شرحان" : n >= 3 && n <= 10 ? `${toArabicDigits(n)} شروح` : `${toArabicDigits(n)} شرحًا`;

const row = (b: any) => {
  const kind = labelFor("book", b.data);
  const meta: string[] = [];
  if (hadithCounts[b.id]) meta.push(`${toArabicDigits(hadithCounts[b.id])} حديثًا`);
  const sharhs = graph.commentariesOf(b.id).length;
  if (sharhs) meta.push(sharhCountLabel(sharhs));
  return {
    href: hrefFor("book", b.id),
    kind,
    accent: kind === "متن" || kind === "مصدر أصلي",
    title: b.data.title as string,
    author: b.data.person ? names.get(b.data.person) ?? "" : "",
    meta: meta.join(" · "),
  };
};

// sections per mockup: المتون / المصادر الأصلية / الشروح (+ بقية الكتب)
const byKind = (k: string) => hadithBooks.filter((b) => labelFor("book", b.data) === k).map(row);
const sections = [
  { title: "المتون", items: byKind("متن") },
  { title: "المصادر الأصلية", items: byKind("مصدر أصلي") },
  { title: "الشروح", items: byKind("شرح") },
  {
    title: "كتبٌ أخرى",
    items: hadithBooks.filter((b) => !["متن", "مصدر أصلي", "شرح"].includes(labelFor("book", b.data))).map(row),
  },
].filter((s) => s.items.length > 0);

// حديث الأسبوع — same weekly rotation as the home page
const highlights = (await getCollection("highlight")).filter(
  (h) => h.data.status === "published" && h.data.kind === "حديث"
);
const wk = Math.floor(Date.now() / 6.048e8);
const featured = highlights.length ? highlights[wk % highlights.length] : null;
const featuredSrc =
  featured?.data.source_type && featured?.data.source_id
    ? hrefFor(featured.data.source_type as string, featured.data.source_id as string)
    : null;
---
<Base title="الحديث" description="متونُ الحديثِ بأسانيدِها وتخاريجِها وعلَلِها، مع شروحِ الأئمة." activeNav="hadith" jsonLd={collectionLd({ title: "الحديث", path: "/hadith", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الحديث", path: "/hadith" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الحديث" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">الحديث وعلومُه</h1>
    <p class="hub-lede">متونُ الحديثِ بأسانيدِها وتخاريجِها وعلَلِها، مع شروحِ الأئمة.</p>

    {featured && (
      <div class="hadith-featured">
        <div class="weekly-kicker k-green">حديثُ الأسبوع</div>
        <p class="hadith-featured-text" data-ar>{(featured.body ?? "").trim()}</p>
        <div class="hadith-featured-foot">
          {featured.data.reference && <span class="faint">{featured.data.reference}</span>}
          {featuredSrc && <a class="hadith-featured-cta" href={featuredSrc}>اقرأ مع الشرح ←</a>}
        </div>
      </div>
    )}

    {sections.map((s) => (
      <section class="hub-section">
        <div class="section-head green">
          <h2>{s.title}</h2>
          <span class="section-count">{toArabicDigits(s.items.length)}</span>
          <div class="rule-fill"></div>
        </div>
        {s.items.map((it) => (
          <a class="latest-row" href={it.href}>
            <span class:list={["type-badge", "green", { accent: it.accent }]}>{it.kind}</span>
            <span class="latest-name">{it.title}</span>
            {it.author && <span class="faint row-author">{it.author}</span>}
            <span class="row-spacer"></span>
            {it.meta && <span class="row-meta">{it.meta}</span>}
            <span class="latest-arrow">←</span>
          </a>
        ))}
      </section>
    ))}
    {sections.length === 0 && <p class="faint">لا توجد موادُّ في هذا القسم بعد.</p>}
  </div>
</Base>

<style>
  /* featured hadith anatomy card — 3px green right border (HANDOFF §5 الحديث hub) */
  .hadith-featured {
    background: var(--card); border: 1px solid var(--line); border-inline-start: 3px solid var(--green);
    border-radius: 10px; padding: 24px 26px; margin: 26px 0 40px;
  }
  .hadith-featured-text {
    margin: 14px 0 16px; font-family: var(--f-matn); font-weight: 600;
    font-size: calc(19px * var(--reading-scale)); line-height: 2.1; color: var(--ink);
  }
  .hadith-featured-foot { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; font-size: 12px; }
  .hadith-featured-cta {
    margin-inline-start: auto; font-family: var(--f-ui); font-size: 12.5px; font-weight: 600;
    color: var(--green); text-decoration: none;
  }
</style>
