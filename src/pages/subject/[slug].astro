---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import EntityCard from "../../components/EntityCard.astro";
import TypeFilter from "../../components/TypeFilter.astro";
import { isPub, loadGraph } from "../../lib/site";
import { ENTITY, hrefFor, toArabicDigits } from "../../lib/display";
import { collectionLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const subjects = (await getCollection("subject")).filter(isPub);
  const graph = await loadGraph();
  return subjects.map((entry) => {
    const topics = graph.topicsBySubject(entry.id).filter(isPub).map((t) => ({ id: t.id, title: t.data.title }));
    const materials = graph
      .materialsBySubject(entry.id)
      .filter(isPub)
      .map((m) => ({ collection: m.collection, id: m.id, title: m.data.title as string, series: m.data.series as string | undefined }));
    return { params: { slug: entry.id }, props: { entry, topics, materials } };
  });
}

const { entry, topics, materials } = Astro.props;
const path = `/subject/${entry.id}`;
const jsonLd = collectionLd({
  title: entry.data.title, description: entry.data.description, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الموضوعات", path: "/subjects" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} description={entry.data.description} activeNav="subjects" jsonLd={jsonLd}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الموضوعات", href: "/subjects" }, { label: entry.data.title }]} />
  <div class="wrap-mid uf5db21c" >
    <h1 class="page-title">{entry.data.title}</h1>
    {entry.data.description && <p class="page-intro">{entry.data.description}</p>}

    {topics.length > 0 && (
      <div class="u28e5a30">
        <div class="section-label">الموضوعات · {toArabicDigits(topics.length)}</div>
        <div class="chip-row">
          {topics.map((t) => <a class="chip" href={hrefFor("topic", t.id)}>{t.title}</a>)}
        </div>
      </div>
    )}

    {materials.length > 0 && (
      <div data-typefilter-scope>
        <div class="section-label">المواد المرتبطة · {toArabicDigits(materials.length)}</div>
        <TypeFilter types={[...new Set(materials.map((m) => m.collection))]} />
        <ol class="flat-list">
          {materials.map((m) => (
            <li>
              <EntityCard href={hrefFor(m.collection, m.id, { series: m.series })} title={m.title} kind={ENTITY[m.collection]?.one} filterKey={m.collection} cta="اطّلع ←" />
            </li>
          ))}
        </ol>
      </div>
    )}
  </div>
</Base>
