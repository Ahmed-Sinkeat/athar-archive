---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import SortableList from "../components/SortableList.astro";
import TitleFilter from "../components/TitleFilter.astro";
import { personNameMap, loadGraph } from "../lib/site";
import { hrefFor, isMatn, labelFor } from "../lib/display";
import { collectionLd } from "../lib/structured-data";
import type { ContentEntry } from "../lib/types";

const graph = await loadGraph();
const names = await personNameMap();

// كل المتون: every published منظومة + كتاب marked متن, in one flat sortable list.
const yr = (e: ContentEntry) => (e.data as { authored_year?: number }).authored_year ?? Number.POSITIVE_INFINITY;
const items = graph.all
  .filter((e) => (e.collection === "poem" || e.collection === "book") && e.data.status === "published" && isMatn(e.collection, e.data))
  .sort((a, b) => yr(a) - yr(b) || (a.data.title as string).localeCompare(b.data.title as string, "ar"));

const card = (it: ContentEntry) => ({
  href: hrefFor(it.collection, it.id),
  title: it.data.title,
  kind: labelFor(it.collection, it.data),
  audio: graph.audioForSource(it.collection, it.id).length > 0,
  sub: it.data.person ? names.get(it.data.person as string) ?? "" : "",
  cta: "ادخل القراءة ←",
});
---
<Base title="المتون" description="كلُّ ما يُحفظ ويُدرَّس: المنظوماتُ ومتونُ الكتب، مُشكَّلةً مرتَّبةً." activeNav="books" jsonLd={collectionLd({ title: "المتون", path: "/matn", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "المتون", path: "/matn" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "المتون" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">المتون</h1>
    <TitleFilter placeholder="تصفية حسب العنوان…" />
    <SortableList items={items} card={card} />
  </div>
</Base>
