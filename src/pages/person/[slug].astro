---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import EntityCard from "../../components/EntityCard.astro";
import Prose from "../../components/Prose.astro";
import { isPub, loadGraph } from "../../lib/site";
import { ENTITY, hrefFor } from "../../lib/display";

export async function getStaticPaths() {
  const people = (await getCollection("person")).filter(isPub);
  const graph = await loadGraph();
  return people.map((entry) => {
    const works = graph
      .materialsByPerson(entry.id)
      .filter(isPub)
      .map((w) => ({ collection: w.collection, id: w.id, title: w.data.title, series: w.data.series }));
    return { params: { slug: entry.id }, props: { entry, works } };
  });
}

const { entry, works } = Astro.props;
const meta = [entry.data.born && `و. ${entry.data.born}`, entry.data.died && `ت. ${entry.data.died}`, entry.data.location]
  .filter(Boolean)
  .join(" · ");
---
<Base title={entry.data.title} description={entry.data.bio} activeNav="people" searchMeta={{ title: entry.data.title, type: "person" }}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الأعلام", href: "/people" }, { label: entry.data.title }]} />
  <div class="wrap-mid" style="padding-block:18px 96px">
    <h1 class="page-title">{entry.data.title}</h1>
    {meta && <div class="reader-byline" style="text-align:right;margin-top:0">{meta}</div>}
    {entry.body?.trim() && <div style="margin:22px 0 8px;max-width:60ch"><Prose body={entry.body} /></div>}

    {works.length > 0 && (
      <div style="margin-top:36px">
        <div class="section-label">من آثارِه في الأرشيف</div>
        <div class="card-grid">
          {works.map((w) => (
            <EntityCard
              href={hrefFor(w.collection, w.id, { series: w.series })}
              title={w.title}
              kind={ENTITY[w.collection]?.one}
              cta="اطّلع ←"
            />
          ))}
        </div>
      </div>
    )}
  </div>
</Base>
