---
// On-demand (migration plan, Phase 3): instead of pre-building every lesson, the
// Worker resolves the series + lesson param, reads the one lesson .md from ASSETS,
// renders, and the middleware edge-caches it. Prep for the ~2k lessons coming.
export const prerender = false;

import { getEntry } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import Prose from "../../../components/Prose.astro";
import AudioPlayer from "../../../components/AudioPlayer.astro";
import { isPub, loadGraph, personNameMap } from "../../../lib/site";
import { parseLesson } from "../../../lib/chapters";
import { loadContentBody, notFound } from "../../../lib/book-asset";
import { hrefFor, lessonParam, toArabicDigits } from "../../../lib/display";
import { lessonLd } from "../../../lib/structured-data";

const { slug, lesson: lessonSlug } = Astro.params as { slug: string; lesson: string };

const series = await getEntry("series", slug);
if (!series || !isPub(series)) return notFound();

// ponytail: full graph build per cold request (lessonsBySeries + benefits/audio
// lookups); fine at current scale, edge-cached. Scope to getCollection if it drags.
const graph = await loadGraph();
const names = await personNameMap();
const lessons = graph.lessonsBySeries(slug).filter(isPub);
const i = lessons.findIndex((l) => lessonParam(l.id, slug) === lessonSlug);
if (i < 0) return notFound();
const lesson = lessons[i];

const lessonBody = await loadContentBody("lesson", lesson.id);
if (lessonBody == null) return notFound();

const headings = parseLesson(lessonBody).headings.filter((h) => h.depth === 2);
const audioEntry = graph.audioForSource("lesson", lesson.id)[0];
const audio = audioEntry ? { url: audioEntry.data.url, format: audioEntry.data.format, duration: audioEntry.data.duration ?? null, sizeBytes: audioEntry.data.size_bytes ?? null } : null;
const benefits = graph.benefitsForSource("lesson", lesson.id).filter(isPub).map((b) => b.data.title);
const lite = (e: any) => (e ? { param: lessonParam(e.id, slug), title: e.data.title, order: e.data.order } : null);
const prev = lite(lessons[i - 1]);
const next = lite(lessons[i + 1]);
const idx = i + 1, total = lessons.length, author = names.get(series.data.person);
const seriesPath = hrefFor("series", series.id);
const path = `/series/${series.id}/${lessonParam(lesson.id, series.id)}`;
const jsonLd = lessonLd({
  title: lesson.data.title, seriesTitle: series.data.title, seriesPath, authorName: author,
  audioUrl: audio?.url, path,
  crumbs: [
    { name: "الرئيسية", path: "/" }, { name: "الدروس", path: "/series" },
    { name: series.data.title, path: seriesPath }, { name: `الدرس ${idx}`, path },
  ],
});
---
<Base title={lesson.data.title} description={`${series.data.title} — الدرس ${idx}`} activeNav="series" ogType="article" jsonLd={jsonLd} searchMeta={{ title: lesson.data.title, type: "lesson", person: author }}>
  <Breadcrumbs
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الدروس", href: "/series" },
      { label: series.data.title, href: hrefFor("series", series.id) },
      { label: `الدرس ${toArabicDigits(idx)}` },
    ]}
  />
  <div class="wrap-mid u2408e22" >
    <div class="eyebrow u89ad788" >الدرس {toArabicDigits(idx)} من {toArabicDigits(total)}</div>
    <h1 class="page-title u266157e" >{lesson.data.title}</h1>
    <div class="reader-byline u7961f65" >
      {author}{lesson.data.duration ? ` · مدة الدرس ${lesson.data.duration}` : ""}
    </div>

    {audio && <AudioPlayer sources={[audio]} label="الاستماع إلى الدرس" />}

    <div class="lesson-grid">
      <div class="transcript">
        <Prose body={lessonBody} />

        {benefits.length > 0 && (
          <div class="benefit-strip">
            <div class="toc-label uec818db" >فوائدُ مستخرجةٌ من الدرس</div>
            <div class="benefit-grid">
              {benefits.map((b: string) => <div class="benefit-quote" data-ar>«{b}»</div>)}
            </div>
          </div>
        )}

        <div class="prevnext">
          {prev ? <a href={`/series/${series.id}/${prev.param}`}>→ الدرس {toArabicDigits(prev.order)}: {prev.title}</a> : <span></span>}
          {next && <a class="next" href={`/series/${series.id}/${next.param}`}>الدرس {toArabicDigits(next.order)}: {next.title} ←</a>}
        </div>
      </div>

      {headings.length > 0 && (
        <aside class="toc-side">
          <div class="toc-box">
            <div class="toc-label">فهرس الدرس</div>
            {headings.map((h: any) => <a href={`#${h.slug}`}>{h.title}</a>)}
          </div>
        </aside>
      )}
    </div>
  </div>
</Base>
