---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import Prose from "../../../components/Prose.astro";
import { isPub, loadGraph, personNameMap } from "../../../lib/site";
import { parseLesson } from "../../../lib/chapters";
import { hrefFor, lessonParam, toArabicDigits } from "../../../lib/display";

export async function getStaticPaths() {
  const seriesList = (await getCollection("series")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  const paths: any[] = [];
  for (const s of seriesList) {
    const lessons = graph.lessonsBySeries(s.id).filter(isPub);
    lessons.forEach((lesson, i) => {
      const headings = parseLesson(lesson.body ?? "").headings.filter((h) => h.depth === 2);
      const audioEntry = graph.audioForSource("lesson", lesson.id)[0];
      const benefits = graph.benefitsForSource("lesson", lesson.id).filter(isPub).map((b) => b.data.title);
      const prev = lessons[i - 1];
      const next = lessons[i + 1];
      const lite = (e: any) => (e ? { param: lessonParam(e.id, s.id), title: e.data.title, order: e.data.order } : null);
      paths.push({
        params: { slug: s.id, lesson: lessonParam(lesson.id, s.id) },
        props: {
          series: s, lesson, headings, benefits,
          audio: audioEntry ? { url: audioEntry.data.url, duration: audioEntry.data.duration ?? null } : null,
          prev: lite(prev), next: lite(next),
          idx: i + 1, total: lessons.length, author: names.get(s.data.person),
        },
      });
    });
  }
  return paths;
}

const { series, lesson, headings, benefits, audio, prev, next, idx, total, author } = Astro.props;
---
<Base title={lesson.data.title} description={`${series.data.title} — الدرس ${idx}`} activeNav="series" searchMeta={{ title: lesson.data.title, type: "lesson" }}>
  <Breadcrumbs
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الدروس", href: "/series" },
      { label: series.data.title, href: hrefFor("series", series.id) },
      { label: `الدرس ${toArabicDigits(idx)}` },
    ]}
  />
  <div class="wrap-mid" style="padding-block:18px 130px">
    <div class="eyebrow" style="letter-spacing:.18em;margin-bottom:10px">الدرس {toArabicDigits(idx)} من {toArabicDigits(total)}</div>
    <h1 class="page-title" style="font-size:clamp(28px,4.5vw,42px)">{lesson.data.title}</h1>
    <div class="reader-byline" style="text-align:right;margin-top:0;margin-bottom:20px">
      {author}{lesson.data.duration ? ` · مدة الدرس ${lesson.data.duration}` : ""}
    </div>

    {audio && (
      <div class="audio-bar">
        <a class="audio-play" href={audio.url} aria-label="تشغيل الصوت"></a>
        <span style="flex:1;font-family:var(--font-ui);font-size:13px;color:var(--ink-soft)">الاستماع إلى الدرس</span>
        {audio.duration && <span class="audio-time">{audio.duration}</span>}
        <a class="btn" href={audio.url} style="padding:6px 12px;font-size:12px">تحميل</a>
      </div>
    )}

    <div class="lesson-grid">
      <div class="transcript">
        <Prose body={lesson.body ?? ""} />

        {benefits.length > 0 && (
          <div class="benefit-strip">
            <div class="toc-label" style="font-size:11.5px;letter-spacing:.16em;margin-bottom:14px">فوائدُ مستخرجةٌ من الدرس</div>
            <div class="benefit-grid">
              {benefits.map((b: string) => <div class="benefit-quote" data-ar>«{b}»</div>)}
            </div>
          </div>
        )}

        <div class="prevnext">
          {prev ? <a href={`/series/${series.id}/${prev.param}`}>→ الدرس {toArabicDigits(prev.order)}: {prev.title}</a> : <span></span>}
          {next && <a class="next" href={`/series/${series.id}/${next.param}`}>الدرس {toArabicDigits(next.order)}: {next.title} ←</a>}
        </div>
      </div>

      {headings.length > 0 && (
        <aside class="toc-side">
          <div class="toc-box">
            <div class="toc-label">فهرس الدرس</div>
            {headings.map((h: any) => <a href={`#${h.slug}`}>{h.title}</a>)}
          </div>
        </aside>
      )}
    </div>
  </div>
</Base>
