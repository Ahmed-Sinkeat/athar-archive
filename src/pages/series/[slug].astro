---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { isPub, loadGraph, personNameMap } from "../../lib/site";
import { hrefFor, toArabicDigits, sourceHref } from "../../lib/display";
import { seriesLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const seriesList = (await getCollection("series")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  return seriesList.map((entry) => {
    const lessons = graph.lessonsBySeries(entry.id).map((l) => ({
      id: l.id, title: l.data.title, order: l.data.order,
      published: l.data.status === "published", duration: l.data.duration ?? null,
    }));
    const stats = graph.seriesStats(entry.id);
    let source = null;
    if (entry.data.source_type && entry.data.source_id) {
      const s = graph.getById(entry.data.source_type, entry.data.source_id);
      if (s) source = { type: entry.data.source_type, id: s.id, title: s.data.title };
    }
    return { params: { slug: entry.id }, props: { entry, lessons, stats, source, author: names.get(entry.data.person) } };
  });
}

const { entry, lessons, stats, source, author } = Astro.props;
const path = `/series/${entry.id}`;
const jsonLd = seriesLd({
  title: entry.data.title, authorName: author, description: entry.data.description, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الدروس", path: "/series" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} description={entry.data.description} activeNav="series" ogType="article" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "series", person: author }}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الدروس", href: "/series" }, { label: entry.data.title }]} />
  <div class="wrap-mid uf5db21c" >
    <div class="tag-verdigris u649209a" >
      سلسلة · {toArabicDigits(stats.publishedLessonCount)} درسًا{stats.totalSeconds > 0 ? ` · ${stats.totalDuration}` : ""}
    </div>
    <h1 class="page-title">{entry.data.title}</h1>
    <div class="reader-byline u56a6980" >{author}</div>
    {source && (
      <p class="page-intro u8677744" >
        شرحٌ لـ
        <a href={sourceHref(source.type, source.id)} class="uae3c165">{source.title}</a>.
      </p>
    )}

    <div class="u2afe04c">
      {lessons.map((l, i) => (
        <>
          {i > 0 && <div class="u86c1892"></div>}
          {l.published ? (
            <a href={hrefFor("lesson", l.id, { series: entry.id })} class="u9b1b542">
              <span class="vnum ud462248" >{toArabicDigits(l.order)}</span>
              <span class="uec199bb">{l.title}</span>
              {l.duration && <span class="faint u58cb331" >{l.duration}</span>}
            </a>
          ) : (
            <div class="u3c8627f">
              <span class="vnum u65145c1" >{toArabicDigits(l.order)}</span>
              <span class="u04850af">{l.title}</span>
              <span class="faint u11a5081" >قيد الإعداد</span>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</Base>
