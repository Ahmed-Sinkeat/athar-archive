---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { isPub, loadGraph, personNameMap } from "../../lib/site";
import { hrefFor, toArabicDigits, sourceHref } from "../../lib/display";

export async function getStaticPaths() {
  const seriesList = (await getCollection("series")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  return seriesList.map((entry) => {
    const lessons = graph.lessonsBySeries(entry.id).map((l) => ({
      id: l.id, title: l.data.title, order: l.data.order,
      published: l.data.status === "published", duration: l.data.duration ?? null,
    }));
    const stats = graph.seriesStats(entry.id);
    let source = null;
    if (entry.data.source_type && entry.data.source_id) {
      const s = graph.getById(entry.data.source_type, entry.data.source_id);
      if (s) source = { type: entry.data.source_type, id: s.id, title: s.data.title };
    }
    return { params: { slug: entry.id }, props: { entry, lessons, stats, source, author: names.get(entry.data.person) } };
  });
}

const { entry, lessons, stats, source, author } = Astro.props;
---
<Base title={entry.data.title} description={entry.data.description} activeNav="series" searchMeta={{ title: entry.data.title, type: "series" }}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الدروس", href: "/series" }, { label: entry.data.title }]} />
  <div class="wrap-mid" style="padding-block:18px 96px">
    <div class="tag-verdigris" style="font-family:var(--font-ui);font-size:12px;letter-spacing:.18em;margin-bottom:10px">
      سلسلة · {toArabicDigits(stats.publishedLessonCount)} درسًا{stats.totalSeconds > 0 ? ` · ${stats.totalDuration}` : ""}
    </div>
    <h1 class="page-title">{entry.data.title}</h1>
    <div class="reader-byline" style="text-align:right;margin-top:0;margin-bottom:6px">{author}</div>
    {source && (
      <p class="page-intro" style="margin-bottom:24px">
        شرحٌ لـ
        <a href={sourceHref(source.type, source.id)} style="color:var(--accent);text-decoration:none">{source.title}</a>.
      </p>
    )}

    <div style="border:1px solid var(--rule);border-radius:14px;background:var(--surface);overflow:hidden;max-width:760px">
      {lessons.map((l, i) => (
        <>
          {i > 0 && <div style="height:1px;background:var(--rule)"></div>}
          {l.published ? (
            <a href={hrefFor("lesson", l.id, { series: entry.id })} style="display:flex;align-items:center;gap:14px;padding:15px 20px;text-decoration:none">
              <span class="vnum" style="margin-top:0">{toArabicDigits(l.order)}</span>
              <span style="flex:1;font-family:var(--font-display);font-size:17px;color:var(--ink)">{l.title}</span>
              {l.duration && <span class="faint" style="font-size:12px;direction:ltr">{l.duration}</span>}
            </a>
          ) : (
            <div style="display:flex;align-items:center;gap:14px;padding:15px 20px;opacity:.5">
              <span class="vnum" style="margin-top:0;color:var(--ink-faint);border-color:var(--rule)">{toArabicDigits(l.order)}</span>
              <span style="flex:1;font-family:var(--font-display);font-size:17px;color:var(--ink-soft)">{l.title}</span>
              <span class="faint" style="font-size:11px">قيد الإعداد</span>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</Base>
