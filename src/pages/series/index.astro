---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BrowseGroups from "../../components/BrowseGroups.astro";
import { personNameMap, loadGraph } from "../../lib/site";
import { hrefFor, toArabicDigits } from "../../lib/display";
import { buildSubjectGroups } from "../../lib/browse";

const graph = await loadGraph();
const names = await personNameMap();
const { groups, uncategorized } = buildSubjectGroups("series", graph);
const card = (it: any) => {
  const s = graph.seriesStats(it.id);
  return {
    href: hrefFor("series", it.id),
    title: it.data.title,
    kind: `سلسلة · ${toArabicDigits(s.publishedLessonCount)} درسًا`,
    kindColor: "tag-verdigris",
    sub: it.data.person ? names.get(it.data.person) ?? "" : "",
    corner: s.totalSeconds > 0 ? `مدة · ${s.totalDuration}` : undefined,
    cta: "ادخل السلسلة ←",
  };
};
---
<Base title="الدروس" description="سلاسلُ شرحِ المتونِ، مفرَّغةً نصاً مع الصوت والفهرس والفوائد المستخرجة." activeNav="series">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الدروس" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">الدروس</h1>
    <p class="page-intro">سلاسلُ شرحِ المتونِ، مفرَّغةً نصاً مع الصوتِ والفهرسِ والفوائدِ، مرتَّبةٌ حسب الفنِّ ثم الموضوع.</p>
    <BrowseGroups groups={groups} uncategorized={uncategorized} card={card} unit="سلسلة" otherLabel="سلاسلُ أخرى" />
  </div>
</Base>
