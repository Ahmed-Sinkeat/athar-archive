---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { loadGraph } from "../lib/site";
import { hrefFor } from "../lib/display";
import type { ContentEntry } from "../lib/types";

// Obsidian-style knowledge graph of the whole archive. Nodes = published entities;
// edges = author / topic / subject / series links. Data is embedded as a JSON
// data block (not executed → CSP-safe) and drawn client-side by force-graph.
const graph = await loadGraph();
const isPub = (e: ContentEntry) => e.data.status === "published";
const TYPES = ["book", "poem", "person", "series", "lesson", "subject", "topic", "article", "question", "benefit"];
const nid = (c: string, id: string) => `${c}:${id}`;

const nodeSet = new Set<string>();
const nodes: { id: string; label: string; type: string; href: string }[] = [];
for (const e of graph.all) {
  if (!TYPES.includes(e.collection) || !isPub(e)) continue;
  const id = nid(e.collection, e.id);
  if (nodeSet.has(id)) continue;
  nodeSet.add(id);
  nodes.push({ id, label: e.data.title as string, type: e.collection, href: hrefFor(e.collection, e.id, { series: (e.data as any).series }) });
}

const links: { source: string; target: string }[] = [];
const addLink = (a: string, b: string) => { if (a !== b && nodeSet.has(a) && nodeSet.has(b)) links.push({ source: a, target: b }); };
for (const e of graph.all) {
  if (!isPub(e)) continue;
  const id = nid(e.collection, e.id);
  if (e.data.person) addLink(id, nid("person", e.data.person as string));
  for (const t of ((e.data.topics as string[]) ?? [])) addLink(id, nid("topic", t));
  if (e.collection === "topic" && e.data.subject) addLink(id, nid("subject", e.data.subject as string));
  if (e.collection === "lesson" && e.data.series) addLink(id, nid("series", e.data.series as string));
  if (e.collection === "series" && e.data.source_type && e.data.source_id) addLink(id, nid(e.data.source_type as string, e.data.source_id as string));
}

const gdata = JSON.stringify({ nodes, links }).replace(/</g, "\\u003c");
---
<Base title="شبكة المعرفة" description="رسمٌ بيانيٌّ تفاعليٌّ يربط كتبَ الأرشيف ومنظوماتِه وأعلامَه وفنونَه." noindex>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "شبكة المعرفة" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">شبكة المعرفة</h1>
    <p class="faint graph-hint">كلُّ نقطةٍ مادةٌ أو عَلَمٌ أو فنّ؛ الخطوطُ روابطُها. اسحبْ للتحريك، مرِّرْ للتكبير، وانقرِ النقطةَ لفتحِها.</p>
  </div>
  <div class="graph-wrap"><div id="graph"></div></div>
  <script type="application/json" id="gdata" set:html={gdata}></script>
  <script>
    import "../scripts/graph.ts";
  </script>
</Base>
