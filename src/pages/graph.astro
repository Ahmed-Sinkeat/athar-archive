---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits } from "../lib/display";
import type { ContentEntry } from "../lib/types";

// Obsidian-style knowledge graph of the whole archive. Nodes = published entities
// (NO individual lessons — only their series); edges = author / topic / subject /
// series links. Data is an embedded JSON block (not executed → CSP-safe), drawn
// client-side by force-graph.
const graph = await loadGraph();
const isPub = (e: ContentEntry) => e.data.status === "published";
const TYPES = ["book", "poem", "person", "series", "subject", "topic", "article", "question", "benefit"];
const nid = (c: string, id: string) => `${c}:${id}`;

const nodeSet = new Set<string>();
const nodes: { id: string; label: string; type: string; href: string }[] = [];
for (const e of graph.all) {
  if (!TYPES.includes(e.collection) || !isPub(e)) continue;
  const id = nid(e.collection, e.id);
  if (nodeSet.has(id)) continue;
  nodeSet.add(id);
  nodes.push({ id, label: e.data.title as string, type: e.collection, href: hrefFor(e.collection, e.id, { series: (e.data as any).series }) });
}

const links: { source: string; target: string }[] = [];
const addLink = (a: string, b: string) => { if (a !== b && nodeSet.has(a) && nodeSet.has(b)) links.push({ source: a, target: b }); };
for (const e of graph.all) {
  if (!isPub(e)) continue;
  const id = nid(e.collection, e.id);
  if (e.collection === "lesson") continue; // lessons aren't nodes; their series is
  if (e.data.person) addLink(id, nid("person", e.data.person as string));
  for (const t of ((e.data.topics as string[]) ?? [])) addLink(id, nid("topic", t));
  if (e.collection === "topic" && e.data.subject) addLink(id, nid("subject", e.data.subject as string));
  if (e.collection === "series" && e.data.source_type && e.data.source_id) addLink(id, nid(e.data.source_type as string, e.data.source_id as string));
  // narrator edges: person → شيوخ
  if (e.collection === "person") {
    for (const teacher of ((e.data.narrates_from as string[] | undefined) ?? [])) {
      addLink(id, nid("person", teacher));
    }
  }
}

// counts + legend/filter chips (color must mirror scripts/graph.ts COLORS)
const COLORS: Record<string, string> = {
  book: "#9c3b32", poem: "#9c3b32", benefit: "#c06a2c", person: "#2f6f6a",
  series: "#b07b00", subject: "#5a4632", topic: "#7a8a52", article: "#3f7d6e", question: "#8a8275",
};
const LABELS: Record<string, string> = {
  book: "الكتب", poem: "الشعر", person: "الأعلام", series: "السلاسل",
  subject: "التصنيفات", topic: "الموضوعات", article: "المقالات", question: "المسائل", benefit: "كُناشة",
};
const counts: Record<string, number> = {};
for (const n of nodes) counts[n.type] = (counts[n.type] ?? 0) + 1;
const present = TYPES.filter((t) => counts[t] && t !== "person");

// Scholar dashboard data
const isPubE = (e: ContentEntry) => e.data.status === "published";
const scholars = graph.all
  .filter((e) => e.collection === "person" && isPubE(e))
  .map((p) => {
    const works = graph.materialsByPerson(p.id).filter(isPubE);
    return {
      id: p.id,
      title: p.data.title as string,
      tabaqa: p.data.tabaqa as string | undefined,
      aqeedah: (p.data as any).aqeedah as string | undefined,
      died: p.data.died as string | undefined,
      worksCount: works.length,
    };
  })
  .filter((s) => s.worksCount > 0)
  .sort((a, b) => b.worksCount - a.worksCount);

const gdata = JSON.stringify({ nodes, links }).replace(/</g, "\\u003c");
---
<Base title="شبكة المعرفة" description="رسمٌ بيانيٌّ تفاعليٌّ يربط كتبَ الأرشيف ومنظوماتِه وأعلامَه وفنونَه." activeNav="graph" noindex>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "شبكة المعرفة" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">شبكة المعرفة</h1>

    <!-- stats overview -->
    <div class="dash-stats">
      {present.map((t) => (
        <div class="dash-stat">
          <div class="dash-stat-num">{toArabicDigits(counts[t])}</div>
          <div class="dash-stat-label">{LABELS[t] ?? t}</div>
        </div>
      ))}
    </div>

    <p class="faint graph-hint">كلُّ نقطةٍ مادةٌ أو عَلَمٌ أو فنّ؛ الخطوطُ روابطُها. اسحبِ النقطةَ لتحريكها، مرِّرْ للتكبير، وانقرْها لفتحِها. أزِلِ العلامةَ عن نوعٍ لإخفائه.</p>
    <div class="graph-legend" data-graph-legend>
      {present.map((t) => (
        <label class="graph-leg" data-type={t}>
          <input type="checkbox" checked />
          <span class="graph-dot" style={`background:${COLORS[t]}`}></span>
          <span class="graph-leg-name">{LABELS[t] ?? t}</span>
          <span class="faint graph-leg-count">{toArabicDigits(counts[t])}</span>
        </label>
      ))}
    </div>
  </div>
  <div class="graph-wrap"><div id="graph"></div></div>

  <!-- scholar dashboard section -->
  <!-- scholar dashboard section -->
  {scholars.length > 0 && (
    <div class="wrap-mid" style="margin-top: 48px; padding-bottom: 80px;">
      <div class="section-label">إضافة الأعلام ومؤلفاتهم إلى الشبكة</div>
      <div class="graph-person-search">
        <input type="search" id="person-search" class="pop-search" placeholder="ابحث عن عَلَم…" aria-label="ابحث عن عَلَم" style="margin-bottom: 16px;" autocomplete="off" />
        <div class="pop-checklist graph-person-list" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; max-height: 400px; overflow-y: auto;">
          {scholars.map((s) => (
            <label class="pop-check graph-person-leg" data-name={s.title}>
              <input type="checkbox" value={s.id} class="person-toggle" />
              <span class="people-name">{s.title} <span class="faint">({toArabicDigits(s.worksCount)})</span></span>
            </label>
          ))}
        </div>
      </div>
    </div>
  )}

  <script type="application/json" id="gdata" set:html={gdata}></script>
  <script>
    import "../scripts/graph.ts";
  </script>
</Base>
