---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits } from "../lib/display";
import type { ContentEntry } from "../lib/types";
import { splitChapters } from "../lib/chapters";
import { readBody } from "../lib/read-body";

// Obsidian-style knowledge graph of the whole archive. Nodes = published entities
// (NO individual lessons — only their series); edges = author / topic / subject /
// series links. Data is an embedded JSON block (not executed → CSP-safe), drawn
// client-side by force-graph.
const graph = await loadGraph();
const isPub = (e: ContentEntry) => e.data.status === "published";
const TYPES = ["book", "poem", "person", "series", "subject", "topic", "article", "question", "benefit"];
const nid = (c: string, id: string) => `${c}:${id}`;

const nodeSet = new Set<string>();
const nodes: { id: string; label: string; type: string; href: string }[] = [];
for (const e of graph.all) {
  if (!TYPES.includes(e.collection) || !isPub(e)) continue;
  const id = nid(e.collection, e.id);
  if (nodeSet.has(id)) continue;
  nodeSet.add(id);
  nodes.push({ id, label: e.data.title as string, type: e.collection, href: hrefFor(e.collection, e.id, { series: (e.data as any).series }) });
}

const links: { source: string; target: string }[] = [];
const addLink = (a: string, b: string) => { if (a !== b && nodeSet.has(a) && nodeSet.has(b)) links.push({ source: a, target: b }); };
for (const e of graph.all) {
  if (!isPub(e)) continue;
  const id = nid(e.collection, e.id);
  if (e.collection === "lesson") continue; // lessons aren't nodes; their series is
  if (e.data.person) addLink(id, nid("person", e.data.person as string));
  for (const t of ((e.data.topics as string[]) ?? [])) {
    addLink(id, nid("topic", t));
    const topicNode = graph.getById("topic", t);
    if (topicNode && topicNode.data.subject) {
      addLink(id, nid("subject", topicNode.data.subject as string));
    }
  }
  if (e.collection === "topic" && e.data.subject) addLink(id, nid("subject", e.data.subject as string));
  if (e.collection === "series" && e.data.source_type && e.data.source_id) addLink(id, nid(e.data.source_type as string, e.data.source_id as string));
  // narrator edges: person → شيوخ
  if (e.collection === "person") {
    for (const teacher of ((e.data.narrates_from as string[] | undefined) ?? [])) {
      addLink(id, nid("person", teacher));
    }
  }
}

// counts + legend/filter chips (token mapping must mirror scripts/graph.ts TOKEN_OF;
// CSS vars keep the legend theme-aware for free)
const COLORS: Record<string, string> = {
  book: "var(--brand)", question: "var(--brand)", series: "var(--brand2)",
  poem: "var(--copper)", article: "var(--copper)",
  person: "var(--green)",
  topic: "var(--gold)", benefit: "var(--gold)",
  subject: "var(--ink2)",
};
const LABELS: Record<string, string> = {
  book: "الكتب", poem: "الشعر", person: "الأعلام", series: "السلاسل",
  subject: "التصنيفات", topic: "الموضوعات", article: "مقالات ومحاضرات", question: "المسائل", benefit: "كُناشة",
};
const counts: Record<string, number> = {};
for (const n of nodes) counts[n.type] = (counts[n.type] ?? 0) + 1;
const present = TYPES.filter((t) => counts[t] && t !== "person");

// Scholar dashboard data
const isPubE = (e: ContentEntry) => e.data.status === "published";
const scholars = graph.all
  .filter((e) => e.collection === "person" && isPubE(e))
  .map((p) => {
    const works = graph.materialsByPerson(p.id).filter(isPubE);
    return {
      id: p.id,
      title: p.data.title as string,
      tabaqa: p.data.tabaqa as string | undefined,
      aqeedah: (p.data as any).aqeedah as string | undefined,
      died: p.data.died as string | undefined,
      worksCount: works.length,
    };
  })
  .filter((s) => s.worksCount > 0)
  .sort((a, b) => b.worksCount - a.worksCount);

const gdata = JSON.stringify({ nodes, links }).replace(/</g, "\\u003c");
---
<Base title="شبكة المعرفة" description="رسمٌ بيانيٌّ تفاعليٌّ يربط كتبَ الأرشيف ومنظوماتِه وأعلامَه وفنونَه." activeNav="graph" noindex>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "شبكة المعرفة" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">شبكة المعرفة</h1>

    <!-- stats overview -->
    <div class="dash-stats">
      {present.map((t) => (
        <div class="dash-stat">
          <div class="dash-stat-num">{toArabicDigits(counts[t])}</div>
          <div class="dash-stat-label">{LABELS[t] ?? t}</div>
        </div>
      ))}
    </div>

    <!-- global graph search input -->
    <div style="margin-bottom: 24px; display: flex; justify-content: center; width: 100%;">
      <input type="search" id="graph-search" class="pop-search" placeholder="البحث في الشبكة والتركيز على العناوين والروابط (مثال: ابن تيمية)..." aria-label="ابحث في الشبكة" style="width: 100%; max-width: 600px; padding: 12px 20px; font-size: 15px; border-radius: var(--radius); border: 1px solid var(--rule-strong); background: var(--surface); color: var(--ink);" autocomplete="off" />
    </div>

    <p class="faint graph-hint">كلُّ نقطةٍ مادةٌ أو عَلَمٌ أو فنّ؛ الخطوطُ روابطُها. اسحبِ النقطةَ لتحريكها، مرِّرْ للتكبير، وانقرْها لفتحِها. أزِلِ العلامةَ عن نوعٍ لإخفائه.</p>
    <div style="display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; align-items: center; position: relative; z-index: 50;">
      <button type="button" id="legend-select-all" class="btn" style="padding: 4px 12px; font-size: 13px; cursor: pointer; border: 1px solid var(--rule-strong); border-radius: 4px; background: var(--surface); color: var(--ink);">تحديد الكل</button>
      <button type="button" id="legend-clear-all" class="btn" style="padding: 4px 12px; font-size: 13px; cursor: pointer; border: 1px solid var(--rule-strong); border-radius: 4px; background: var(--surface); color: var(--ink);">إلغاء تحديد الكل</button>

      {scholars.length > 0 && (
        <details class="pop-dropdown" style="position: relative; display: inline-block;">
          <summary class="btn" style="padding: 4px 12px; font-size: 13px; cursor: pointer; border-radius: 4px; border: 1px solid var(--rule-strong); background: var(--surface); color: var(--ink); display: inline-flex; align-items: center; gap: 6px; list-style: none; user-select: none;">
            <span>تصفية الأعلام</span>
            <span class="faint" id="scholar-counter" style="font-size: 11px; margin-inline-start: 4px;">({toArabicDigits(scholars.length)} / {toArabicDigits(scholars.length)})</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="pop-dropdown-menu">
            <input type="search" id="person-search" class="pop-search" placeholder="ابحث عن عَلَم…" aria-label="ابحث عن عَلَم" style="width: 100%; padding: 8px 12px; font-size: 13px; border-radius: 6px; border: 1px solid var(--rule-strong); background: var(--paper); color: var(--ink);" autocomplete="off" />
            <div style="display: flex; gap: 6px; margin-bottom: 4px; flex-wrap: wrap;">
              <button type="button" id="person-select-all" class="btn" style="padding: 3px 8px; font-size: 11px; cursor: pointer; border-radius: 4px; border: 1px solid var(--rule-strong); background: var(--paper); color: var(--ink);">تحديد الكل</button>
              <button type="button" id="person-clear-all" class="btn" style="padding: 3px 8px; font-size: 11px; cursor: pointer; border-radius: 4px; border: 1px solid var(--rule-strong); background: var(--paper); color: var(--ink);">إلغاء الكل</button>
            </div>
            <div class="pop-checklist graph-person-list" style="display: flex; flex-direction: column; gap: 8px; max-height: 250px; overflow-y: auto; padding-inline: 4px 2px;">
              {scholars.map((s) => (
                <label class="pop-check graph-person-leg" data-name={s.title} style="display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; width: 100%;">
                  <input type="checkbox" value={s.id} class="person-toggle" checked style="accent-color: var(--accent); width: 14px; height: 14px; cursor: pointer;" />
                  <span class="people-name" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; text-align: right;">
                    {s.title}
                    <span class="faint" style="font-size: 11px; margin-inline-start: 4px;">({toArabicDigits(s.worksCount)})</span>
                  </span>
                </label>
              ))}
            </div>
          </div>
        </details>
      )}
    </div>
    <div class="graph-legend" data-graph-legend>
      {present.map((t) => (
        <label class="graph-leg" data-type={t}>
          <input type="checkbox" checked={t !== "chapter" && t !== "article" && t !== "question"} />
          <span class="graph-dot" style={`background:${COLORS[t]}`}></span>
          <span class="graph-leg-name">{LABELS[t] ?? t}</span>
          <span class="faint graph-leg-count">{toArabicDigits(counts[t])}</span>
        </label>
      ))}
    </div>
  </div>
  <div class="graph-wrap"><div id="graph"></div></div>

  <script type="application/json" id="gdata" set:html={gdata}></script>
  <script>
    import "../scripts/graph.ts";
  </script>
</Base>

<style>
  details.pop-dropdown summary::-webkit-details-marker {
    display: none;
  }
  details.pop-dropdown summary {
    list-style: none;
    outline: none;
  }
  .pop-dropdown-menu {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    z-index: 1000;
    width: 300px;
    background: var(--surface);
    border: 1px solid var(--rule-strong);
    border-radius: var(--radius-lg);
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  [dir="rtl"] .pop-dropdown-menu {
    right: 0;
    left: auto;
  }
  .pop-checklist::-webkit-scrollbar {
    width: 6px;
  }
  .pop-checklist::-webkit-scrollbar-thumb {
    background: var(--rule-strong);
    border-radius: 3px;
    border: none;
  }
</style>

