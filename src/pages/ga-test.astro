---
// Hidden GA test page — not linked from nav, not in sitemap.
// Swap G-XXXXXXXXXX for the real Measurement ID, verify in GA Realtime, then
// move the <script> block into src/layouts/Base.astro to enable site-wide.
const GA_ID = "G-NBHR8NV97G";
---
<html lang="ar">
<head>
  <meta charset="utf-8" />
  <meta name="robots" content="noindex, nofollow" />
  <title>GA test</title>
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
  <script define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag("js", new Date());
    gtag("config", GA_ID);
  </script>
</head>
<body>
  <p>GA test page — check GA Realtime reports for a hit from this page.</p>
</body>
</html>
