---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Relations from "../../components/Relations.astro";
import ReaderSidebar from "../../components/ReaderSidebar.astro";
import InlineSearch from "../../components/InlineSearch.astro";
import { markdownToSafeHtml } from "../../lib/sanitize";
import { applyTajweed, TAJWEED_COLORS } from "../../lib/tajweed";
import { notesByAnchor, loadGraph, personNameMap } from "../../lib/site";
import { parseBook } from "../../lib/chapters";
import { toArabicDigits } from "../../lib/display";
// Build-time only: used to know WHICH verses have tafsir (so we render a
// clickable ayah-num button), never to inline note bodies into page HTML —
// those are fetched on demand from /tafsir-frag/<surah>/<ayah>.html (M1).
// A small keys-only sidecar (gen-tafsir-keys.ts), NOT the full 300+MB
// index — importing that here forced Vite to bundle the whole thing as a
// page module dependency and OOM'd both `astro check` and `astro build`.
import tafsirKeys from "../../data/quran-tafsir-keys.json";
import { isPrimaryShard } from "../../lib/build-shard";

export async function getStaticPaths() {
  if (!isPrimaryShard) return [];
  const surahs = await getCollection("quran");
  const graph = await loadGraph();
  const names = await personNameMap();
  const byNumber = [...surahs].sort((a, b) => (a.data.number as number) - (b.data.number as number));
  return surahs.map((entry) => {
    const body = entry.body ?? "";
    const byAnchor = notesByAnchor("quran", entry.id, graph, names);
    const { paragraphs } = parseBook(body);
    const i = byNumber.findIndex((s) => s.id === entry.id);
    const nav = (s: typeof entry | undefined) => (s ? { href: `/quran/${s.id}`, name: s.data.name as string } : null);
    const surahList = byNumber.map((s) => ({ id: s.id, number: s.data.number as number, name: s.data.name as string }));
    return {
      params: { surah: entry.id },
      props: { entry, paragraphs, byAnchor, prev: nav(byNumber[i - 1]), next: nav(byNumber[i + 1]), surahList },
    };
  });
}

const { entry, paragraphs, byAnchor, prev, next, surahList } = Astro.props;
const { data } = entry;
const ayahCount = data.ayah_count as number;
const tafsirVerseKeys = new Set(tafsirKeys as string[]);
const surahTitle = `سورة ${data.name}`;
const path = `/quran/${entry.id}`;

// 1. Map each ayah to its page
let currentPage = data.start_page;
const ayahPageMap = new Map<string, number>();
const pageAyahsMap = new Map<number, { id: string; text: string }[]>();

for (const para of paragraphs) {
  const pageMatch = para.text.match(/<hr class="page-sep" data-page="(\d+)" \/>/);
  if (pageMatch) {
    currentPage = parseInt(pageMatch[1], 10);
  }
  ayahPageMap.set(para.id, currentPage);
  if (!pageAyahsMap.has(currentPage)) {
    pageAyahsMap.set(currentPage, []);
  }
  const cleanText = para.text.replace(/<hr class="page-sep" data-page="\d+" \/>/g, "").trim();
  pageAyahsMap.get(currentPage)!.push({ id: para.id, text: cleanText });
}

// 2. Group annotations of this surah by page
const pageNotesData = new Map<number, any[]>();
for (const [pageNum, ayahs] of pageAyahsMap.entries()) {
  const pageNotes: any[] = [];
  for (const ayah of ayahs) {
    const notes = byAnchor[ayah.id] ?? [];
    pageNotes.push(...notes.map(n => ({ ...n, ayahId: ayah.id, ayahText: ayah.text })));
  }
  if (pageNotes.length === 0) continue;

  const groups = new Map<string, { kind: string; annotator?: string; items: any[] }>();
  for (const note of pageNotes) {
    const key = note.annotator ? `${note.kind} — ${note.annotator}` : note.kind;
    if (!groups.has(key)) {
      groups.set(key, { kind: note.kind, annotator: note.annotator, items: [] });
    }
    groups.get(key)!.items.push(note);
  }

  const entries = [...groups.entries()].map(([label, group]) => {
    const htmlParts = group.items.map((item) => {
      const title = `الآية (${item.ayahId})`;
      const ayahHtml = `<div class="sheet-ayah-title" style="color: var(--gold); font-size: 0.85em; margin-top: 1rem; margin-bottom: 0.25rem;">${title}</div><div class="sheet-ayah-text" style="font-family: var(--font-quran); font-size: 1.25em; line-height: 1.8; color: var(--ink); margin-bottom: 0.5rem;">﴿ ${item.ayahText} ﴾</div>`;
      const bodyHtml = `<div class="sheet-ayah-body">${markdownToSafeHtml(item.body)}</div>`;
      return `${ayahHtml}${bodyHtml}`;
    });
    return {
      kind: group.kind,
      label: label,
      body: htmlParts.join('<hr style="border: 0; border-top: 1px dashed var(--rule); margin-block: 1rem;" />'),
    };
  });

  pageNotesData.set(pageNum, entries);
}

// 3. Process paragraphs to inject start page separator and set notes on all separators
// ponytail: tajweed coloring is only validated against Al-Fatiha's own text
// so far — gate it to surah 1 until the rest of the mushaf is checked too.
const processedParagraphs = paragraphs.map((para, idx) => {
  let text = data.number === 1 ? applyTajweed(para.text) : para.text;
  if (idx === 0) {
    text = `<hr class="page-sep" data-page="${data.start_page}" />\n` + text;
  }

  text = text.replace(/<hr class="page-sep" data-page="(\d+)" \/>/g, (match, pageStr) => {
    const pNum = parseInt(pageStr, 10);
    const notes = pageNotesData.get(pNum);
    const notesAttr = notes && notes.length > 0 ? ` data-notes='${JSON.stringify(notes).replace(/'/g, "&apos;")}'` : "";
    return `<hr class="page-sep" data-page="${pNum}" id="p${pNum}"${notesAttr} />`;
  });

  const verseKey = `${data.number}:${para.id}`;
  const hasTafsir = tafsirVerseKeys.has(verseKey);

  return {
    ...para,
    text,
    verseKey,
    tafsirPackId: hasTafsir ? `ann-quran-${data.number}-${para.id}` : undefined,
  };
});
---
<Base title={surahTitle} description={`${surahTitle} — ${data.ayah_count} آية`} activeNav="quran" readingPage tajweedPage={data.number === 1}>
  <Breadcrumbs items={[
    { label: "الرئيسية", href: "/" },
    { label: "القرآن وعلومه", href: "/quran" },
    { label: "المصحف الشريف", href: "/quran/mushaf" },
    { label: surahTitle },
  ]} />

  <div class="chap-grid">
  <div class="wrap-matn reading-pad" dir="rtl" data-cite-book={surahTitle} data-cite-kind="quran" data-cite-surah={data.name}>
    <div class="plate-outer surah-plate">
      <div class="plate-inner surah-plate-inner">
        <span class="plate-corner c-tr" aria-hidden="true">۞</span>
        <span class="plate-corner c-tl" aria-hidden="true">۞</span>
        <span class="plate-corner c-br" aria-hidden="true">۞</span>
        <span class="plate-corner c-bl" aria-hidden="true">۞</span>
        <div class="reader-head">
          <a class="eyebrow pill-link" href="/quran/mushaf">المصحف الشريف</a>
          <div class="ornament" aria-hidden="true">۞</div>
          <h1 class="reader-title surah-title">{surahTitle}</h1>
          <div class="reader-byline faint">{data.ayah_count} آية</div>
        </div>
      </div>
    </div>
    <!-- outside the plate, not inside it — the frame stays the clean
         manuscript look, the download action is secondary chrome under it -->
    <button type="button" class="toggle-btn surah-dl" data-action="download:toggle" data-dl-kind="quran" data-dl-id={entry.id} data-dl-title={surahTitle} aria-pressed="false">
      <span class="toggle-dot"></span><span data-dl-label>تنزيل للقراءة دون اتصال</span>
    </button>
    <button type="button" class="toggle-btn surah-dl surah-tasmi" data-action="toggle:tasmi" aria-pressed="false" title="إخفاء الآيات حتى تنقر عليها">
      <span class="toggle-dot"></span><span>وضع التسميع</span>
    </button>

    <InlineSearch placeholder="ابحث عن آية… (بأي لفظ من نصها)" params={{ type: "quran" }} />

    <div class="ayah-list">
      {processedParagraphs.map((para) => {
        return (
          <span class="ayah verse" id={para.id} data-anchor={para.id}>
            <span class="ayah-text" set:html={markdownToSafeHtml(para.text)} />
            {para.tafsirPackId ? (
              <button type="button" class="ayah-num ayah-num-btn ann-mark" data-ann={para.tafsirPackId} data-ann-src={`/tafsir-frag/${data.number}/${para.id}.html`} aria-haspopup="dialog" aria-label={`تفسير الآية ${para.id}`}>{para.id}</button>
            ) : (
              <span class="ayah-num">{para.id}</span>
            )}
          </span>
        );
      })}
    </div>

    <p class="ayah-hint faint">اضغط على الآية لعرضِ التفسيرِ والمواضعِ المرتبطة</p>

    <!-- anchored tafsir panel (HANDOFF §5): the ann-sheet mounts here instead of
         floating over the mushaf — the modal hid the text being explained -->
    <div id="tafsir-panel-slot"></div>

    <nav class="surah-nav" aria-label="تنقل بين السور">
      {next ? (
        <a class="surah-nav-card" href={next.href}>
          <span class="surah-nav-kicker">السورة التالية ←</span>
          <span class="surah-nav-name">{next.name}</span>
        </a>
      ) : (
        <span class="surah-nav-end">آخرُ سور المصحف</span>
      )}
      {prev ? (
        <a class="surah-nav-card" href={prev.href}>
          <span class="surah-nav-kicker">→ السورة السابقة</span>
          <span class="surah-nav-name">{prev.name}</span>
        </a>
      ) : (
        <span class="surah-nav-end">أولُ سور المصحف</span>
      )}
    </nav>

    <Relations items={[]} />
  </div>

  <!-- long-surah shortcuts: fixed ↑/↓ so reaching either end is one tap -->
  <div class="surah-scroll-fabs" aria-hidden="false">
    <button type="button" class="icon-btn" data-action="scroll:top" aria-label="إلى أول السورة">↑</button>
    <button type="button" class="icon-btn" data-action="scroll:bottom" aria-label="إلى آخر السورة">↓</button>
  </div>

  <ReaderSidebar label={`سور القرآن · ${toArabicDigits(surahList.length)} سورة`}>
    <div class="toc-box surah-jump-box">
      <div class="toc-label">تنقُّل داخل السورة</div>
      <input class="ayah-jump" type="number" inputmode="numeric" min="1" max={ayahCount}
        placeholder={`إلى الآية… (١–${toArabicDigits(ayahCount)})`} data-ayah-jump />
      {[...pageAyahsMap.keys()].length > 1 && (
        <div class="surah-page-links">
          {[...pageAyahsMap.keys()].sort((a, b) => a - b).map((p) => (
            <a href={`#p${p}`} title={`الصفحة ${toArabicDigits(p)}`}>{toArabicDigits(p)}</a>
          ))}
        </div>
      )}
    </div>
    <!-- sitewide surah index, not this surah's own TOC — data-dl-skip keeps
         downloads.ts's collectUrls() from bundling all 114 surahs into a
         single-surah "download for offline" -->
    <div class="toc-box has-current" data-dl-skip>
      <div class="toc-label">سور القرآن الكريم</div>
      {surahList.map((s) => (
        <a href={`/quran/${s.id}`} class:list={[{ "toc-current": s.id === entry.id }]}>
          {toArabicDigits(s.number)} — سورة {s.name}
        </a>
      ))}
    </div>
  </ReaderSidebar>
  </div>
</Base>

<style define:vars={TAJWEED_COLORS}>
  :global(.page-sep) { display: flex !important; scroll-margin-top: 90px; }

  /* within-surah navigation (sidebar box): ayah jump + page-number chips */
  .ayah-jump {
    width: 100%; box-sizing: border-box; padding: 7px 10px; font-family: var(--font-ui); font-size: 13px;
    border: 1px solid var(--rule); border-radius: var(--radius); background: var(--surface); color: var(--ink);
  }
  .surah-page-links { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
  .surah-page-links a {
    display: inline-grid; place-items: center; min-width: 30px; height: 26px; padding-inline: 4px;
    border: 1px solid var(--rule); border-radius: var(--radius); text-decoration: none;
    font-family: var(--font-mono); font-size: 11.5px; color: var(--ink-soft);
  }
  .surah-page-links a:hover { border-color: var(--gold); color: var(--gold-text); }

  /* fixed ↑/↓ shortcuts — bottom start corner, clear of the tafsir panel */
  .surah-scroll-fabs {
    position: fixed; inset-inline-start: 14px; bottom: 14px; z-index: 40;
    display: flex; flex-direction: column; gap: 8px;
  }
  .surah-scroll-fabs .icon-btn { background: var(--card); border: 1px solid var(--line2); }

  /* gold double-border plate (HANDOFF §4: manuscript plate, Quran variant) —
     corner ۞ at all 4 corners + soft gold tint, per the mockup */
  .surah-plate { border-color: color-mix(in srgb, var(--gold) 50%, transparent); margin-block-end: 8px; }
  .surah-plate-inner {
    padding: 26px 24px; position: relative;
    border-color: color-mix(in srgb, var(--gold) 30%, transparent);
    background: color-mix(in srgb, var(--gold) 4%, var(--card));
  }
  .plate-corner { position: absolute; color: var(--gold); font-size: 12px; line-height: 1; }
  .plate-corner.c-tr { top: 8px; right: 10px; }
  .plate-corner.c-tl { top: 8px; left: 10px; }
  .plate-corner.c-br { bottom: 8px; right: 10px; }
  .plate-corner.c-bl { bottom: 8px; left: 10px; }
  .surah-plate .reader-head { margin: 0; }
  /* this overrides .reader-title's own reading-scale-aware font-size (global.css) —
     keep it scaling too, or the font +/- control visibly resizes the title
     but not the ayah text below it, which is the whole point of the control */
  .surah-title { font-size: calc(clamp(28px, 5vw, 34px) * var(--reading-scale)); }
  .surah-dl { display: flex; justify-content: center; text-align: center; margin: 14px auto 0; }
  .surah-tasmi { margin-top: 8px; }

  /* continuous centered ayah block — NOT one-per-line (HANDOFF §5) */
  .ayah-list {
    direction: rtl; margin-block: 2rem; text-align: center; text-wrap: pretty;
    font-family: var(--font-quran); font-size: calc(1.4rem * var(--reading-scale)); line-height: 2.5; color: var(--ink);
  }
  .ayah { display: inline; }
  .ayah-text { display: inline; }
  /* markdownToSafeHtml wraps prose in <p> — force inline so ayat flow as one
     continuous block instead of breaking a line per ayah */
  .ayah-text :global(p) { display: inline; margin: 0; }
  .ayah.verse.ann-active-verse {
    background: color-mix(in srgb, var(--gold) 14%, transparent);
    outline: 1px solid color-mix(in srgb, var(--gold) 45%, transparent);
    border-radius: 6px;
  }

  /* gold circled ayah number, trailing the ayah text */
  .ayah-num {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 20px; height: 20px; padding-inline: 3px; box-sizing: border-box;
    margin-inline: 3px; border: 1px solid var(--gold); border-radius: 999px;
    background: var(--gold); font-family: var(--font-ui); font-size: 10px; color: #fff;
    vertical-align: middle;
  }
  .ayah-num-btn {
    border: 1px solid var(--gold);
    cursor: pointer;
  }
  .ayah-num-btn:hover,
  .ayah-num-btn:focus-visible {
    background: color-mix(in srgb, var(--gold) 80%, black);
  }

  .ayah-hint { margin: 26px 0 0; text-align: center; font-size: 11.5px; }

  /* prev/next surah cards (mockup: قارئ السورة footer nav) */
  .surah-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; max-width: 720px; margin: 40px auto 0; }
  .surah-nav-card {
    display: block; background: var(--card); border: 1px solid var(--line); border-radius: 10px;
    padding: 14px 16px; color: var(--ink); text-decoration: none; transition: border-color .15s;
  }
  .surah-nav-card:hover { border-color: var(--gold); }
  .surah-nav-kicker { display: block; font-size: 10.5px; color: var(--ink3); margin-bottom: 4px; }
  .surah-nav-name { font-family: var(--f-disp); font-size: 15.5px; font-weight: 700; }
  .surah-nav-end {
    border: 1px dashed var(--line); border-radius: 10px; padding: 14px 16px;
    color: var(--ink3); font-size: 12px; display: flex; align-items: center;
  }

  /* tajweed rule colors (surah 1 only for now — see the ponytail note above).
     --tw-user-* is a separate custom-property namespace reader.ts writes to
     on :root for saved overrides — it's never set here, so when unset the
     var() fallback reads the build-time default from define:vars above with
     no cascade fight between the two. */
  .ayah-text :global(.tw-qalqalah) { color: var(--tw-user-qalqalah, var(--qalqalah)); }
  .ayah-text :global(.tw-ikhfa) { color: var(--tw-user-ikhfa, var(--ikhfa)); }
  .ayah-text :global(.tw-ikhfa-syafawi) { color: var(--tw-user-ikhfa-syafawi, var(--ikhfa-syafawi)); }
  .ayah-text :global(.tw-iqlab) { color: var(--tw-user-iqlab, var(--iqlab)); }
  .ayah-text :global(.tw-idgham-bighunnah) { color: var(--tw-user-idgham-bighunnah, var(--idgham-bighunnah)); }
  .ayah-text :global(.tw-idgham-bilaghunnah) { color: var(--tw-user-idgham-bilaghunnah, var(--idgham-bilaghunnah)); }
  .ayah-text :global(.tw-idgham-mimi) { color: var(--tw-user-idgham-mimi, var(--idgham-mimi)); }
  .ayah-text :global(.tw-idgham-shamsiyyah) { color: var(--tw-user-idgham-shamsiyyah, var(--idgham-shamsiyyah)); }
  .ayah-text :global(.tw-ghunnah) { color: var(--tw-user-ghunnah, var(--ghunnah)); }
  .ayah-text :global(.tw-madd-tabii) { color: var(--tw-user-madd-tabii, var(--madd-tabii)); }
  .ayah-text :global(.tw-madd-wajib) { color: var(--tw-user-madd-wajib, var(--madd-wajib)); }
  .ayah-text :global(.tw-madd-jaiz) { color: var(--tw-user-madd-jaiz, var(--madd-jaiz)); }
  .ayah-text :global(.tw-madd-arid) { color: var(--tw-user-madd-arid, var(--madd-arid)); }
  .ayah-text :global(.tw-madd-badal) { color: var(--tw-user-madd-badal, var(--madd-badal)); }

  /* settings-popover color-customization UI (Base.astro renders it, gated to
     tajweedPage) — kept in this page's own scoped stylesheet rather than the
     shared global.css bundle, since that bundle ships to every page and this
     only matters on this one; see the SSR-conditional note in Base.astro. */
  :global(.tajweed-advanced) { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--rule); }
  :global(.tajweed-advanced summary) { font-size: 13px; color: var(--ink-soft); cursor: pointer; }
  :global(.tajweed-grid) { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 12px; margin: 10px 0; }
  :global(.tajweed-color-row) { display: flex; align-items: center; gap: 8px; font-size: 12.5px; color: var(--ink); cursor: pointer; }
  :global(.tajweed-color-row input[type="color"]) {
    width: 22px; height: 22px; padding: 0; border: 1px solid var(--rule-strong); border-radius: 6px;
    background: none; cursor: pointer; flex: none;
  }
  :global(.pop-reset) { font-size: 13px; color: var(--ink2); background: none; border: none; padding: 0; cursor: pointer; font-family: inherit; }
  :global(.pop-reset:hover) { text-decoration: underline; }

  .ayah-notes { margin-block-start: 0.5rem; }
  .ayah-note {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--ink-soft);
    padding: 0.4rem 0;
    border-block-start: 1px dashed var(--rule);
  }
  .note-kind {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
  }
</style>
