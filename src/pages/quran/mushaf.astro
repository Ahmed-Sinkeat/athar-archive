---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { collectionLd } from "../../lib/structured-data";
import { getCollection } from "astro:content";
import { toArabicDigits } from "../../lib/display";

// Surah list — sorted by number
const surahs = (await getCollection("quran"))
  .sort((a, b) => (a.data.number as number) - (b.data.number as number));
---
<Base title="المصحف الشريف" description="تصفح سور القرآن الكريم وقراءة آياته بالرسم العثماني." activeNav="quran" jsonLd={collectionLd({ title: "المصحف الشريف", path: "/quran/mushaf", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "القرآن وعلومه", path: "/quran" }, { name: "المصحف الشريف", path: "/quran/mushaf" }] })}>
  <Breadcrumbs items={[
    { label: "الرئيسية", href: "/" },
    { label: "القرآن وعلومه", href: "/quran" },
    { label: "المصحف الشريف" }
  ]} />
  <div class="wrap-mid">
    <h1 class="page-title">المصحف الشريف</h1>

    {surahs.length > 0 && (
      <section class="surah-list" aria-label="فهرس السور">
        <h2 class="section-label">سور القرآن الكريم</h2>
        <ol class="surah-grid" dir="rtl">
          {surahs.map((s) => (
            <li>
              <a href={`/quran/${s.id}`} class="surah-card">
                <span class="surah-num">{toArabicDigits(s.data.number)}</span>
                <span class="surah-name">{s.data.name}</span>
                <span class="surah-ayat faint">{toArabicDigits(s.data.ayah_count)} آية</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}
  </div>
</Base>

<style>
  .surah-list { margin-block: 2.5rem; }
  .surah-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
    gap: 14px;
    list-style: none;
    padding: 0;
  }
  .surah-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 20px 14px;
    border: 1px solid var(--rule);
    border-radius: 12px;
    background: var(--surface);
    text-decoration: none;
    text-align: center;
    transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.6), 0 3px 10px rgba(26,20,16,0.03);
  }
  .surah-card:hover {
    background: var(--accent-wash);
    border-color: var(--accent-border);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.6), 0 6px 18px rgba(26,20,16,0.08);
  }
  .surah-num {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--gold-text);
  }
  .surah-name {
    font-family: var(--font-display); font-size: 20px; font-weight: 700;
    color: var(--ink);
    transition: color 0.15s;
  }
  .surah-card:hover .surah-name {
    color: var(--accent);
  }
  .surah-ayat {
    font-family: var(--font-ui); font-size: 12.5px;
    color: var(--ink-soft);
  }
</style>
