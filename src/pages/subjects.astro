---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { isPub, loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits } from "../lib/display";

const subjects = (await getCollection("subject")).filter(isPub);
const graph = await loadGraph();
---
<Base title="الموضوعات" description="شبكةُ المعرفة في الأرشيف: تصنيفاتٌ كبرى تتفرَّع إلى موضوعاتٍ علمية." activeNav="subjects">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الموضوعات" }]} />
  <div class="wrap-mid uf5db21c" >
    <h1 class="page-title">الموضوعات</h1>
    <p class="page-intro">شبكةُ المعرفةِ في الأرشيف: تصنيفاتٌ كبرى تتفرَّع إلى موضوعاتٍ علميةٍ، وكلُّ موضوعٍ صفحةٌ تجمعُ ما تعلَّق به من كتبٍ وسلاسلَ ودروسٍ وفوائدَ ومقالات.</p>

    <div class="u3273cc8">
      {subjects.map((s, i) => {
        const topics = graph.topicsBySubject(s.id).filter(isPub);
        return (
          <>
            {i > 0 && <div class="u86c1892"></div>}
            <div>
              <div class="u3ee22c2">
                <h2 class="u50936fb">{s.data.title}</h2>
                <span class="faint u6750b23" >{toArabicDigits(topics.length)} موضوعات</span>
              </div>
              <div class="chip-row">
                {topics.map((t) => <a class="chip" href={hrefFor("topic", t.id)}>{t.data.title}</a>)}
              </div>
            </div>
          </>
        );
      })}
    </div>
  </div>
</Base>
