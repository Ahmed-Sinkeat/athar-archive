---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { MORNING, EVENING, type AdhkarItem } from "../lib/adhkar-data";
import { toArabicDigits } from "../lib/display";

const RING_R = 44;
const RING_C = 2 * Math.PI * RING_R;
const preview = (t: string) => (t.length > 46 ? t.slice(0, 46) + "…" : t);
const periods: { id: "morning" | "evening"; label: string; items: AdhkarItem[] }[] = [
  { id: "morning", label: "الصباح", items: MORNING },
  { id: "evening", label: "المساء", items: EVENING },
];
---
<Base title="الأذكار" description="أذكار الصباح والمساء، مع عدّاد للتكرار يُحفظ على هذا الجهاز ويُعاد كل يوم." activeNav="home">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الأذكار" }]} />

  <div data-azkar data-period="morning">
    <div class="wrap-mid reading-pad azkar-page">
      <h1 class="page-title">الأذكار</h1>
      <p class="faint azkar-hint">اضغط على أي ذكرٍ لعدّه؛ يُحفظ تقدُّمك على هذا الجهاز، ويُعاد كل يوم.</p>

      <div class="azkar-toolbar">
        <div class="azkar-tabs" role="tablist" aria-label="اختيار الوقت">
          {periods.map((p, i) => (
            <button type="button" class="azkar-tab" data-azkar-tab data-period={p.id} role="tab" aria-selected={i === 0 ? "true" : "false"}>{p.label}</button>
          ))}
        </div>
        <div class="azkar-toolbar-actions">
          <button type="button" class="icon-btn" data-action="azkar:index" aria-label="فهرس الأذكار">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="14" y2="18"></line></svg>
          </button>
          <button type="button" class="icon-btn" data-action="azkar:share" aria-label="مشاركة الصفحة">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 15V4"></path><path d="M8 7l4-4 4 4"></path><path d="M6 12v6a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-6"></path></svg>
          </button>
          <button type="button" class="icon-btn" data-action="azkar:copy-all" aria-label="نسخ كل الأذكار">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"></rect><path d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1"></path></svg>
          </button>
          <button type="button" class="icon-btn" data-action="azkar:reset" aria-label="إعادة ضبط الجلسة">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 1 3 6.7"></path><path d="M3 21v-5h5"></path></svg>
          </button>
        </div>
      </div>

      <div class="azkar-progress-track"><div class="azkar-progress-fill" data-azkar-progress-fill></div></div>
      <p class="faint azkar-progress-label" data-azkar-progress-label>{toArabicDigits(0)} من {toArabicDigits(MORNING.length)}</p>

      {periods.map((p) => (
        <section class="azkar-list" data-azkar-list data-period={p.id}>
          <h2 class="azkar-section-heading">{p.id === "morning" ? "أذكار الصباح" : "أذكار المساء"}</h2>
          {p.items.map((it) => (
            <div id={`azkar-${it.id}`} class="azkar-card">
              <button type="button" class="azkar-tap" data-azkar-item data-id={it.id} data-period={p.id} data-count={it.count} aria-pressed="false">
                <span class="azkar-badge">
                  <svg class="azkar-ring" width="46" height="46" viewBox="0 0 100 100" aria-hidden="true">
                    <circle cx="50" cy="50" r={RING_R} class="azkar-ring-track"></circle>
                    <circle cx="50" cy="50" r={RING_R} class="azkar-ring-fill" data-azkar-ring style={`stroke-dasharray:${RING_C};stroke-dashoffset:${RING_C}`}></circle>
                  </svg>
                  <span class="azkar-badge-center">
                    <svg class="azkar-check" data-azkar-check width="15" height="15" viewBox="0 0 24 24" style="display:none" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg>
                    <span class="azkar-badge-num" data-azkar-num>{toArabicDigits(it.count)}</span>
                  </span>
                </span>
                <span class="azkar-card-body">
                  <span class="azkar-text">{it.text}</span>
                  {it.source && <span class="azkar-source">{it.source}</span>}
                </span>
              </button>
              <button type="button" class="icon-btn azkar-copy-item" data-action="azkar:copy-item" data-id={it.id} data-period={p.id} data-text={it.text} data-count={it.count} data-source={it.source ?? ""} aria-label="نسخ هذا الذكر">
                <svg class="azkar-copy-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"></rect><path d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1"></path></svg>
                <svg class="azkar-copy-done" width="15" height="15" viewBox="0 0 24 24" style="display:none" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg>
              </button>
            </div>
          ))}
        </section>
      ))}

      <div class="azkar-complete" data-azkar-complete hidden>
        <div class="azkar-complete-mark">
          <svg width="48" height="48" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--gold)" stroke-width="1.4" fill="none"></circle><path d="M8 12.3l2.6 2.6L16 9.5" stroke="var(--gold)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg>
        </div>
        <h2 data-azkar-complete-heading></h2>
        <p class="faint">تقبّل الله منّا ومنكم</p>
        <div class="azkar-complete-actions">
          <button type="button" class="btn" data-action="azkar:review">مراجعة الأذكار</button>
        </div>
      </div>

      <div class="azkar-toast" data-azkar-toast>تم النسخ</div>
    </div>

    <div class="azkar-scrim" data-azkar-scrim hidden></div>
    <aside class="azkar-sheet" data-azkar-sheet hidden aria-label="فهرس الأذكار">
      <div class="azkar-sheet-handle"></div>
      <div class="azkar-sheet-head">
        <span class="azkar-sheet-title" data-azkar-sheet-title>أذكار الصباح</span>
        <button type="button" class="icon-btn" data-action="azkar:index-close" aria-label="إغلاق">✕</button>
      </div>
      {periods.map((p) => (
        <div class="azkar-sheet-list" data-azkar-sheet-list data-period={p.id} hidden={p.id !== "morning"}>
          {p.items.map((it) => (
            <a href={`#azkar-${it.id}`} class="azkar-sheet-row" data-azkar-sheet-row data-id={it.id} data-period={p.id} data-count={it.count}>
              <span class="azkar-sheet-status" data-azkar-sheet-status>×{toArabicDigits(it.count)}</span>
              <span class="azkar-sheet-preview">{preview(it.text)}</span>
            </a>
          ))}
        </div>
      ))}
    </aside>
  </div>
</Base>

<script>
  import "../scripts/adhkar.ts";
</script>

<style>
  .azkar-hint { font-size: 13px; margin: -6px 0 var(--sp-4); }

  .azkar-toolbar { display: flex; align-items: center; justify-content: space-between; gap: var(--sp-3); flex-wrap: wrap; margin-bottom: var(--sp-3); }
  .azkar-tabs { display: flex; gap: var(--sp-2); }
  .azkar-tab {
    padding: 8px 22px; border-radius: var(--radius-pill); font-family: var(--font-ui); font-size: 13px;
    border: 1px solid var(--rule); background: var(--card); color: var(--ink); cursor: pointer;
    transition: background var(--t-fast) var(--ease), color var(--t-fast) var(--ease), border-color var(--t-fast) var(--ease);
  }
  .azkar-tab[aria-selected="true"] { background: var(--accent-solid); border-color: var(--accent-solid); color: var(--onbrand); }
  .azkar-toolbar-actions { display: flex; gap: var(--sp-2); }
  .azkar-toolbar-actions .icon-btn.is-flash { color: var(--green); border-color: var(--green); }

  .azkar-progress-track { height: 4px; border-radius: var(--radius-pill); background: var(--rule); overflow: hidden; max-width: 360px; margin: 0 auto var(--sp-1); }
  .azkar-progress-fill { height: 100%; width: 0%; background: var(--accent); border-radius: inherit; transition: width var(--t-base) var(--ease); }
  .azkar-progress-label { text-align: center; font-size: 11px; margin: 0 0 var(--sp-4); }

  .azkar-list { display: flex; flex-direction: column; gap: var(--sp-3); margin-bottom: var(--sp-5); }
  .azkar-list[hidden] { display: none; }
  .azkar-section-heading { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--ink); margin: 0 0 var(--sp-1); }

  .azkar-card {
    width: 100%; display: flex; align-items: center; gap: var(--sp-2);
    border: 1px solid var(--rule); border-radius: var(--radius-lg); background: var(--card);
    padding: var(--sp-2); scroll-margin-top: 90px;
  }
  .azkar-card.is-done .azkar-text { color: var(--ink2); }

  .azkar-tap {
    flex: 1; min-width: 0; display: flex; align-items: center; gap: var(--sp-3); text-align: right;
    border: none; background: none; padding: var(--sp-2); font-family: inherit; color: inherit; cursor: pointer;
  }
  .azkar-card.is-done .azkar-tap { cursor: default; }

  .azkar-badge { position: relative; width: 46px; height: 46px; flex-shrink: 0; }
  .azkar-ring { transform: rotate(-90deg); }
  .azkar-ring-track { fill: none; stroke: var(--rule); stroke-width: 6; }
  .azkar-ring-fill { fill: none; stroke: var(--accent); stroke-width: 6; stroke-linecap: round; transition: stroke-dashoffset var(--t-base) var(--ease), stroke var(--t-fast) var(--ease); }
  .azkar-card.is-done .azkar-ring-fill { stroke: var(--green); }
  .azkar-badge-center { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .azkar-badge-num { font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--ink); }
  .azkar-check { color: var(--green); }

  .azkar-card-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
  .azkar-text { font-family: var(--font-display); font-size: 18px; line-height: 1.9; color: var(--ink); }
  .azkar-source { font-family: var(--font-ui); font-size: 11.5px; color: var(--ink3); }

  .azkar-copy-item { align-self: flex-start; flex-shrink: 0; width: 34px; height: 34px; }
  .azkar-copy-item.is-copied { color: var(--green); border-color: var(--green); }

  .azkar-complete { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--sp-3); text-align: center; padding: var(--sp-7) var(--sp-5); }
  .azkar-complete[hidden] { display: none; }
  .azkar-complete h2 { font-family: var(--font-display); font-weight: 700; font-size: 23px; color: var(--ink); margin: 0; }
  .azkar-complete-actions { margin-top: var(--sp-4); }

  .azkar-toast {
    position: fixed; top: 70px; left: 50%; transform: translateX(-50%) translateY(-8px); opacity: 0; pointer-events: none;
    background: var(--ink); color: var(--card); font-size: 11.5px; padding: 7px 14px; border-radius: var(--radius-pill);
    z-index: 80; transition: opacity var(--t-fast) var(--ease), transform var(--t-fast) var(--ease);
  }
  .azkar-toast.is-shown { opacity: 1; transform: translateX(-50%) translateY(0); }

  .azkar-scrim { position: fixed; inset: 0; background: rgba(0, 0, 0, .4); z-index: 70; }

  .azkar-sheet {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 75; background: var(--card);
    border-top: 1px solid var(--rule); border-radius: 16px 16px 0 0; max-width: 520px; margin: 0 auto;
    max-height: 72%; display: flex; flex-direction: column;
  }
  .azkar-sheet[hidden] { display: none; }

  /* desktop: a small anchored panel near the toolbar instead of a full-width
     bottom sheet — no scrim needed, JS closes it on an outside click instead */
  @media (min-width: 641px) {
    .azkar-scrim { display: none; }
    .azkar-sheet {
      left: auto; bottom: auto; top: 150px; inset-inline-end: max(24px, calc(50% - 340px));
      width: 360px; max-width: 360px; margin: 0; max-height: 60vh;
      border: 1px solid var(--rule); border-radius: var(--radius-lg);
    }
    .azkar-sheet-handle { display: none; }
  }
  .azkar-sheet-handle { width: 36px; height: 4px; border-radius: var(--radius-pill); background: var(--rule-strong); margin: 12px auto 6px; flex-shrink: 0; }
  .azkar-sheet-head { display: flex; align-items: center; justify-content: space-between; padding: 8px 18px 12px; flex-shrink: 0; }
  .azkar-sheet-title { font-size: 14px; font-weight: 700; color: var(--ink); font-family: var(--font-display); }
  .azkar-sheet-list { overflow: auto; padding: 0 12px 8px; }
  .azkar-sheet-row { display: flex; align-items: center; gap: var(--sp-3); width: 100%; padding: 11px 8px; border-radius: var(--radius); text-decoration: none; }
  .azkar-sheet-row:hover { background: var(--inset); }
  .azkar-sheet-status { font-size: 11px; color: var(--ink3); min-width: 30px; text-align: center; flex-shrink: 0; }
  .azkar-sheet-row.is-done .azkar-sheet-status { color: var(--green); }
  .azkar-sheet-preview { font-size: 13.5px; color: var(--ink); font-family: var(--font-display); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; }
  .azkar-sheet-row.is-done .azkar-sheet-preview { color: var(--ink3); }

  @media (max-width: 640px) {
    .azkar-text { font-size: 16px; }
    .azkar-card { padding: 14px; gap: var(--sp-3); }
  }
</style>
