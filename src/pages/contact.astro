---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { config } from "../../ahlalathar.config";
---
<Base title="تواصل" description="تواصل مع فريق أهل الأثر للاقتراح أو التصحيح." activeNav="home">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "تواصل" }]} />
  <div class="wrap-read reading-pad" style="padding-block:24px 96px">
    <h1 class="page-title">تواصل</h1>
    <div class="prose" data-ar>
      <p>لاقتراحِ متنٍ أو منظومةٍ، أو للتنبيهِ على خطأٍ في النصِّ، راسلْنا على:</p>
      <p><a href={`mailto:${config.reportErrorMailto}`} style="font-family:var(--font-mono);direction:ltr;display:inline-block">{config.reportErrorMailto}</a></p>
    </div>
  </div>
</Base>
