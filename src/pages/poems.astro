---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import EntityCard from "../components/EntityCard.astro";
import { personNameMap, personEraMap, loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits } from "../lib/display";
import { analyzePoem } from "../lib/chunk";
import { buildSubjectGroups } from "../lib/browse";

const graph = await loadGraph();
const names = await personNameMap();
const eras = await personEraMap();
const { groups, uncategorized } = buildSubjectGroups("poem", graph);

const subOf = (d: any, body: string) =>
  `${(d.person ? names.get(d.person) ?? "" : "")} · ${toArabicDigits(analyzePoem(body ?? "").verseCount)} بيت`;
const eraOf = (d: any) => (d.person ? eras.get(d.person) : undefined);
---
<Base title="المنظومات" description="منظوماتٌ علميةٌ محقَّقةٌ مُشكَّلةٌ مع الشروح والتخريج." activeNav="poems" searchScope={{ type: "poem" }}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "المنظومات" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">المنظومات</h1>
    <p class="page-intro">منظوماتٌ علميةٌ مُشكَّلةٌ، أبياتُها مُرقَّمةٌ، مرتَّبةٌ حسب الفنِّ ثم الموضوع. المُعلَّمُ منها له شرحٌ وتخريج.</p>

    {groups.map((g) => (
      <section class="browse-group">
        <div class="browse-subject">
          <h2><a href={hrefFor("subject", g.id)}>{g.title}</a></h2>
          <span class="faint">{toArabicDigits(g.count)} منظومة</span>
        </div>
        {g.topics.map((t) => (
          <div class="browse-topic">
            <h3 class="browse-topic-h"><a href={hrefFor("topic", t.id)}>{t.title}</a></h3>
            <div class="card-grid">
              {t.items.map((it) => (
                <EntityCard href={hrefFor("poem", it.id)} title={it.data.title} kind="منظومة" matn={true} era={eraOf(it.data)} sub={subOf(it.data, it.body)} cta="ادخل القراءة ←" />
              ))}
            </div>
          </div>
        ))}
      </section>
    ))}

    {uncategorized.length > 0 && (
      <section class="browse-group">
        <div class="browse-subject"><h2>موضوعاتٌ أخرى</h2></div>
        <div class="card-grid">
          {uncategorized.map((it) => (
            <EntityCard href={hrefFor("poem", it.id)} title={it.data.title} kind="منظومة" matn={true} era={eraOf(it.data)} sub={subOf(it.data, it.body)} cta="ادخل القراءة ←" />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>
