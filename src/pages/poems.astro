---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import TitleFilter from "../components/TitleFilter.astro";
import { personNameMap, loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits, labelFor } from "../lib/display";
import { analyzePoem } from "../lib/chunk";
import { readBody } from "../lib/read-body";
import { collectionLd } from "../lib/structured-data";
import { buildSubjectGroups } from "../lib/browse";

const graph = await loadGraph();
const names = await personNameMap();
const allPoems = graph.all.filter((e) => e.collection === "poem" && e.data.status === "published");
const { groups, uncategorized } = buildSubjectGroups("poem", graph);

const verseCountLabel = (n: number) =>
  n === 2 ? `${toArabicDigits(n)} بيتان` : n >= 3 && n <= 10 ? `${toArabicDigits(n)} أبيات` : `${toArabicDigits(n)} بيتًا`;

// poem titles fall back to the first hemistich — showing those in the meta row
// would just repeat the verse below, so keep only real occasion titles
// tashkeel + tatweel only, as \u escapes — raw Arabic ranges got mangled here
// before and stripped every letter, which blanked ALL card titles
const strip = (s: string) => s.replace(/[\u0610-\u061A\u064B-\u065F\u0670\u06D6-\u06ED\u0640]/g, "").trim();
const cardList = await Promise.all(
  allPoems.map(async (p) => {
    const { verses, verseCount } = analyzePoem(await readBody(p as any));
    const title = p.data.title as string;
    const isVerseTitle = !!verses[0] && strip(title).length > 0 && strip(verses[0].sadr).startsWith(strip(title).slice(0, 18));
    return {
      id: p.id,
      rawTitle: title,
      href: hrefFor("poem", p.id),
      kind: labelFor("poem", p.data),
      poet: p.data.person ? names.get(p.data.person as string) ?? "" : "",
      title: isVerseTitle ? "" : title,
      count: verseCount,
      first: verses[0],
    };
  })
);
const cardsById = new Map(cardList.map((c) => [c.id, c]));

// منظومةُ الأسبوع — same weekly rotation as the homepage's مختارات الأسبوع / the
// حديث الأسبوع card on /hadith (moved here from the homepage per request)
const publishedPoems = (await getCollection("poem")).filter((p) => p.data.status === "published");
const wk = Math.floor(Date.now() / 6.048e8);
const featured = publishedPoems.length ? publishedPoems[wk % publishedPoems.length] : null;
const featuredVerses = featured ? analyzePoem(await readBody(featured)).verses.slice(0, 3) : [];
---
<Base title="الشعر" description="منظوماتٌ علميةٌ مع الشروح والتخريج." activeNav="poems" searchScope={{ type: "poem" }} jsonLd={collectionLd({ title: "الشعر", path: "/poems", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الشعر", path: "/poems" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الشعر" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">الشعر والمنظومات</h1>
    <p class="hub-lede poems-lede">{toArabicDigits(cardList.length)} منظومة علمية مُرقَّمة الأبيات، مع الشروح والتخريج.</p>

    {featured && (
      <div class="weekly-card k-copper poem-of-week">
        <div class="weekly-kicker k-copper">منظومةُ الأسبوع</div>
        <div class="weekly-text poem-of-week-verses" data-ar>
          {featuredVerses.map((v) => (
            <p>{v.sadr}{v.ajz && <Fragment><span class="poem-sep" aria-hidden="true">❁</span>{v.ajz}</Fragment>}</p>
          ))}
        </div>
        <div class="weekly-foot poem-of-week-foot">
          <span class="faint">{featured.data.title} · {featured.data.person ? names.get(featured.data.person as string) : ""}</span>
          <a class="weekly-ref" href={hrefFor("poem", featured.id)}>اقرأ المنظومة ←</a>
        </div>
      </div>
    )}

    <TitleFilter placeholder="تصفية حسب العنوان…" />

    <div class="browse show-flat" data-browse>
      <div class="browse-toolbar">
        <div class="browse-view-toggle" role="group" aria-label="طريقة العرض">
          <button type="button" data-flat-toggle="grouped" aria-pressed="false">مُجمَّع</button>
          <button type="button" data-flat-toggle="flat" aria-pressed="true">قائمة</button>
        </div>
      </div>

      <!-- flat «قائمة» view: plain divided text rows, not cards. Downloading
           lives on /downloads now, not scattered per-row here. -->
      <div class="browse-flat">
        <ul class="poem-rows">
          {cardList.map((c) => (
            <li class="poem-row" data-title={c.rawTitle}>
              <a class="poem-row-link" href={c.href}>
                <span class="poem-row-title">{c.rawTitle}</span>
                {c.poet && <span class="poem-row-poet">{c.poet}</span>}
              </a>
              <span class="row-meta">{verseCountLabel(c.count)}</span>
            </li>
          ))}
        </ul>
        {cardList.length === 0 && <p class="faint">لا توجد موادُّ في هذا القسم بعد.</p>}
      </div>

      <div class="masail-tree browse-grouped">
        {groups.map((g) => (
          <details class="masail-subject">
            <summary>
              <span class="masail-subject-name">{g.title}</span>
              <span class="faint masail-count">{toArabicDigits(g.count)}</span>
            </summary>
            <div class="masail-topics">
              {g.topics.map((t) => (
                <details class="masail-topic">
                  <summary>
                    <span>{t.title}</span>
                    <span class="faint masail-count">{toArabicDigits(t.items.length)}</span>
                  </summary>
                  <div class="poem-cards browse-cards">
                    {t.items.map((it) => {
                      const c = cardsById.get(it.id);
                      return c ? (
                        <a class="poem-card" href={c.href} data-title={c.rawTitle}>
                          <div class="poem-card-meta">
                            <span class="poem-badge">{c.kind}</span>
                            <span class="poem-byline">{[c.poet, c.title].filter(Boolean).join(" · ")}</span>
                            <span class="row-spacer"></span>
                            <span class="row-meta">{verseCountLabel(c.count)}</span>
                          </div>
                          {c.first && (
                            <p class="poem-card-verse" data-ar>
                              {c.first.sadr}
                              {c.first.ajz && <Fragment><span class="poem-sep" aria-hidden="true">❁</span>{c.first.ajz}</Fragment>}
                            </p>
                          )}
                        </a>
                      ) : null;
                    })}
                  </div>
                </details>
              ))}
            </div>
          </details>
        ))}

        {uncategorized.length > 0 && (
          <details class="masail-subject">
            <summary>
              <span class="masail-subject-name">موضوعاتٌ أخرى</span>
              <span class="faint masail-count">{toArabicDigits(uncategorized.length)}</span>
            </summary>
            <div class="poem-cards browse-cards">
              {uncategorized.map((it) => {
                const c = cardsById.get(it.id);
                return c ? (
                  <a class="poem-card" href={c.href} data-title={c.rawTitle}>
                    <div class="poem-card-meta">
                      <span class="poem-badge">{c.kind}</span>
                      <span class="poem-byline">{[c.poet, c.title].filter(Boolean).join(" · ")}</span>
                      <span class="row-spacer"></span>
                      <span class="row-meta">{verseCountLabel(c.count)}</span>
                    </div>
                    {c.first && (
                      <p class="poem-card-verse" data-ar>
                        {c.first.sadr}
                        {c.first.ajz && <Fragment><span class="poem-sep" aria-hidden="true">❁</span>{c.first.ajz}</Fragment>}
                      </p>
                    )}
                  </a>
                ) : null;
              })}
            </div>
          </details>
        )}
      </div>
    </div>
  </div>
</Base>

<style>
  /* flat «قائمة» view: plain divided text rows, not cards */
  .poem-rows { list-style: none; margin: 22px 0 0; padding: 0; }
  .poem-row { display: flex; align-items: center; gap: 12px; padding: 10px 2px; min-height: 44px; border-bottom: 1px solid var(--line); }
  .poem-row-link { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; gap: 2px; color: var(--ink); text-decoration: none; }
  .poem-row-title { font-size: 15.5px; font-weight: 600; }
  .poem-row-link:hover .poem-row-title { color: var(--copper); }
  .poem-row-poet { font-family: var(--f-ui); font-size: 12px; color: var(--ink2); }
  .poem-row .row-meta { flex: none; }

  /* grouped «مُجمَّع» view keeps the verse-preview cards (HANDOFF §5 الشعر) */
  .poem-cards { display: flex; flex-direction: column; gap: 12px; margin-top: 22px; }
  .browse-cards.poem-cards { margin-top: 0; }
  .poem-card {
    display: block; background: var(--card); border: 1px solid var(--line); border-radius: 10px;
    padding: 20px 22px; color: var(--ink); text-decoration: none; transition: border-color .15s;
  }
  .poem-card:hover { border-color: var(--copper); }
  .poem-card-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; flex-wrap: wrap; }
  .poem-badge {
    font-family: var(--f-ui); font-size: 10.5px; font-weight: 600; color: var(--copper);
    border: 1px solid color-mix(in srgb, var(--copper) 35%, transparent); border-radius: 5px; padding: 2px 9px;
  }
  .poem-byline { font-family: var(--f-ui); font-size: 12.5px; font-weight: 600; color: var(--ink2); }
  .poem-card-verse { margin: 0; font-family: var(--f-disp); font-size: 19px; line-height: 1.9; }
  .poem-sep { color: var(--copper); padding: 0 10px; }
  .poems-lede { margin-bottom: 18px; }
  .poem-of-week { margin-bottom: 26px; }
  .poem-of-week-verses p { margin: 0 0 8px; }
  .poem-of-week-verses p:last-child { margin-bottom: 0; }
  .poem-of-week-foot .faint { font-size: 11px; }
</style>
