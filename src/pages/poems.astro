---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import BrowseGroups from "../components/BrowseGroups.astro";
import SectionSearch from "../components/SectionSearch.astro";
import { personNameMap, personEraMap, loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits } from "../lib/display";
import { analyzePoem } from "../lib/chunk";
import { buildSubjectGroups } from "../lib/browse";
import { collectionLd } from "../lib/structured-data";

const graph = await loadGraph();
const names = await personNameMap();
const eras = await personEraMap();
const { groups, uncategorized } = buildSubjectGroups("poem", graph);
const card = (it: any) => ({
  href: hrefFor("poem", it.id),
  title: it.data.title,
  kind: "منظومة",
  matn: true,
  era: it.data.person ? eras.get(it.data.person) : undefined,
  sub: `${it.data.person ? names.get(it.data.person) ?? "" : ""} · ${toArabicDigits(analyzePoem(it.body ?? "").verseCount)} بيت`,
  cta: "ادخل القراءة ←",
});
---
<Base title="الشعر" description="منظوماتٌ علميةٌ محقَّقةٌ مُشكَّلةٌ مع الشروح والتخريج." activeNav="poems" searchScope={{ type: "poem" }} jsonLd={collectionLd({ title: "الشعر", path: "/poems", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الشعر", path: "/poems" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الشعر" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">الشعر</h1>
    <SectionSearch scope="poem" placeholder="ابحث في الشعر…" />
    <BrowseGroups groups={groups} uncategorized={uncategorized} card={card} unit="منظومة" personNames={names} />
  </div>
</Base>
