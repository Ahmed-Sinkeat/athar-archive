---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Prose from "../../components/Prose.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import ReaderSidebar from "../../components/ReaderSidebar.astro";
import { isPub, loadGraph } from "../../lib/site";
import { readBody } from "../../lib/read-body";
import { articleLd } from "../../lib/structured-data";
import { parseToc } from "../../lib/chapters";
import { hrefFor } from "../../lib/display";
import { isPrimaryShard } from "../../lib/build-shard";

export async function getStaticPaths() {
  if (!isPrimaryShard) return [];
  const articles = (await getCollection("article")).filter(isPub);
  const graph = await loadGraph();
  const paths = [];
  for (const entry of articles) {
    const body = await readBody(entry);
    const person = graph.getById("person", entry.data.person);
    const audioEntry = entry.data.audio ? graph.getById("audio", entry.data.audio) : null;
    paths.push({
      params: { slug: entry.id },
      props: {
        entry, body, author: person?.data.title as string | undefined,
        audio: audioEntry
          ? {
              url: audioEntry.data.url as string,
              format: audioEntry.data.format as "opus" | "mp3" | undefined,
              duration: (audioEntry.data.duration as string | null) ?? null,
              sizeBytes: (audioEntry.data.size_bytes as number | null) ?? null,
            }
          : null,
      },
    });
  }
  return paths;
}

const { entry, body, author, audio } = Astro.props;
const tocNested = parseToc(body ?? "");
const path = `/article/${entry.id}`;
// fallback only when an article has no real description at all — never overrides one
const pageDescription = (entry.data.description as string | undefined) ||
  `${entry.data.title}${author ? ` — ${author}` : ""}، النص الكامل على أهل الأثر.`;
const jsonLd = articleLd({
  title: entry.data.title, authorId: entry.data.person, authorName: author,
  description: pageDescription, audioUrl: audio?.url,
  datePublished: new Date(entry.data.published_at).toISOString(), path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "مقالات ومحاضرات", path: "/articles" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} description={pageDescription} activeNav="articles" ogType="article" jsonLd={jsonLd} readingPage>
  <Breadcrumbs width="wrap-read" items={[{ label: "الرئيسية", href: "/" }, { label: "مقالات ومحاضرات", href: "/articles" }, { label: entry.data.title }]} />
  <div class="chap-outer">
    <div class="chap-grid">
      <div class="reading-pad" data-cite-book={entry.data.title} data-cite-author={author}>
        <div class="reader-head">
          <div class="eyebrow u87c136d" >مقالة</div>
          <h1 class="reader-title ub9b0323" >{entry.data.title}</h1>
          <div class="reader-byline">{entry.data.person ? <a href={hrefFor("person", entry.data.person)}>{author}</a> : author}</div>
        </div>

        {audio && <AudioPlayer sources={[audio]} title={entry.data.title} subtitle={author} />}

        <div class="rule-short"></div>
        <div class="ua26bda7"><Prose body={body} /></div>
        <div class="ornament ud38b410" >۞</div>
      </div>

      {tocNested?.length > 0 && (
        <ReaderSidebar label="فهرس العناوين">
          <div class="toc-box has-current">
            <div class="toc-label">فهرس العناوين</div>
            {tocNested.map((h) => (
              <a href={`#${h.slug}`} style={`padding-inline-start: ${(h.depth - 2) * 1}rem`}>{h.title}</a>
            ))}
          </div>
        </ReaderSidebar>
      )}
    </div>
  </div>
</Base>
