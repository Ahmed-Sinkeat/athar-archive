---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Prose from "../../components/Prose.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import { isPub, loadGraph, subjectTitlesFor } from "../../lib/site";
import { readBody } from "../../lib/read-body";
import { articleLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const articles = (await getCollection("article")).filter(isPub);
  const graph = await loadGraph();
  const paths = [];
  for (const entry of articles) {
    const body = await readBody(entry);
    const person = graph.getById("person", entry.data.person);
    const audioEntry = entry.data.audio ? graph.getById("audio", entry.data.audio) : null;
    paths.push({
      params: { slug: entry.id },
      props: {
        entry, body, author: person?.data.title as string | undefined,
        subjects: subjectTitlesFor(entry.data.topics, graph),
        audio: audioEntry
          ? {
              url: audioEntry.data.url as string,
              format: audioEntry.data.format as "opus" | "mp3" | undefined,
              duration: (audioEntry.data.duration as string | null) ?? null,
              sizeBytes: (audioEntry.data.size_bytes as number | null) ?? null,
            }
          : null,
      },
    });
  }
  return paths;
}

const { entry, body, author, audio, subjects } = Astro.props;
const path = `/article/${entry.id}`;
const jsonLd = articleLd({
  title: entry.data.title, authorId: entry.data.person, authorName: author,
  description: entry.data.description, audioUrl: audio?.url,
  datePublished: new Date(entry.data.published_at).toISOString(), path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "المقالات", path: "/articles" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} description={entry.data.description} activeNav="articles" ogType="article" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "article", person: author, subjects }}>
  <Breadcrumbs width="wrap-read" items={[{ label: "الرئيسية", href: "/" }, { label: "المقالات", href: "/articles" }, { label: entry.data.title }]} />
  <div class="wrap-read reading-pad">
    <div class="reader-head">
      <div class="eyebrow u87c136d" >مقالة</div>
      <h1 class="reader-title ub9b0323" >{entry.data.title}</h1>
      <div class="reader-byline">{author}</div>
    </div>

    {audio && <div class="u583f758"><AudioPlayer sources={[audio]} label="استماعٌ إلى المقالة" /></div>}

    <div class="rule-short"></div>
    <div class="ua26bda7"><Prose body={body} /></div>
    <div class="ornament ud38b410" >۞</div>
  </div>
</Base>
