---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import TitleFilter from "../components/TitleFilter.astro";
import { isPub, loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits, ERA_VALUES } from "../lib/display";
import { collectionLd } from "../lib/structured-data";

const people = (await getCollection("person")).filter(isPub);
const graph = await loadGraph();
const worksOf = (id: string) => graph.materialsByPerson(id).filter(isPub).length;

// Compute the best sortable year for each person:
// death year → birth year → era order index × 200 → "" (undated last).
const parseYear = (s: string | undefined): number | null => {
  if (!s) return null;
  const n = parseInt(String(s).replace(/[^\d]/g, ""), 10);
  return isNaN(n) ? null : n;
};
const bestYear = (p: any): string => {
  const died = parseYear(p.data.died as string | undefined);
  if (died != null) return String(died);
  const born = parseYear(p.data.born as string | undefined);
  if (born != null) return String(born);
  const eraIdx = ERA_VALUES.indexOf(p.data.era ?? "");
  if (eraIdx >= 0) return String(eraIdx * 200);
  return "";
};

// Century timeline (التراجم secondary view, HANDOFF §5): bucket by the same
// death→birth→era-derived year used for "بالتاريخ" sort. People with no
// derivable year at all fall into "غير مؤرَّخ" at the end.
const centuryOf = (p: any): number | null => {
  const y = parseYear(bestYear(p));
  return y != null ? Math.ceil(y / 100) : null;
};
const centuryBuckets = new Map<number, typeof people>();
const undated: typeof people = [];
for (const p of people) {
  const c = centuryOf(p);
  if (c == null) { undated.push(p); continue; }
  if (!centuryBuckets.has(c)) centuryBuckets.set(c, []);
  centuryBuckets.get(c)!.push(p);
}
const centuries = [...centuryBuckets.entries()]
  .sort((a, b) => a[0] - b[0])
  .map(([n, ppl]) => ({ n, people: ppl.sort((a, b) => a.data.title.localeCompare(b.data.title, "ar")) }));
---
<Base title="التراجم والأعلام" description="تراجمُ الناظمين والمصنِّفين والشُّرّاح، وما لكلٍّ منهم في الأرشيف." activeNav="people" searchScope={{ type: "person" }} jsonLd={collectionLd({ title: "التراجم والأعلام", path: "/people", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "التراجم والأعلام", path: "/people" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "التراجم والأعلام" }]} />
  <div class="wrap-mid uf5db21c" style="padding-bottom: 80px;">
    <h1 class="page-title">التراجم والأعلام</h1>
    <TitleFilter placeholder="تصفية حسب الاسم…" scope={{ type: "person" }} />

    <!-- century timeline is the primary view (mockup التراجم); flat sortable list behind the toggle -->
    <div class="browse" data-browse>
      <div class="browse-toolbar">
        <div class="browse-view-toggle" role="group" aria-label="طريقة العرض">
          <button type="button" data-flat-toggle="grouped" aria-pressed="true">مُجمَّع</button>
          <button type="button" data-flat-toggle="flat" aria-pressed="false">قائمة</button>
        </div>
      </div>

      <div class="browse-flat">
        <div class="sortable" data-sortable data-sort="title" data-dir="asc">
          <div class="sort-controls">
            <span class="faint sort-label">ترتيب:</span>
            <button type="button" class="sort-btn" data-sort-key="title" aria-pressed="true">أبجديًّا</button>
            <button type="button" class="sort-btn" data-sort-key="year" aria-pressed="false">بالتاريخ</button>
            <button type="button" class="sort-btn" data-sort-key="works" aria-pressed="false">بالمصادر</button>
            <button type="button" class="icon-btn sort-dir" data-sort-dir aria-label="عكس الترتيب" title="عكس الترتيب">↑</button>
          </div>
          <ol class="flat-list">
            {people.map((p) => {
              const works = worksOf(p.id);
              return (
                <li data-title={p.data.title} data-year={bestYear(p)} data-works={works}>
                  <a class="flat-row" href={hrefFor("person", p.id)}>
                    <span class="flat-row-main">
                      <span class="flat-row-title">{p.data.title}</span>
                      {(p.data.tabaqa || p.data.era) && (
                        <span class="flat-row-sub">{p.data.tabaqa ?? p.data.era}</span>
                      )}
                    </span>
                    <span class="flat-row-meta faint">
                      {p.data.died ? `ت ${p.data.died}` : p.data.born ? `و ${p.data.born}` : ""}
                    </span>
                    <span class="flat-row-count">{toArabicDigits(works)} مصدر</span>
                  </a>
                </li>
              );
            })}
          </ol>
        </div>
      </div>

      <div class="century-timeline browse-grouped">
        {centuries.map(({ n, people: ppl }) => (
          <div class="century-node">
            <div class="century-head">
              <span class="century-dot" aria-hidden="true"></span>
              <h2>القرن {toArabicDigits(n)}</h2>
            </div>
            <div class="century-people">
              {ppl.map((p) => (
                <a class="person-card" href={hrefFor("person", p.id)} data-title={p.data.title}>
                  <div class="person-card-name">{p.data.title}</div>
                  <div class="person-card-meta faint">
                    {p.data.tabaqa ?? p.data.era ?? ""}
                    {(p.data.died || p.data.born) && (p.data.tabaqa || p.data.era) ? " · " : ""}
                    {p.data.died ? `ت ${p.data.died}` : p.data.born ? `و ${p.data.born}` : ""}
                  </div>
                  <span class="pill person-card-count">{toArabicDigits(worksOf(p.id))} مصدر</span>
                </a>
              ))}
            </div>
          </div>
        ))}

        {undated.length > 0 && (
          <div class="century-node">
            <div class="century-head">
              <span class="century-dot" aria-hidden="true"></span>
              <h2>غير مؤرَّخ</h2>
            </div>
            <div class="century-people">
              {undated.map((p) => (
                <a class="person-card" href={hrefFor("person", p.id)} data-title={p.data.title}>
                  <div class="person-card-name">{p.data.title}</div>
                  <div class="person-card-meta faint">{p.data.tabaqa ?? p.data.era ?? ""}</div>
                  <span class="pill person-card-count">{toArabicDigits(worksOf(p.id))} مصدر</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</Base>
