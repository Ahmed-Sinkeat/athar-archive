---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { isPub, loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits } from "../lib/display";

const people = (await getCollection("person")).filter(isPub);
const graph = await loadGraph();
---
<Base title="الأعلام" description="تراجمُ الناظمين والمصنِّفين والشُّرّاح، وما لكلٍّ منهم في الأرشيف." activeNav="people">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الأعلام" }]} />
  <div class="wrap-mid" style="padding-block:18px 96px">
    <h1 class="page-title">الأعلام</h1>
    <p class="page-intro">تراجمُ الناظمين والمصنِّفين والشُّرّاح. اختر عَلَماً لتصفّحِ آثارِه في المكتبة.</p>
    <div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(260px,1fr))">
      {people.map((p) => {
        const works = graph.materialsByPerson(p.id).length;
        return (
          <a class="card" href={hrefFor("person", p.id)} style="display:flex;gap:16px;align-items:center">
            <div style="width:52px;height:52px;border-radius:50%;background:var(--paper-2);border:1px solid var(--rule-strong);display:grid;place-items:center;font-family:var(--font-display);font-size:22px;color:var(--accent);flex:0 0 auto">{p.data.title.replace(/^(ال|شيخ الإسلام |الإمام )/, "").trim().charAt(0)}</div>
            <div>
              <div class="card-title" style="font-size:19px">{p.data.title}</div>
              {(p.data.died || p.data.location) && (
                <div class="card-sub" style="margin-top:3px;font-size:12.5px">{[p.data.died && `ت ${p.data.died}`, p.data.location].filter(Boolean).join(" · ")}</div>
              )}
              <div class="faint" style="font-size:12px;margin-top:6px">{toArabicDigits(works)} من الأعمال</div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Base>
