---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { isPub, loadGraph } from "../lib/site";
import { hrefFor, toArabicDigits, eraLabel, ERA_VALUES } from "../lib/display";

const people = (await getCollection("person")).filter(isPub);
const graph = await loadGraph();
const presentEras = ERA_VALUES.filter((e) => people.some((p) => p.data.era === e));
---
<Base title="الأعلام" description="تراجمُ الناظمين والمصنِّفين والشُّرّاح، وما لكلٍّ منهم في الأرشيف." activeNav="people">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الأعلام" }]} />
  <div class="wrap-mid uf5db21c" >
    <h1 class="page-title">الأعلام</h1>
    <p class="page-intro">تراجمُ الناظمين والمصنِّفين والشُّرّاح. اختر عَلَماً لتصفّحِ آثارِه في الأرشيف.</p>

    {presentEras.length > 1 && (
      <div class="u1b7f0c1" data-filterbar>
        <button class="chip" data-filter="all" aria-pressed="true">الكل</button>
        {presentEras.map((e) => <button class="chip" data-filter={e} aria-pressed="false">{eraLabel(e)}</button>)}
      </div>
    )}

    <div class="card-grid u73cb55d" >
      {people.map((p) => {
        const works = graph.materialsByPerson(p.id).length;
        return (
          <a class="card ub2eeea3" href={hrefFor("person", p.id)} data-era={p.data.era} >
            <div class="u48e4dba">{p.data.title.replace(/^(ال|شيخ الإسلام |الإمام )/, "").trim().charAt(0)}</div>
            <div>
              <div class="card-title u94aa034" >{p.data.title}</div>
              {p.data.era && <div class="u2b0979c"><span class="pill tag-verdigris">{eraLabel(p.data.era)}</span></div>}
              {(p.data.died || p.data.location) && (
                <div class="card-sub u9439bf6" >{[p.data.died && `ت ${p.data.died}`, p.data.location].filter(Boolean).join(" · ")}</div>
              )}
              <div class="faint u2b0979c" >{toArabicDigits(works)} من الأعمال</div>
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <script is:inline>
    (() => {
      const bar = document.querySelector("[data-filterbar]");
      if (!bar) return;
      const cards = [...document.querySelectorAll(".card-grid .card")];
      bar.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-filter]");
        if (!btn) return;
        const f = btn.dataset.filter;
        bar.querySelectorAll("[data-filter]").forEach((b) => b.setAttribute("aria-pressed", String(b === btn)));
        cards.forEach((c) => { c.style.display = f === "all" || c.dataset.era === f ? "" : "none"; });
      });
    })();
  </script>
</Base>
