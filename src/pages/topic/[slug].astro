---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import EntityCard from "../../components/EntityCard.astro";
import TypeFilter from "../../components/TypeFilter.astro";
import Prose from "../../components/Prose.astro";
import { isPub, loadGraph } from "../../lib/site";
import { ENTITY, hrefFor, toArabicDigits } from "../../lib/display";
import { collectionLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const topics = (await getCollection("topic")).filter(isPub);
  const graph = await loadGraph();
  return topics.map((entry) => {
    const subject = graph.getById("subject", entry.data.subject);
    const materials = graph
      .materialsByTopic(entry.id)
      .filter(isPub)
      .map((m) => ({ collection: m.collection, id: m.id, title: m.data.title, series: m.data.series }));
    return {
      params: { slug: entry.id },
      props: { entry, subject: subject ? { id: subject.id, title: subject.data.title } : null, materials },
    };
  });
}

const { entry, subject, materials } = Astro.props;
const path = `/topic/${entry.id}`;
const jsonLd = collectionLd({
  title: entry.data.title, description: entry.data.description, path,
  crumbs: [
    { name: "الرئيسية", path: "/" }, { name: "الموضوعات", path: "/subjects" },
    ...(subject ? [{ name: subject.title, path: hrefFor("subject", subject.id) }] : []),
    { name: entry.data.title, path },
  ],
});
---
<Base title={entry.data.title} description={entry.data.description} activeNav="subjects" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "topic" }}>
  <Breadcrumbs
    width="wrap-read"
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الموضوعات", href: "/subjects" },
      ...(subject ? [{ label: subject.title, href: hrefFor("subject", subject.id) }] : []),
      { label: entry.data.title },
    ]}
  />
  <div class="wrap-read uf5db21c" >
    {subject && <div class="eyebrow u57e29a5" >{subject.title}</div>}
    <h1 class="page-title">{entry.data.title}</h1>
    {entry.data.description && <p class="page-intro">{entry.data.description}</p>}
    {entry.body?.trim() && <div class="u49f14f8"><Prose body={entry.body} /></div>}

    <div class="section-label u2fbbbcd" >ما تعلَّق بهذا الموضوع · {toArabicDigits(materials.length)}</div>
    {materials.length > 0 ? (
      <div data-typefilter-scope>
        <TypeFilter types={[...new Set(materials.map((m) => m.collection))]} />
        <div class="card-grid">
          {materials.map((m) => (
            <EntityCard
              href={hrefFor(m.collection, m.id, { series: m.series })}
              title={m.title}
              kind={ENTITY[m.collection]?.one}
              filterKey={m.collection}
              cta="اطّلع ←"
            />
          ))}
        </div>
      </div>
    ) : (
      <p class="faint">لا توجد موادُّ مرتبطةٌ بعد.</p>
    )}
  </div>
</Base>
