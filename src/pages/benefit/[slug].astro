---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Prose from "../../components/Prose.astro";
import { isPub, loadGraph } from "../../lib/site";
import { hrefFor, sourceHref, ENTITY } from "../../lib/display";
import { benefitLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const benefits = (await getCollection("benefit")).filter(isPub);
  const graph = await loadGraph();
  return benefits.map((entry) => {
    const person = graph.getById("person", entry.data.person);
    let source = null;
    if (entry.data.source_type && entry.data.source_id) {
      const s = graph.getById(entry.data.source_type, entry.data.source_id);
      if (s) source = { type: entry.data.source_type, id: s.id, title: s.data.title };
    }
    return {
      params: { slug: entry.id },
      props: { entry, personName: person?.data.title, personId: person?.id, source },
    };
  });
}

const { entry, personName, personId, source } = Astro.props;
const path = `/benefit/${entry.id}`;
const jsonLd = benefitLd({
  text: entry.data.title, authorName: personName, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الفوائد", path: "/benefits" }, { name: "فائدة", path }],
});
---
<Base title={entry.data.title} activeNav="benefits" ogType="article" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "benefit" }}>
  <Breadcrumbs width="wrap-read" items={[{ label: "الرئيسية", href: "/" }, { label: "الفوائد", href: "/benefits" }, { label: "فائدة" }]} />
  <div class="wrap-read reading-pad u91a8701" >
    <div class="ornament u3ba7d3f" >۞</div>
    <div class="prose u70b1b12" data-ar >
      <div class="u9256257">{entry.data.title}</div>
    </div>
    {entry.body?.trim() && <div class="u3ebb645"><Prose body={entry.body} /></div>}

    <div class="uf82600a">
      {personId && <a href={hrefFor("person", personId)} class="u17583d4">{personName}</a>}
      {source && (
        <div class="faint u5e0faad" >
          من <a href={sourceHref(source.type, source.id)} class="uf55e15c">{ENTITY[source.type]?.one} {source.title}</a>
        </div>
      )}
    </div>
  </div>
</Base>
