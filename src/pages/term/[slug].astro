---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { isPub } from "../../lib/site";
import { markdownToSafeHtml } from "../../lib/sanitize";
import { isPrimaryShard } from "../../lib/build-shard";

export async function getStaticPaths() {
  if (!isPrimaryShard) return [];
  const terms = (await getCollection("term")).filter(isPub);
  return terms.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---
<Base title={entry.data.title} description={entry.data.definition} activeNav="mujam">
  <Breadcrumbs width="wrap-read" items={[{ label: "الرئيسية", href: "/" }, { label: "المعجم", href: "/mujam" }, { label: entry.data.title }]} />
  <div class="wrap-read reading-pad">
    <div class="reader-head">
      <div class="eyebrow u87c136d">مصطلح</div>
      <h1 class="reader-title u97df06b">{entry.data.title}</h1>
      {entry.data.definition && <p class="mujam-def-head">{entry.data.definition}</p>}
    </div>
    <div class="rule-short"></div>
    {entry.body && <div class="ua26bda7 prose" data-ar set:html={markdownToSafeHtml(entry.body)} />}
  </div>
</Base>
