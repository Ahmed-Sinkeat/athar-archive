---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SectionSearch from "../../components/SectionSearch.astro";
import { personNameMap, loadGraph } from "../../lib/site";
import { hrefFor, toArabicDigits } from "../../lib/display";
import { buildSubjectGroups } from "../../lib/browse";
import { collectionLd } from "../../lib/structured-data";

const graph = await loadGraph();
const names = await personNameMap();
const { groups, uncategorized } = buildSubjectGroups("question", graph);

const allQuestions = [...groups.flatMap((g) => g.topics.flatMap((t) => t.items)), ...uncategorized];

const personIds = [...new Set(allQuestions.map((it) => it.data.person as string | undefined).filter(Boolean))] as string[];
const personsForFilter = personIds
  .map((id) => ({ id, name: names.get(id) ?? id }))
  .sort((a, b) => a.name.localeCompare(b.name, "ar"));

const topicMap = new Map<string, string>();
for (const g of groups) for (const t of g.topics) topicMap.set(t.id, t.title);
const topicsForFilter = [...topicMap.entries()]
  .map(([id, title]) => ({ id, title }))
  .sort((a, b) => a.title.localeCompare(b.title, "ar"));
---
<Base title="المسائل" description="مسائلُ علميةٌ مجموعةٌ على هيئة سؤالٍ وجواب، مرتَّبةٌ حسب الفنِّ والموضوع." activeNav="questions" searchScope={{ type: "question" }} jsonLd={collectionLd({ title: "المسائل", path: "/questions", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "المسائل", path: "/questions" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "المسائل" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">المسائل</h1>
    <SectionSearch scope="question" placeholder="ابحث في المسائل…" />

    {(personsForFilter.length > 1 || topicsForFilter.length > 1) && (
      <div class="browse-filters browse-filters-standalone">
        {personsForFilter.length > 1 && (
          <select class="browse-filter" data-filter-key="person" aria-label="فلترة بالعَلَم">
            <option value="">كل الأعلام</option>
            {personsForFilter.map((p) => <option value={p.id}>{p.name}</option>)}
          </select>
        )}
        {topicsForFilter.length > 1 && (
          <select class="browse-filter" data-filter-key="topic" aria-label="فلترة بالموضوع">
            <option value="">كل الموضوعات</option>
            {topicsForFilter.map((t) => <option value={t.id}>{t.title}</option>)}
          </select>
        )}
      </div>
    )}

    <div class="masail-tree" data-masail-browse>
      {groups.map((g, gi) => (
        <details class="masail-subject" open={gi === 0}>
          <summary>
            <span class="masail-subject-name">{g.title}</span>
            <span class="faint masail-count">{toArabicDigits(g.count)} مسألة</span>
          </summary>
          <div class="masail-topics">
            {g.topics.map((t) => (
              <details class="masail-topic">
                <summary>
                  <span>{t.title}</span>
                  <span class="faint masail-count">{toArabicDigits(t.items.length)}</span>
                </summary>
                <ul class="masail-list">
                  {t.items.map((it) => (
                    <li
                      data-person={(it.data.person as string | undefined) ?? ""}
                      data-topics={((it.data.topics as string[] | undefined) ?? []).join(",")}
                    >
                      <a href={hrefFor("question", it.id)}>
                        <span>{it.data.title}</span>
                        {it.data.person && <span class="faint"> · {names.get(it.data.person)}</span>}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ))}
          </div>
        </details>
      ))}

      {uncategorized.length > 0 && (
        <details class="masail-subject">
          <summary>
            <span class="masail-subject-name">مسائلُ أخرى</span>
            <span class="faint masail-count">{toArabicDigits(uncategorized.length)}</span>
          </summary>
          <ul class="masail-list masail-list-flush">
            {uncategorized.map((it) => (
              <li
                data-person={(it.data.person as string | undefined) ?? ""}
                data-topics={((it.data.topics as string[] | undefined) ?? []).join(",")}
              ><a href={hrefFor("question", it.id)}>{it.data.title}</a></li>
            ))}
          </ul>
        </details>
      )}
    </div>
  </div>
</Base>
