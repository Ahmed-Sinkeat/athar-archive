---
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TitleFilter from "../../components/TitleFilter.astro";
import { personNameMap, loadGraph } from "../../lib/site";
import { hrefFor, toArabicDigits } from "../../lib/display";
import { buildSubjectGroups } from "../../lib/browse";
import { collectionLd } from "../../lib/structured-data";

const graph = await loadGraph();
const names = await personNameMap();
const { groups, uncategorized } = buildSubjectGroups("question", graph);

const allQuestions = [...groups.flatMap((g) => g.topics.flatMap((t) => t.items)), ...uncategorized];

const personIds = [...new Set(allQuestions.map((it) => it.data.person as string | undefined).filter(Boolean))] as string[];
const personsForFilter = personIds
  .map((id) => ({ id, name: names.get(id) ?? id }))
  .sort((a, b) => a.name.localeCompare(b.name, "ar"));

const topicMap = new Map<string, string>();
for (const g of groups) for (const t of g.topics) topicMap.set(t.id, t.title);
const topicsForFilter = [...topicMap.entries()]
  .map(([id, title]) => ({ id, title }))
  .sort((a, b) => a.title.localeCompare(b.title, "ar"));

---
<Base title="المسائل" description="مسائلُ علميةٌ مجموعةٌ على هيئة سؤالٍ وجواب، مرتَّبةٌ حسب الفنِّ والموضوع." activeNav="questions" searchScope={{ type: "question" }} jsonLd={collectionLd({ title: "المسائل", path: "/questions", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "المسائل", path: "/questions" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "المسائل" }]} />
  <div class="wrap-mid uf5db21c">
    <h1 class="page-title">المسائل</h1>
    <TitleFilter placeholder="ابحث بالسؤال أو الجواب…" scope={{ type: "question" }} />

    {(personsForFilter.length > 1 || topicsForFilter.length > 1) && (
      <div class="browse-filters browse-filters-standalone">
        {personsForFilter.length > 1 && (
          <>
            <input type="text" list="questions-person-list" class="browse-filter browse-filter-text" data-filter-key="person" aria-label="فلترة بالعَلَم" placeholder="كل الأعلام" />
            <datalist id="questions-person-list">
              {personsForFilter.map((p) => <option value={p.name} />)}
            </datalist>
          </>
        )}
        {topicsForFilter.length > 1 && (
          <>
            <select class="browse-filter" data-filter-key="topic" aria-label="فلترة بالموضوع">
              <option value="">كل الموضوعات</option>
              {topicsForFilter.map((t) => <option value={t.id}>{t.title}</option>)}
            </select>
            {/* mobile-only tappable chips (same pattern as BrowseGroups.astro's
                kind filter) — same data-filter-key engine, driven by reader.ts */}
            <div class="browse-filter-chips" role="group" aria-label="فلترة بالموضوع">
              <button type="button" data-filter-key="topic" value="" aria-pressed="true">الكل</button>
              {topicsForFilter.map((t) => <button type="button" data-filter-key="topic" value={t.id} aria-pressed="false">{t.title}</button>)}
            </div>
          </>
        )}
      </div>
    )}

    <div class="masail-view-toggle" role="group" aria-label="طريقة العرض">
      <button type="button" data-masail-view="tree" aria-pressed="true">حسب الموضوع</button>
      <button type="button" data-masail-view="flat" aria-pressed="false">قائمة</button>
    </div>

    <!-- flat «قائمة» view is built CLIENT-side by cloning the tree's <li>s
         (script below): rendering all ~950 questions twice server-side made
         this the heaviest HTML page on the site (~1MB) for zero benefit -->
    <div class="masail-tree" data-masail-browse>
      {groups.map((g, gi) => (
        <details class="masail-subject" open={gi === 0}>
          <summary>
            <span class="masail-subject-name">{g.title}</span>
            <span class="faint masail-count">{toArabicDigits(g.count)} مسألة</span>
          </summary>
          <div class="masail-topics">
            {g.topics.map((t) => (
              <details class="masail-topic">
                <summary>
                  <span>{t.title}</span>
                  <span class="faint masail-count">{toArabicDigits(t.items.length)}</span>
                </summary>
                <ul class="masail-list">
                  {t.items.map((it) => (
                    <li
                      data-title={it.data.title}
                      data-person={(it.data.person as string | undefined) ?? ""}
                      data-person-name={it.data.person ? names.get(it.data.person as string) ?? "" : ""}
                      data-topics={((it.data.topics as string[] | undefined) ?? []).join(",")}
                      data-ts={+new Date(it.data.published_at as string) || 0}
                    >
                      <a href={hrefFor("question", it.id)}>
                        {(it.data.topics as string[] | undefined)?.[0] && topicMap.get((it.data.topics as string[])[0]) && (
                          <span class="pill tag-accent masail-topic-tag">{topicMap.get((it.data.topics as string[])[0])}</span>
                        )}
                        <span>{it.data.title}</span>
                        {it.data.person && <span class="faint"> · {names.get(it.data.person as string)}</span>}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ))}
          </div>
        </details>
      ))}

      {uncategorized.length > 0 && (
        <details class="masail-subject">
          <summary>
            <span class="masail-subject-name">مسائلُ أخرى</span>
            <span class="faint masail-count">{toArabicDigits(uncategorized.length)}</span>
          </summary>
          <ul class="masail-list masail-list-flush">
            {uncategorized.map((it) => (
              <li
                data-title={it.data.title}
                data-person={(it.data.person as string | undefined) ?? ""}
                data-person-name={it.data.person ? names.get(it.data.person as string) ?? "" : ""}
                data-topics={((it.data.topics as string[] | undefined) ?? []).join(",")}
                data-ts={+new Date(it.data.published_at as string) || 0}
              ><a href={hrefFor("question", it.id)}>{it.data.title}</a></li>
            ))}
          </ul>
        </details>
      )}
    </div>
  </div>

  <script is:inline data-astro-rerun>
    (() => {
      const browse = document.querySelector("[data-masail-browse]");
      if (!browse) return;
      const trees = [...browse.querySelectorAll(":scope > details")];
      const btns = document.querySelectorAll("[data-masail-view]");
      // flat view built lazily from the tree's own <li>s, newest first —
      // the filters keep working on the clones (same data-* attrs)
      let flat = null;
      const buildFlat = () => {
        flat = document.createElement("ul");
        flat.className = "masail-list masail-list-flush masail-flat";
        [...browse.querySelectorAll(":scope > details li[data-title]")]
          .sort((a, b) => (+b.dataset.ts || 0) - (+a.dataset.ts || 0))
          .forEach((li) => flat.appendChild(li.cloneNode(true)));
        browse.prepend(flat);
      };
      const apply = (view) => {
        const isFlat = view === "flat";
        if (isFlat && !flat) buildFlat();
        if (flat) flat.hidden = !isFlat;
        trees.forEach((d) => { d.style.display = isFlat ? "none" : ""; });
        btns.forEach((b) => b.setAttribute("aria-pressed", String(b.dataset.masailView === view)));
      };
      btns.forEach((b) =>
        b.addEventListener("click", () => {
          apply(b.dataset.masailView);
          try { localStorage.setItem("aa-masail-view", b.dataset.masailView); } catch {}
        }),
      );
      let saved = "tree";
      try { saved = localStorage.getItem("aa-masail-view") || "tree"; } catch {}
      apply(saved);
    })();
  </script>
</Base>
