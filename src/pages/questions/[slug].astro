---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Prose from "../../components/Prose.astro";
import { isPub, loadGraph } from "../../lib/site";
import { hrefFor } from "../../lib/display";
import { questionLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const questions = (await getCollection("question")).filter(isPub);
  const graph = await loadGraph();
  return questions.map((entry) => {
    const person = entry.data.person ? graph.getById("person", entry.data.person) : null;
    return {
      params: { slug: entry.id },
      props: { entry, personName: person?.data.title, personId: person?.id },
    };
  });
}

const { entry, personName, personId } = Astro.props;
const path = `/questions/${entry.id}`;
const answerText = (entry.body ?? "").replace(/[#*_`>]/g, "").replace(/\s+/g, " ").trim().slice(0, 4000);
const jsonLd = questionLd({
  title: entry.data.title, answerText, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "المسائل", path: "/questions" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} activeNav="home" ogType="article" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "question" }}>
  <Breadcrumbs width="wrap-read" items={[{ label: "الرئيسية", href: "/" }, { label: "المسائل", href: "/questions" }, { label: entry.data.title }]} />
  <div class="wrap-read reading-pad">
    <div class="reader-head">
      <div class="eyebrow u87c136d" >مسائل</div>
      <h1 class="reader-title u97df06b" >{entry.data.title}</h1>
      {personId && <div class="reader-byline"><a href={hrefFor("person", personId)} class="uae3c165">{personName}</a></div>}
    </div>
    <div class="rule-short"></div>
    <div class="ua26bda7"><Prose body={entry.body ?? ""} /></div>
  </div>
</Base>
