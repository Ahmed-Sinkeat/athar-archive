---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import { isPub, loadGraph, subjectTitlesFor } from "../../lib/site";
import { readBody } from "../../lib/read-body";
import { markdownMasailToHtml } from "../../lib/sanitize";
import { hrefFor } from "../../lib/display";
import { questionLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const questions = (await getCollection("question")).filter(isPub);
  const graph = await loadGraph();
  const paths = [];
  for (const entry of questions) {
    const body = await readBody(entry);
    const person = entry.data.person ? graph.getById("person", entry.data.person) : null;
    const audioEntry = entry.data.audio ? graph.getById("audio", entry.data.audio) : null;
    // مسائل أخرى: same مجيب first, then the rest
    const others = [...questions]
      .filter((q) => q.id !== entry.id)
      .sort((a, b) => Number(b.data.person === entry.data.person) - Number(a.data.person === entry.data.person))
      .slice(0, 4)
      .map((q) => ({
        href: hrefFor("question", q.id),
        title: q.data.title as string,
        person: q.data.person ? (graph.getById("person", q.data.person)?.data.title as string | undefined) : undefined,
      }));
    paths.push({
      params: { slug: entry.id },
      props: {
        entry, body, personName: person?.data.title as string | undefined, personId: person?.id,
        subjects: subjectTitlesFor(entry.data.topics, graph), others,
        audio: audioEntry
          ? {
              url: audioEntry.data.url as string,
              format: audioEntry.data.format as "opus" | "mp3" | undefined,
              duration: (audioEntry.data.duration as string | null) ?? null,
              sizeBytes: (audioEntry.data.size_bytes as number | null) ?? null,
            }
          : null,
      },
    });
  }
  return paths;
}

const { entry, body, personName, personId, subjects, others, audio } = Astro.props;
const path = `/questions/${entry.id}`;
const answerText = body.replace(/[#*_`>]/g, "").replace(/\s+/g, " ").trim().slice(0, 4000);
const jsonLd = questionLd({
  title: entry.data.title, answerText, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "المسائل", path: "/questions" }, { name: entry.data.title, path }],
});

// Split the rendered body at the «الجواب» heading (tagged masail-a by the
// processor) so السؤال gets its own subordinate card and الجواب its section
// head (HANDOFF §5 المسائل). Falls back to one prose block when absent.
const html = markdownMasailToHtml(body);
let questionHtml: string | null = null;
let answerHtml: string | null = null;
let answerTitle = "الجواب";
{
  // question = the «السؤال» h2's content; answer = from the next h2 on,
  // whatever it's titled («الجواب…», «مسألة: …», …)
  const qMatch = html.match(/<h2[^>]*>\s*السؤال[\s\S]*?<\/h2>/);
  const qEnd = qMatch && qMatch.index !== undefined ? qMatch.index + qMatch[0].length : -1;
  const rest = qEnd >= 0 ? html.slice(qEnd) : html;
  const aMatch = rest.match(/<h2[^>]*>([\s\S]*?)<\/h2>/);
  if (aMatch && aMatch.index !== undefined && (qEnd >= 0 || /^\s*(الجواب|مسألة)/.test(aMatch[1].replace(/<[^>]+>/g, "")))) {
    answerTitle = aMatch[1].replace(/<[^>]+>/g, "").trim() || "الجواب";
    answerHtml = rest.slice(aMatch.index + aMatch[0].length);
    questionHtml = (qEnd >= 0 ? rest.slice(0, aMatch.index) : html.slice(0, aMatch.index)).trim() || null;
  }
}
---
<Base title={entry.data.title} activeNav="questions" ogType="article" jsonLd={jsonLd} readingPage>
  <Breadcrumbs width="wrap-read" items={[{ label: "الرئيسية", href: "/" }, { label: "المسائل", href: "/questions" }, { label: entry.data.title }]} />
  <article class="wrap-read reading-pad" data-cite-book={entry.data.title} data-cite-author={personName}>
    <header class="masala-head">
      <span class="masala-badge">مسألة</span>
      <h1 class="masala-title">{entry.data.title}</h1>
      {personId && (
        <p class="masala-byline">من أجوبة <a href={hrefFor("person", personId)}>{personName}</a></p>
      )}
      {subjects.length > 0 && (
        <p class="masala-meta">
          {subjects.map((s, i) => <Fragment>{i > 0 && <span class="masala-dot" aria-hidden="true"></span>}<span>{s}</span></Fragment>)}
        </p>
      )}
    </header>

    {audio && <AudioPlayer sources={[audio]} title={entry.data.title} subtitle={personName} />}

    {questionHtml && answerHtml ? (
      <>
        <section class="masala-question">
          <p class="masala-q-kicker">السؤال</p>
          <div class="prose masala-q-body" data-ar set:html={questionHtml} />
        </section>
        <div class="section-head"><h2>{answerTitle}</h2><div class="rule-fill"></div></div>
        <div class="prose masala-answer" data-ar set:html={answerHtml} />
      </>
    ) : (
      <div class="prose" data-ar set:html={html} />
    )}

    {others.length > 0 && (
      <section class="hub-section masala-others">
        <div class="section-head"><h2>مسائلُ أخرى</h2><div class="rule-fill"></div></div>
        {others.map((o) => (
          <a class="latest-row" href={o.href}>
            <span class="latest-name masala-other-title">{o.title}</span>
            {o.person && <span class="faint row-author">{o.person}</span>}
            <span class="row-spacer"></span>
            <span class="latest-arrow">←</span>
          </a>
        ))}
      </section>
    )}
  </article>
</Base>

<style>
  .masala-head { text-align: center; margin-bottom: 34px; }
  .masala-badge {
    display: inline-block; font-family: var(--f-ui); font-size: 10.5px; font-weight: 600;
    color: var(--brand); border: 1px solid color-mix(in srgb, var(--brand) 30%, transparent);
    border-radius: 5px; padding: 3px 12px; margin-bottom: 16px;
  }
  .masala-title {
    margin: 0 0 12px; font-family: var(--f-disp); font-size: clamp(24px, 4.5vw, 32px);
    font-weight: 700; line-height: 1.75; max-width: 620px; margin-inline: auto;
  }
  .masala-byline { margin: 0 0 8px; font-size: 13px; color: var(--ink2); }
  .masala-byline a { font-family: var(--f-disp); font-size: 16px; font-weight: 700; color: var(--brand); text-decoration: none; }
  .masala-meta { margin: 0; display: flex; align-items: center; justify-content: center; gap: 10px; font-size: 12px; color: var(--ink3); flex-wrap: wrap; }
  .masala-dot { width: 3px; height: 3px; border-radius: 99px; background: var(--ink3); }

  /* السؤال — subordinate to the answer: card, 3px maroon side border, ink2 */
  .masala-question {
    background: var(--card); border: 1px solid var(--line); border-inline-start: 3px solid var(--brand);
    border-radius: 10px; padding: 20px 24px; margin-bottom: 34px;
  }
  .masala-q-kicker {
    margin: 0 0 12px; display: flex; align-items: center; gap: 8px;
    font-family: var(--f-ui); font-size: 11.5px; font-weight: 600; letter-spacing: .1em; color: var(--brand);
  }
  .masala-q-kicker::before { content: ""; width: 7px; height: 7px; background: var(--brand); transform: rotate(45deg); flex: none; }
  .masala-q-body { font-size: calc(15px * var(--reading-scale)); line-height: 2.15; color: var(--ink2); text-align: justify; }
  .masala-q-body :global(p) { color: var(--ink2); }

  .masala-others { margin-top: 44px; }
  .masala-other-title { font-size: 16.5px; }
</style>
