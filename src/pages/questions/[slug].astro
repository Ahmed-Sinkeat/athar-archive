---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { isPub, loadGraph, subjectTitlesFor } from "../../lib/site";
import { readBody } from "../../lib/read-body";
import { markdownMasailToHtml } from "../../lib/sanitize";
import { hrefFor } from "../../lib/display";
import { questionLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const questions = (await getCollection("question")).filter(isPub);
  const graph = await loadGraph();
  const paths = [];
  for (const entry of questions) {
    const body = await readBody(entry);
    const person = entry.data.person ? graph.getById("person", entry.data.person) : null;
    paths.push({
      params: { slug: entry.id },
      props: { entry, body, personName: person?.data.title as string | undefined, personId: person?.id, subjects: subjectTitlesFor(entry.data.topics, graph) },
    });
  }
  return paths;
}

const { entry, body, personName, personId, subjects } = Astro.props;
const path = `/questions/${entry.id}`;
const answerText = body.replace(/[#*_`>]/g, "").replace(/\s+/g, " ").trim().slice(0, 4000);
const jsonLd = questionLd({
  title: entry.data.title, answerText, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "المسائل", path: "/questions" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} activeNav="questions" ogType="article" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "question", person: personName, subjects }}>
  <Breadcrumbs width="wrap-read" items={[{ label: "الرئيسية", href: "/" }, { label: "المسائل", href: "/questions" }, { label: entry.data.title }]} />
  <div class="wrap-read reading-pad">
    <div class="reader-head">
      <div class="eyebrow u87c136d" >مسائل</div>
      <h1 class="reader-title u97df06b" >{entry.data.title}</h1>
      {personId && <div class="reader-byline"><a href={hrefFor("person", personId)} class="uae3c165">{personName}</a></div>}
    </div>
    <div class="rule-short"></div>
    <div class="ua26bda7 prose" data-ar set:html={markdownMasailToHtml(body)} />
  </div>
</Base>
