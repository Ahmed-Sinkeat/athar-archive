---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Prose from "../../components/Prose.astro";
import { isPub, loadGraph } from "../../lib/site";
import { hrefFor } from "../../lib/display";

export async function getStaticPaths() {
  const questions = (await getCollection("question")).filter(isPub);
  const graph = await loadGraph();
  return questions.map((entry) => {
    const person = entry.data.person ? graph.getById("person", entry.data.person) : null;
    return {
      params: { slug: entry.id },
      props: { entry, personName: person?.data.title, personId: person?.id },
    };
  });
}

const { entry, personName, personId } = Astro.props;
---
<Base title={entry.data.title} activeNav="home">
  <Breadcrumbs width="wrap-read" items={[{ label: "الرئيسية", href: "/" }, { label: "المسائل", href: "/questions" }, { label: entry.data.title }]} />
  <div class="wrap-read reading-pad">
    <div class="reader-head">
      <div class="eyebrow" style="margin-bottom:16px">مسائل</div>
      <h1 class="reader-title" style="font-size:clamp(28px,5vw,44px)">{entry.data.title}</h1>
      {personId && <div class="reader-byline"><a href={hrefFor("person", personId)} style="color:var(--accent);text-decoration:none">{personName}</a></div>}
    </div>
    <div class="rule-short"></div>
    <div style="margin-top:20px"><Prose body={entry.body ?? ""} /></div>
  </div>
</Base>
