---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
// مكتبتي — فوائدُ وإشاراتٌ مرجعيةٌ خاصةٌ بهذا الجهاز فقط. تُصنع بتظليل النصِّ أثناء
// القراءة وتُحفَظ في المتصفّح (localStorage)؛ لا تُرسَل لأيِّ خادم. القائمة تُبنى في
// المتصفّح من scripts/library.ts. ponytail: empty shell, the device fills it.
---
<Base title="الفوائد" description="فوائدُك وإشاراتُك المرجعيةُ المحفوظةُ على هذا الجهاز." activeNav="benefits" noindex>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الفوائد" }]} />
  <div class="wrap-mid u91a8701">
    <h1 class="page-title">مكتبتي</h1>
    <p class="page-intro">فوائدُك وإشاراتُك المرجعيةُ — تُصنَع بتظليلِ النصِّ أثناء القراءة، وتُحفَظ على هذا الجهازِ وحده.</p>
    <div class="lib-tabs" data-lib-tabs>
      <button data-lib-tab="benefit" aria-pressed="true">الفوائد</button>
      <button data-lib-tab="bookmark" aria-pressed="false">الإشارات المرجعية</button>
    </div>
    <div data-lib-list></div>
  </div>
  <script>
    import "../scripts/library.ts";
  </script>
</Base>
