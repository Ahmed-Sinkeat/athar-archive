---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import SectionSearch from "../components/SectionSearch.astro";
import { personNameMap, publishedSorted } from "../lib/site";
import { hrefFor } from "../lib/display";

const benefits = await publishedSorted("benefit");
const names = await personNameMap();
---
<Base title="الفوائد" description="فوائدُ علميةٌ مستخرجةٌ من المتون والدروس والمقالات." activeNav="benefits">
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "الفوائد" }]} />
  <div class="wrap-mid uf5db21c" >
    <h1 class="page-title">الفوائد</h1>
    <SectionSearch scope="benefit" placeholder="ابحث في الفوائد…" />
    <div class="card-grid u44f04b0" >
      {benefits.map((e) => (
        <a class="card" href={hrefFor("benefit", e.id)}>
          <div class="benefit-quote u4f07dcd"  data-ar>«{e.data.title}»</div>
          <div class="faint u7c95cb6" >{names.get(e.data.person)}</div>
        </a>
      ))}
    </div>
  </div>
</Base>
