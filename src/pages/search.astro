---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
// Static client-side search via Pagefind (index built post-`astro build`).
// Results are noindex (FR-S-04/06); no server, no keys (SEC-01).
---
<Base title="البحث" activeNav="home" noindex>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "البحث" }]} />
  <div class="wrap-mid uf5db21c" >
    <h1 class="page-title">البحث</h1>
    <p class="page-intro">ابحثْ في المتون والمنظومات والدروس والفوائد والمقالات. يعملُ البحثُ بلا خادمٍ، وبفهرسٍ ثابتٍ يُبنى مع الموقع.</p>

    <div class="u7fc16fa">
      <div class="u6371093">
        <input id="q" type="search" autocomplete="off" placeholder="ابحث…" class="u38ae86c" />
      </div>
    </div>

    <div id="filters" class="chip-row u86de7ac" ></div>
    <div id="status" class="faint u608848d" ></div>
    <div id="results" class="u3f99027"></div>

    <noscript>
      <p class="faint u2517a51" >يحتاجُ البحثُ إلى تفعيل JavaScript. يمكنك التصفّحُ عبر <a href="/books" class="ua805525">الكتب</a> و<a href="/poems" class="ua805525">المنظومات</a> و<a href="/subjects" class="ua805525">الموضوعات</a>.</p>
    </noscript>
  </div>

  <script is:inline>
    (async () => {
      const LABEL = { poem: "منظومة", book: "كتاب", series: "سلسلة", lesson: "درس", person: "عَلَم", subject: "تصنيف", topic: "موضوع", benefit: "فائدة", article: "مقالة", question: "مسائل" };
      const input = document.getElementById("q");
      const results = document.getElementById("results");
      const status = document.getElementById("status");
      const filtersEl = document.getElementById("filters");
      const params = new URLSearchParams(location.search);

      // Fixed scope carried in from a section / reader / person page.
      const scope = {
        type: params.get("scope"),
        person: params.get("person"),
        id: params.get("in"),
        label: params.get("label"),
      };
      const hasScope = !!(scope.type || scope.person || scope.id);

      // Facet selections (narrow within current results).
      let activeType = null;
      let activePerson = null;

      if (hasScope) {
        const what = scope.id ? (scope.label || "هذا المتن")
          : scope.person ? `أرشيف ${scope.label || scope.person}`
          : (LABEL[scope.type] || scope.type);
        input.placeholder = `ابحث ضمن ${what}…`;
      }

      let pagefind;
      try {
        pagefind = await import("/pagefind/pagefind.js");
        if (pagefind.init) await pagefind.init();
      } catch (e) {
        status.textContent = "سيُفعَّل البحثُ بعد بناء الموقع (الفهرس يُولَّد مع البناء).";
        return;
      }

      function esc(s) { const d = document.createElement("div"); d.textContent = s; return d.innerHTML; }
      function toAr(n) { return String(n).replace(/[0-9]/g, (d) => "٠١٢٣٤٥٦٧٨٩"[+d]); }

      function chip(label, pressed, onClick, cls) {
        const b = document.createElement("button");
        b.className = "chip" + (cls ? " " + cls : "");
        b.textContent = label;
        b.setAttribute("aria-pressed", String(pressed));
        b.onclick = onClick;
        return b;
      }

      function buildFilters() {
        const f = {};
        if (scope.type) f.type = scope.type;
        if (scope.person) f.person = scope.person;
        if (scope.id) f.id = scope.id;
        if (activeType) f.type = activeType;
        if (activePerson) f.person = activePerson;
        return Object.keys(f).length ? f : undefined;
      }

      function renderFilters(data) {
        filtersEl.innerHTML = "";
        if (hasScope) {
          const what = scope.id ? `ضمن: ${scope.label || "هذا المتن"}`
            : scope.person ? `أرشيف: ${scope.label || scope.person}`
            : `النوع: ${LABEL[scope.type] || scope.type}`;
          filtersEl.appendChild(chip(`${what} ✕`, true, () => {
            location.href = "/search" + (input.value ? "?q=" + encodeURIComponent(input.value) : "");
          }, "chip-scope"));
        }
        if (!scope.type && !scope.id) {
          const types = [...new Set(data.flatMap((d) => d.filters?.type || []))];
          if (types.length > 1 || activeType) {
            filtersEl.appendChild(chip("كل الأنواع", !activeType, () => { activeType = null; run(input.value); }));
            types.forEach((tp) => filtersEl.appendChild(chip(LABEL[tp] || tp, activeType === tp, () => { activeType = tp; run(input.value); })));
          }
        }
        if (!scope.person && !scope.id) {
          const persons = [...new Set(data.flatMap((d) => d.filters?.person || []))];
          if (persons.length > 1 || activePerson) {
            filtersEl.appendChild(chip("كل الأعلام", !activePerson, () => { activePerson = null; run(input.value); }));
            persons.forEach((p) => filtersEl.appendChild(chip(p, activePerson === p, () => { activePerson = p; run(input.value); })));
          }
        }
      }

      async function run(query) {
        const q = (query || "").trim();
        const url = new URL(location.href);
        if (q) url.searchParams.set("q", q); else url.searchParams.delete("q");
        history.replaceState(null, "", url);
        results.innerHTML = "";
        if (!q) { status.textContent = ""; renderFilters([]); return; }

        const filters = buildFilters();
        const search = await pagefind.search(q, filters ? { filters } : undefined);
        const data = await Promise.all(search.results.slice(0, 30).map((r) => r.data()));

        status.textContent = data.length ? `${toAr(data.length)} نتيجة لـ «${q}»` : `لا نتائج لـ «${q}».`;
        renderFilters(data);

        for (const d of data) {
          const type = (d.filters?.type || [])[0];
          const a = document.createElement("a");
          a.href = d.url;
          a.className = "latest-row";
          a.style.alignItems = "flex-start";
          a.innerHTML =
            `<span class="pill tag-accent uac6ea07" >${LABEL[type] || ""}</span>` +
            `<span class="u97445a8"><span class="latest-name u2a1b75c" >${esc(d.meta?.title || "")}</span>` +
            `<span class="faint ue24357e" data-ar >${d.excerpt}</span></span>`;
          results.appendChild(a);
        }
      }

      let t;
      input.addEventListener("input", () => { clearTimeout(t); t = setTimeout(() => run(input.value), 180); });

      const initial = params.get("q");
      if (initial) { input.value = initial; run(initial); }
      else if (hasScope) { renderFilters([]); }
      input.focus();
    })();
  </script>
</Base>
