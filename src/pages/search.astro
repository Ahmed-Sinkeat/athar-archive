---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
// Real on-site search: client fetches /api/search (D1 FTS5 index built by
// scripts/gen-search-index.ts). Replaced the Google site-search delegation —
// still no keys, no third-party (SEC-01); noindex (FR-S-04/06).
// ONE control: بالنص (full-text) | بالعنوان (titles only). Content-type scoping
// and the الكل/mode/sort selects were removed per request — title mode returns a
// clean one-row-per-work list (API dedupes chunked-book chapters), text mode
// lists each matching passage with an expandable snippet and lands on the exact
// spot (chapter/ayah url + aa-hl in-page scroll). `in=<book id>` may still arrive
// from an in-reader "search this book" link and narrows the query if present.
---
<Base title="البحث" activeNav="home" noindex>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "البحث" }]} />
  <div class="wrap-mid search-page">
    <div class="search-bar-row">
      <div class="search-bar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path></svg>
        <input id="q" data-topsearch-input type="search" autocomplete="off" placeholder="ابحث في المتون والمنظومات والأعلام…" class="search-input" />
      </div>
      <button type="button" id="go" class="search-submit">بحث</button>
    </div>

    <div id="history" class="search-history" hidden></div>

    <div class="search-modes" role="group" aria-label="نوع البحث">
      <button type="button" class="search-mode" data-mode="text" aria-pressed="true">بالنص</button>
      <button type="button" class="search-mode" data-mode="title" aria-pressed="false">بالعنوان</button>
    </div>
    <div class="search-tools-row">
      <span id="results-count" class="search-count"></span>
    </div>
    <div id="results" class="search-results" aria-live="polite"></div>
    <button type="button" id="more" class="search-load-more" hidden>تحميل المزيد</button>

    <style is:global>
      .search-page { padding-top: 8px; }
      .search-bar-row { display: flex; gap: 8px; }
      .search-bar {
        flex: 1; display: flex; align-items: center; gap: 10px; background: var(--surface);
        border: 1px solid var(--rule-strong); border-radius: 10px; padding: 0 16px; height: 50px;
        color: var(--ink-faint);
      }
      .search-input {
        flex: 1; border: none; outline: none; background: transparent;
        font-family: var(--font-serif); font-size: 17px; color: var(--ink);
      }
      .search-submit {
        background: var(--accent); color: var(--onbrand, #fff); border: none; border-radius: 10px;
        padding: 0 26px; font-family: var(--font-ui); font-size: 14px; font-weight: 600; cursor: pointer;
      }
      .search-submit:hover { background: var(--brand2, var(--accent)); }
      .search-history { display: flex; flex-wrap: wrap; gap: 6px; margin: 10px 0 0; }
      .search-history-chip {
        font-family: var(--font-ui); font-size: 11.5px; color: var(--ink-faint); background: none;
        border: 1px dashed var(--rule); border-radius: 999px; padding: 4px 12px; cursor: pointer;
      }
      .search-history-chip:hover { border-style: solid; color: var(--ink-soft); }
      /* two-mode toggle (بالنص / بالعنوان) — segmented pill, the ONLY search
         control now (content-type scoping + الكل removed per request) */
      .search-modes { display: inline-flex; gap: 4px; margin: 16px 0 10px; padding: 3px; background: var(--inset); border-radius: 999px; }
      .search-mode {
        font-family: var(--font-ui); font-size: 12.5px; font-weight: 600; color: var(--ink-soft);
        background: none; border: none; border-radius: 999px; padding: 6px 18px; cursor: pointer;
        transition: background .15s, color .15s;
      }
      .search-mode[aria-pressed="true"] { background: var(--surface); color: var(--ink); box-shadow: 0 1px 3px color-mix(in srgb, var(--shdw) 12%, transparent); }
      .search-tools-row { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin: 0 0 16px; }
      .search-count { font-size: 12px; color: var(--ink-faint); }

      /* results as a clean book-list (matches /books rows): kind pill, title,
         author. Text mode adds an expandable snippet of the match below. */
      .search-results { display: flex; flex-direction: column; gap: 10px; }
      .search-hit {
        position: relative; background: var(--surface); border: 1px solid var(--rule);
        border-inline-end: 3px solid var(--accent); border-radius: 10px; padding: 14px 18px;
        color: var(--ink); transition: border-color .15s;
      }
      .search-hit:hover { border-color: var(--accent); }
      .search-hit[data-type="quran"] { border-inline-end-color: var(--gold-text); }
      .search-hit[data-type="poem"] { border-inline-end-color: var(--copper); }
      .search-hit[data-type="article"], .search-hit[data-type="term"] { border-inline-end-color: var(--verdigris); }
      /* stretched overlay link: whole row navigates, but the expand/copy
         buttons (stacked above) stay independently clickable — same invalid-
         nesting-avoidance pattern as EntityCard's .card-link */
      .search-hit-link { position: absolute; inset: 0; z-index: 0; border-radius: inherit; }
      .search-hit > :not(.search-hit-link):not(.search-hit-actions) { position: relative; z-index: 1; pointer-events: none; }
      .search-hit-kindrow { margin: 0 0 6px; }
      .search-hit-kindrow .pill { font-size: 10.5px; padding: 2px 9px; }
      .search-hit-title { font-family: var(--font-display); font-weight: 700; font-size: 18px; line-height: 1.5; color: var(--ink); }
      .search-hit[data-type="poem"] .search-hit-title { color: var(--copper); }
      .search-hit-sub { margin-top: 3px; font-family: var(--font-ui); font-size: 12.5px; color: var(--ink-faint); }
      .search-hit-snippet {
        margin: 10px 0 0; padding-top: 10px; border-top: 1px dashed var(--rule);
        font-family: var(--font-serif); font-size: 16px; line-height: 2; color: var(--ink-soft);
      }
      .search-hit-snippet mark { background: var(--gold-soft); color: var(--ink); border-radius: 3px; padding: 0 3px; }
      .search-hit-full {
        margin: 8px 0 0; font-family: var(--font-serif); font-size: 15.5px; line-height: 2; color: var(--ink); white-space: pre-wrap;
      }
      .search-hit-actions { position: absolute; z-index: 2; inset-inline-end: 12px; bottom: 10px; display: flex; gap: 2px; }
      .search-hit-expand, .search-hit-copy {
        background: none; border: none; cursor: pointer;
        color: var(--ink-faint); padding: 4px; line-height: 0; border-radius: 6px;
      }
      .search-hit-expand:hover, .search-hit-copy:hover { color: var(--ink); background: var(--inset); }
      .search-hit-expand[aria-expanded="true"] svg { transform: rotate(180deg); }
      .search-hit-expand svg { transition: transform .15s; }
      .search-load-more {
        display: block; margin: 20px auto 0; font-family: var(--font-ui); font-size: 13px; font-weight: 600;
        color: var(--ink); background: var(--surface); border: 1px solid var(--rule-strong); border-radius: 8px;
        padding: 10px 24px; cursor: pointer;
      }
      .search-load-more:hover { border-color: var(--accent); color: var(--accent); }
      .search-empty { font-family: var(--font-ui); font-size: 14px; color: var(--ink-soft); margin-top: 24px; }
    </style>

    <noscript>
      <p class="faint u2517a51" >للبحث فعِّلْ JavaScript، أو تصفّحْ عبر <a href="/books" class="ua805525">الكتب</a> و<a href="/poems" class="ua805525">المنظومات</a> و<a href="/subjects" class="ua805525">الموضوعات</a>.</p>
    </noscript>
  </div>

  <script is:inline data-astro-rerun>
    (() => {
      const input = document.getElementById("q");
      if (!input) return;
      const results = document.getElementById("results");
      const countEl = document.getElementById("results-count");
      const moreBtn = document.getElementById("more");
      const historyEl = document.getElementById("history");
      const params = new URLSearchParams(location.search);
      // a book scope may still arrive from an in-reader "search this book" link
      const inBook = params.get("in") || "";

      const TYPE_LABEL = { quran: "قرآن", book: "كتاب", poem: "منظومة", article: "مقالة", question: "مسألة", term: "معجم", person: "عَلَم" };
      // the ONE control: بالنص (full-text) | بالعنوان (titles only)
      let field = params.get("field") === "title" ? "title" : "text";
      const modeBtns = document.querySelectorAll(".search-mode");
      const syncModes = () => modeBtns.forEach((b) => b.setAttribute("aria-pressed", String(b.dataset.mode === field)));
      syncModes();
      modeBtns.forEach((b) => {
        b.addEventListener("click", () => {
          if (b.dataset.mode === field) return;
          field = b.dataset.mode;
          syncModes();
          offset = 0;
          go();
        });
      });

      // recent searches (localStorage, most-recent-first, capped)
      const HIST_KEY = "aa-search-history";
      const getHistory = () => { try { return JSON.parse(localStorage.getItem(HIST_KEY) || "[]"); } catch { return []; } };
      const addHistory = (term) => {
        const h = [term, ...getHistory().filter((t) => t !== term)].slice(0, 8);
        localStorage.setItem(HIST_KEY, JSON.stringify(h));
      };
      const esc = (s) => s.replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));
      const renderHistory = () => {
        const h = getHistory();
        if (!h.length || input.value.trim()) { historyEl.hidden = true; return; }
        historyEl.innerHTML = h.map((t) => `<button type="button" class="search-history-chip">${esc(t)}</button>`).join("");
        historyEl.hidden = false;
      };
      historyEl.addEventListener("click", (e) => {
        const btn = e.target.closest(".search-history-chip");
        if (!btn) return;
        input.value = btn.textContent;
        offset = 0;
        go();
      });
      input.addEventListener("focus", renderHistory);

      let seq = 0;
      let offset = 0;
      let lastHits = [];
      // search links to a paragraph anchor for quran/"athar"-numbered books only —
      // everything else has none, so the target page can't scroll/highlight on
      // its own. aa-hl carries the query there instead; marks.ts's in-page find
      // (already tashkeel-insensitive, already highlights + scrolls) picks it up
      // on load. Query params must come before any #hash, not after.
      const withHl = (url, term) => {
        if (!term) return url;
        const i = url.indexOf("#");
        const path = i < 0 ? url : url.slice(0, i);
        const hash = i < 0 ? "" : url.slice(i);
        return `${path}${path.includes("?") ? "&" : "?"}aa-hl=${encodeURIComponent(term)}${hash}`;
      };
      // title mode → land on the WORK itself (a book's own landing page, not
      // whichever chapter row happened to win the group); text mode → land on
      // the exact passage (chapter/ayah/athar url + aa-hl scroll-to-match).
      const landingUrl = (h) => (h.book ? `/book/${h.book}` : h.url);
      const renderHit = (h, terms) => {
        const type = esc(h.type);
        const sub = h.person_name
          ? `<div class="search-hit-sub">${esc(h.person_name)}${h.death_year ? ` (ت ${h.death_year}هـ)` : ""}</div>` : "";
        const kindPill = TYPE_LABEL[h.type]
          ? `<div class="search-hit-kindrow"><span class="pill">${TYPE_LABEL[h.type]}</span></div>` : "";
        const head = kindPill + `<div class="search-hit-title">${esc(h.title)}</div>` + sub;

        if (field === "title") {
          // clean book-list row — no snippet, whole row opens the work
          return `<div class="search-hit" data-type="${type}">` +
            `<a class="search-hit-link" href="${esc(landingUrl(h))}" aria-label="${esc(h.title)}"></a>` +
            head + `</div>`;
        }
        // text mode: same row + the matched passage, expandable + copyable
        const snippet = esc(h.snippet || "").replaceAll("&lt;mark&gt;", "<mark>").replaceAll("&lt;/mark&gt;", "</mark>");
        return `<div class="search-hit" data-type="${type}" data-url="${esc(h.url)}">` +
          `<a class="search-hit-link" href="${esc(withHl(h.url, terms))}" aria-label="${esc(h.title)}"></a>` +
          head +
          `<p class="search-hit-snippet">${snippet}</p>` +
          `<div class="search-hit-full" hidden></div>` +
          `<div class="search-hit-actions">` +
          `<button type="button" class="search-hit-expand" title="عرض النص كاملاً" aria-label="عرض النص كاملاً" aria-expanded="false">` +
          `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>` +
          `</button>` +
          `<button type="button" class="search-hit-copy" title="نسخ" aria-label="نسخ النتيجة">` +
          `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>` +
          `</button></div></div>`;
      };
      // full paragraph text isn't in the search response (kept light — see
      // api/search.ts) — fetched once per result, on demand, and cached here
      // for both "expand" and "copy" to share.
      const fullTextCache = new Map();
      const fetchFullText = async (url) => {
        if (fullTextCache.has(url)) return fullTextCache.get(url);
        const p = fetch("/api/search?url=" + encodeURIComponent(url))
          .then((r) => (r.ok ? r.json() : { text: "" }))
          .then((d) => d.text || "")
          .catch(() => "");
        fullTextCache.set(url, p);
        return p;
      };
      results.addEventListener("click", async (e) => {
        const card = e.target.closest(".search-hit");
        if (!card) return;
        const url = card.dataset.url;
        const expandBtn = e.target.closest(".search-hit-expand");
        if (expandBtn) {
          const full = card.querySelector(".search-hit-full");
          const open = expandBtn.getAttribute("aria-expanded") === "true";
          if (open) { full.hidden = true; expandBtn.setAttribute("aria-expanded", "false"); return; }
          if (!full.textContent) { full.textContent = "…"; full.hidden = false; full.textContent = (await fetchFullText(url)) || "تعذَّر تحميل النص."; }
          else full.hidden = false;
          expandBtn.setAttribute("aria-expanded", "true");
          return;
        }
        const copyBtn = e.target.closest(".search-hit-copy");
        if (copyBtn) {
          const ok = () => { copyBtn.setAttribute("title", "نُسخ ✓"); setTimeout(() => copyBtn.setAttribute("title", "نسخ"), 1200); };
          const fail = () => { copyBtn.setAttribute("title", "تعذَّر النسخ"); setTimeout(() => copyBtn.setAttribute("title", "نسخ"), 1200); };
          const title = card.querySelector(".search-hit-title")?.textContent || "";
          const full = (await fetchFullText(url)) || card.querySelector(".search-hit-snippet")?.textContent || "";
          (navigator.clipboard?.writeText(`${title}\n${full}`) || Promise.reject()).then(ok, fail);
        }
      });

      const go = async (append = false) => {
        const terms = input.value.trim();
        const my = ++seq;
        if (!terms) { results.innerHTML = ""; countEl.textContent = ""; moreBtn.hidden = true; renderHistory(); return; }
        historyEl.hidden = true;
        const p = new URLSearchParams({ q: terms, field, offset: String(offset) });
        if (inBook) p.set("book", inBook);
        const res = await fetch("/api/search?" + p).catch(() => null);
        if (my !== seq) return; // a newer query already answered
        const data = res && res.ok ? await res.json() : null;
        if (my !== seq) return;
        if (!data) { results.innerHTML = '<p class="search-empty">تعذَّر البحث الآن — حاولْ لاحقًا.</p>'; countEl.textContent = ""; moreBtn.hidden = true; return; }
        lastHits = append ? lastHits.concat(data.hits) : data.hits;
        if (!lastHits.length) { results.innerHTML = '<p class="search-empty">لا نتائج.</p>'; countEl.textContent = ""; moreBtn.hidden = true; return; }
        countEl.textContent = data.approximate
          ? `${lastHits.length}${data.hasMore ? "+" : ""} نتيجة تقريبية — لا مطابقة تامة لِـ «${terms}»`
          : `${lastHits.length}${data.hasMore ? "+" : ""} نتيجة عن «${terms}»`;
        const html = data.hits.map((h) => renderHit(h, terms)).join("");
        if (append) results.insertAdjacentHTML("beforeend", html);
        else results.innerHTML = html;
        moreBtn.hidden = !data.hasMore;
        if (!append) addHistory(terms);
      };
      moreBtn.addEventListener("click", () => { offset += 20; go(true); });

      let t;
      input.addEventListener("input", () => { clearTimeout(t); offset = 0; t = setTimeout(go, 250); historyEl.hidden = true; });
      input.addEventListener("keydown", (e) => { if (e.key === "Enter") { clearTimeout(t); offset = 0; go(); } });
      document.getElementById("go")?.addEventListener("click", () => { clearTimeout(t); offset = 0; go(); });
      const initial = params.get("q");
      if (initial) { input.value = initial; go(); } else { renderHistory(); }
      input.focus();
    })();
  </script>
</Base>
