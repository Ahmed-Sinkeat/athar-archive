---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { config } from "../../ahlalathar.config.js";
// Search delegates to Google site search. Pagefind was removed: book/lesson bodies
// are now on-demand and never in the build, so a static index can't see them. Google
// crawls the on-demand pages (they're in sitemap.xml). Results open on Google. No
// server, no keys (SEC-01); noindex (FR-S-04/06).
const host = new URL(config.siteUrl).host;
---
<Base title="البحث" activeNav="home" noindex>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "البحث" }]} />
  <div class="wrap-mid uf5db21c" >
    <h1 class="page-title">البحث</h1>
    <p class="page-intro">ابحثْ في المتون والمنظومات والدروس والفوائد والمقالات. تُفتَح النتائجُ في Google.</p>

    <div class="u7fc16fa">
      <div class="u6371093">
        <input id="q" type="search" autocomplete="off" placeholder="ابحث…" class="u38ae86c" data-host={host} />
      </div>
    </div>
    <div id="scope-note" class="faint u608848d" ></div>
    <div class="u86de7ac"><button id="go" class="btn btn-accent">بحث في Google ↗</button></div>

    <noscript>
      <p class="faint u2517a51" >للبحث فعِّلْ JavaScript، أو تصفّحْ عبر <a href="/books" class="ua805525">الكتب</a> و<a href="/poems" class="ua805525">المنظومات</a> و<a href="/subjects" class="ua805525">الموضوعات</a>.</p>
    </noscript>
  </div>

  <script is:inline data-astro-rerun>
    (() => {
      const input = document.getElementById("q");
      if (!input) return;
      const host = input.dataset.host;
      const params = new URLSearchParams(location.search);
      const label = params.get("label"); // optional scope hint carried from a section/reader page
      if (label) document.getElementById("scope-note").textContent = `سياق: ${label}`;
      const go = () => {
        const terms = input.value.trim();
        if (!terms) return;
        const q = "site:" + host + " " + (label ? label + " " : "") + terms;
        window.open("https://www.google.com/search?q=" + encodeURIComponent(q), "_blank", "noopener");
      };
      document.getElementById("go").addEventListener("click", go);
      input.addEventListener("keydown", (e) => { if (e.key === "Enter") go(); });
      const initial = params.get("q");
      if (initial) input.value = initial;
      input.focus();
    })();
  </script>
</Base>
