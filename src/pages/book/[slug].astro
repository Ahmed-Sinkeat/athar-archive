---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Prose from "../../components/Prose.astro";
import StudyBar from "../../components/StudyBar.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import RelatedStrip from "../../components/RelatedStrip.astro";
import Relations from "../../components/Relations.astro";
import { markdownToSafeHtml } from "../../lib/sanitize";
import { isPub, loadGraph, personNameMap, subjectTitlesFor, notesByAnchor, relatedTo, backlinksList } from "../../lib/site";
import { analyzeBook } from "../../lib/chunk";
import { readBody } from "../../lib/read-body";
import { hrefFor, toArabicDigits, labelFor, isMatn } from "../../lib/display";
import { bookLd } from "../../lib/structured-data";
import { parseToc } from "../../lib/chapters";

export async function getStaticPaths() {
  const books = (await getCollection("book")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  const paths = [];
  for (const entry of books) {
    const body = await readBody(entry);
    const a = analyzeBook(body);
    const byAnchor = notesByAnchor("book", entry.id, graph, names);
    const audios = graph.audioForSource("book", entry.id)
      .filter((x) => x.data.status === "published")
      .map((au) => ({ url: au.data.url, format: au.data.format, duration: au.data.duration ?? null, sizeBytes: au.data.size_bytes ?? null, label: au.data.title }));
    const commentaries = graph.commentariesOf(entry.id)
      .filter(isPub)
      .map(c => ({ href: hrefFor("book", c.id), title: c.data.title, author: c.data.person ? names.get(c.data.person as string) : "" }));
    // Phase 2: chunked books → store a light TOC (titles+slugs) only; the body and
    // its annotations live on the on-demand chapter pages, never in this landing's HTML.
    paths.push({ params: { slug: entry.id }, props: { entry, chunked: a.chunked, toc: a.chapters.map((c) => ({ title: c.title, slug: c.slug })), tocNested: a.chunked ? [] : parseToc(body ?? ""), body: a.chunked ? undefined : body, byAnchor: a.chunked ? {} : byAnchor, audios, commentaries, author: names.get(entry.data.person), subjects: subjectTitlesFor(entry.data.topics, graph), related: relatedTo(entry, graph, names), backlinks: backlinksList(entry, graph, names) } });
  }
  return paths;
}

const { entry, chunked, toc, tocNested, body, byAnchor, audios, commentaries, author, subjects, related, backlinks } = Astro.props;
const KIND_SLUG: Record<string, string> = { شرح: "sharh", حاشية: "hashiya", تخريج: "takhrij", إعراب: "iraab" };
const anchors = Object.entries(byAnchor);
const path = `/book/${entry.id}`;
const jsonLd = bookLd({
  title: entry.data.title, authorId: entry.data.person, authorName: author,
  description: entry.data.description, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الكتب", path: "/books" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} description={entry.data.description} activeNav="books" ogType="book" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "book", id: entry.id, person: author, matn: isMatn("book", entry.data), subjects }} searchScope={{ in: entry.id, label: entry.data.title }}>
  <Breadcrumbs
    width="wrap-matn"
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الكتب", href: "/books" },
      { label: entry.data.title },
    ]}
  />
  <div class="wrap-matn reading-pad">
    <div class="reader-head">
      <a class="eyebrow u87c136d pill-link" href={isMatn("book", entry.data) ? "/matn" : "/books"}>{labelFor("book", entry.data)}</a>
      <h1 class="reader-title ue7e55f7" >{entry.data.title}</h1>
      <div class="reader-byline">{author}</div>
      {entry.data.transcript_status && (
        <div style="margin-top: 0.5rem;">
          <span class={`pill ${entry.data.transcript_status === 'قيد المراجعة' ? 'tag-accent' : ''}`}>{entry.data.transcript_status}</span>
        </div>
      )}
    </div>
    {audios.length > 0 && <div class="u49fcd85"><AudioPlayer sources={audios} label="استماعٌ إلى المتن" /></div>}

    {entry.data.transcript_status && (
      <div class="wrap-mid" style="margin-top: 1rem; text-align: center;">
        <button type="button" class="btn" data-action="transcript:send-review" data-book={entry.data.title}>أرسل ملاحظات المراجعة عبر البريد</button>
      </div>
    )}

    <div class="rule-short"></div>

    {chunked ? (
      <!-- light TOC: links to the on-demand chapter pages; no body in this HTML -->
      <nav class="toc-box has-current" aria-label="فهرس الفصول">
        <div class="toc-label">فصول الكتاب · {toArabicDigits(toc.length)} فصل</div>
        {toc.map((c) => (
          <a href={hrefFor("book", entry.id, { chapter: c.slug })}>{c.title}</a>
        ))}
      </nav>
    ) : isMatn("book", entry.data) ? (
      <>
        {tocNested?.length > 0 && (
          <nav class="toc-box has-current" aria-label="فهرس العناوين">
            <div class="toc-label">فهرس العناوين</div>
            {tocNested.map((h) => (
              <a href={`#${h.slug}`} style={`padding-inline-start: ${(h.depth - 2) * 1}rem`}>{h.title}</a>
            ))}
          </nav>
        )}
        <StudyBar prose downloadUrl={entry.data.attachments?.[0]?.url} />
        <div class="u49fcd85" data-matn={entry.id} data-unit="فقرة"><Prose body={body ?? ""} /></div>
      </>
    ) : (
      <>
        {tocNested?.length > 0 && (
          <nav class="toc-box has-current" aria-label="فهرس العناوين">
            <div class="toc-label">فهرس العناوين</div>
            {tocNested.map((h) => (
              <a href={`#${h.slug}`} style={`padding-inline-start: ${(h.depth - 2) * 1}rem`}>{h.title}</a>
            ))}
          </nav>
        )}
        <StudyBar prose downloadUrl={entry.data.attachments?.[0]?.url} />
        <div class="u49fcd85"><Prose body={body ?? ""} /></div>
      </>
    )}

    {/* All annotations now open in the bottom sheet: phrase notes are wrapped
        inline; whole-paragraph notes attach to their فقرة. The packs stay in the
        DOM (hidden) so Pagefind/no-JS still see the text. */}
    {anchors.map(([anchor, notes]) => (
      <div class="ann-pack" id={`ann-${anchor}`} data-ann-pack data-phrase={notes.find((n) => n.phrase)?.phrase} hidden>
        {notes.map((nt) => (
          <div class={`ann-entry k-${KIND_SLUG[nt.kind] ?? "sharh"}`} data-kind={nt.kind} data-label={nt.annotator ? `${nt.kind} — ${nt.annotator}` : nt.kind}>
            <div class="ann-entry-body" data-ar><Fragment set:html={markdownToSafeHtml(nt.body)} /></div>
            {nt.sourceHref && <a class="ann-source-link" href={nt.sourceHref}>اقرأ في موضعه{nt.sourceLabel ? `: ${nt.sourceLabel}` : ""} ←</a>}
          </div>
        ))}
      </div>
    ))}

    <div class="ornament ud38b410" >۞</div>
  </div>
  {commentaries.length > 0 && (
    <div class="wrap-mid" style="margin-top: 2rem; border-top: 1px solid var(--border, #e0e0e0); padding-top: 1rem;">
      <h2 class="section-title">شروحه وتعليقاته</h2>
      <ul style="list-style: none; padding: 0;">
        {commentaries.map(c => (
          <li style="margin-bottom: 0.5rem;"><a href={c.href}>{c.title}</a> {c.author && <span class="faint">— {c.author}</span>}</li>
        ))}
      </ul>
    </div>
  )}
  <div class="wrap-mid"><RelatedStrip items={related} /></div>
  <Relations items={backlinks} />
</Base>
