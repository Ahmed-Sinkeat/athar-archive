---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Prose from "../../components/Prose.astro";
import StudyBar from "../../components/StudyBar.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import Attachments from "../../components/Attachments.astro";
import { markdownToSafeHtml } from "../../lib/sanitize";
import { isPub, loadGraph, personNameMap } from "../../lib/site";
import { analyzeBook } from "../../lib/chunk";
import { hrefFor, toArabicDigits, labelFor, isMatn } from "../../lib/display";
import { bookLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const books = (await getCollection("book")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  return books.map((entry) => {
    const annos = graph
      .annotationsForTarget("book", entry.id)
      .filter((an) => an.data.status === "published")
      .map((an) => ({ kind: an.data.kind, anchor: an.data.anchor, body: an.body ?? "" }));
    const au = graph.audioForSource("book", entry.id).find((a) => a.data.status === "published");
    const audio = au ? { url: au.data.url, format: au.data.format, duration: au.data.duration ?? null, sizeBytes: au.data.size_bytes ?? null } : null;
    return { params: { slug: entry.id }, props: { entry, annos, audio, author: names.get(entry.data.person) } };
  });
}

const { entry, annos, audio, author } = Astro.props;
const a = analyzeBook(entry.body ?? "");
const path = `/book/${entry.id}`;
const jsonLd = bookLd({
  title: entry.data.title, authorId: entry.data.person, authorName: author,
  description: entry.data.description, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الكتب", path: "/books" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} description={entry.data.description} activeNav="books" ogType="book" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "book", id: entry.id, person: author, matn: isMatn("book", entry.data) }} searchScope={{ in: entry.id, label: entry.data.title }}>
  <Breadcrumbs
    width="wrap-matn"
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الكتب", href: "/books" },
      { label: entry.data.title },
    ]}
  />
  <div class="wrap-matn reading-pad">
    <div class="reader-head">
      <div class="eyebrow u87c136d" >{labelFor("book", entry.data)}</div>
      <h1 class="reader-title ue7e55f7" >{entry.data.title}</h1>
      <div class="reader-byline">{author}</div>
    </div>
    {audio && <div class="u49fcd85"><AudioPlayer url={audio.url} format={audio.format} duration={audio.duration} sizeBytes={audio.sizeBytes} label="استماعٌ إلى المتن" /></div>}

    <div class="rule-short"></div>

    {a.chunked ? (
      <div class="card-grid ue1dce25" >
        {a.chapters.map((c) => (
          <a class="card u6f3d7fe" href={hrefFor("book", entry.id, { chapter: c.slug })} >
            <div class="card-title ub9199e2" >{c.title}</div>
          </a>
        ))}
      </div>
    ) : isMatn("book", entry.data) ? (
      <>
        <StudyBar prose />
        <div class="u49fcd85" data-matn={entry.id} data-unit="فقرة"><Prose body={entry.body ?? ""} /></div>
      </>
    ) : (
      <div class="u49fcd85"><Prose body={entry.body ?? ""} /></div>
    )}

    {annos.length > 0 && (
      <div class="benefit-strip">
        <div class="toc-label uec818db" >حواشٍ وتخريجات</div>
        {annos.map((an) => (
          <div class="note u2a1b75c"  data-ar>
            <span class="note-kind">{an.kind} · {an.anchor}</span>
            <Fragment set:html={markdownToSafeHtml(an.body)} />
          </div>
        ))}
      </div>
    )}

    <Attachments items={entry.data.attachments} heading="طبعاتٌ وتحميلات" />

    <div class="ornament ud38b410" >۞</div>
  </div>
</Base>
