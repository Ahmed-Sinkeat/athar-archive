---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Prose from "../../components/Prose.astro";
import StudyBar from "../../components/StudyBar.astro";
import ReaderSidebar from "../../components/ReaderSidebar.astro";
import BookPageJump from "../../components/BookPageJump.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import RelatedStrip from "../../components/RelatedStrip.astro";
import Relations from "../../components/Relations.astro";
import { markdownToSafeHtml } from "../../lib/sanitize";
import { isPub, loadGraph, personNameMap, notesByAnchor, relatedTo, backlinksList, originOf } from "../../lib/site";
import { analyzeBook, deriveVolumes } from "../../lib/chunk";
import { readBody } from "../../lib/read-body";
import { hrefFor, toArabicDigits, isMatn, labelFor } from "../../lib/display";
import { bookLd } from "../../lib/structured-data";
import { parseToc, parseBook } from "../../lib/chapters";
import { isAtharNumberedBook, injectAtharAnchors, type TakhrijLink } from "../../lib/hadith";
import takhrijData from "../../data/takhrij.json";

export async function getStaticPaths() {
  const books = (await getCollection("book")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  const paths = [];
  for (const entry of books) {
    const body = await readBody(entry);
    const a = analyzeBook(body);
    const atharNumbered = !a.chunked && isAtharNumberedBook(parseBook(body).paragraphs);
    const takhrijFor = (n: number) => (takhrijData as Record<string, TakhrijLink[]>)[`${entry.id}:${n}`];
    const renderBody = atharNumbered ? injectAtharAnchors(body, takhrijFor) : body;
    const byAnchor = notesByAnchor("book", entry.id, graph, names);
    const audios = graph.audioForSource("book", entry.id)
      .filter((x) => x.data.status === "published")
      .map((au) => ({
        url: au.data.url as string,
        format: au.data.format as "opus" | "mp3" | undefined,
        duration: (au.data.duration as string | null) ?? null,
        sizeBytes: (au.data.size_bytes as number | null) ?? null,
        label: au.data.title as string,
      }));
    const commentaries = graph.commentariesOf(entry.id)
      .filter(isPub)
      .map(c => ({ href: hrefFor("book", c.id), title: c.data.title, author: c.data.person ? names.get(c.data.person as string) : "" }));
    // "اقرأ في موضعه" (#pN) deep-links land here first (hash never reaches the
    // server for a chunked book) — a firstPage per chapter lets client JS pick
    // the right chapter slice and redirect. Fall back to the first page marker
    // actually inside heading-split chapters (no firstPage from page-slicing).
    const firstPageOf = (c: (typeof a.chapters)[number]) =>
      c.firstPage ?? (c.content.match(/data-page="(\d+)"/)?.[1] ? Number(c.content.match(/data-page="(\d+)"/)![1]) : undefined);
    // multi-volume (مجلد) books carry data-juz on each page-sep (epub-import
    // --merge-volumes) — one entry per volume in source order, so the reader
    // jump control can offer a volume picker instead of a raw page number.
    // Untagged books still reset their printed page number at each volume
    // boundary, so deriveVolumes synthesizes one from that (see chunk.ts).
    const rawJuzOf = (c: (typeof a.chapters)[number]) => c.content.match(/data-juz="([^"]+)"/)?.[1];
    const { volumes, juzAt } = deriveVolumes(body, a.chapters.map((c) => ({ firstPage: firstPageOf(c) })));
    const firstJuzOf = (c: (typeof a.chapters)[number], i: number) => rawJuzOf(c) ?? juzAt(i);
    // Phase 2: chunked books → store a light TOC (titles+slugs) only; the body and
    // its annotations live on the on-demand chapter pages, never in this landing's HTML.
    paths.push({ params: { slug: entry.id }, props: { entry, chunked: a.chunked, toc: a.chapters.map((c, i) => ({ title: c.title, slug: c.slug, parent: c.parent, parentTitle: c.parentTitle, firstPage: firstPageOf(c), juz: firstJuzOf(c, i) })), volumes, tocNested: a.chunked ? [] : parseToc(body ?? ""), body: a.chunked ? undefined : renderBody, byAnchor: a.chunked ? {} : byAnchor, audios, commentaries, author: entry.data.person ? names.get(entry.data.person) : undefined, topicLabel: labelFor("book", entry.data), origin: originOf(entry.data, graph), related: relatedTo(entry, graph, names), backlinks: backlinksList(entry, graph, names) } });
  }
  return paths;
}

const { entry, chunked, toc, volumes, tocNested, body, byAnchor, audios, commentaries, author, topicLabel, origin, related, backlinks } = Astro.props;
const bookPageCount = Math.max(0, ...[...(body ?? "").matchAll(/data-page="(\d+)"/g)].map((m) => Number(m[1])));
const KIND_SLUG: Record<string, string> = { شرح: "sharh", حاشية: "hashiya", تخريج: "takhrij", إعراب: "iraab" };
// Oversized chapters get re-split into "صفحات S-E" slices (parent set) — group
// those back under the parent chapter for the TOC instead of listing each slice.
interface TocGroup { href: string; title: string; slices: { href: string; title: string }[] }
function groupToc(items: { title: string; slug: string; parent?: string; parentTitle?: string }[]): TocGroup[] {
  const groups: TocGroup[] = [];
  const byKey = new Map<string, TocGroup>();
  for (const c of items) {
    const key = c.parent ?? c.slug;
    const href = hrefFor("book", entry.id, { chapter: c.slug });
    let g = byKey.get(key);
    if (!g) {
      g = { href, title: c.parentTitle ?? c.title, slices: [] };
      byKey.set(key, g);
      groups.push(g);
    }
    if (c.parent) g.slices.push({ href, title: c.title });
  }
  return groups;
}
const anchors = Object.entries(byAnchor);
const path = `/book/${entry.id}`;
const isHadith = entry.data.genre === "حديث";
const jsonLd = bookLd({
  title: entry.data.title, authorId: entry.data.person, authorName: author,
  description: entry.data.description, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الكتب", path: "/books" }, { name: entry.data.title, path }],
});
---
<Base title={entry.data.title} description={entry.data.description} activeNav="books" ogType="book" jsonLd={jsonLd} searchScope={{ in: entry.id, label: entry.data.title }} readingPage>
  <Breadcrumbs
    width="wrap-matn"
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الكتب", href: "/books" },
      { label: entry.data.title },
    ]}
  />
  {/* Reading measure comes from the grid arithmetic (chap-outer 960px minus the
      232px sidebar minus the gap ≈ 680px), matching book/[slug]/[chapter].astro
      and the mockup's "Article column max 680px" — NOT from wrapping the whole
      grid in wrap-matn's own (narrower) fixed measure, which would carve the
      sidebar's width out of the reading column instead of giving it its own. */}
  <div class:list={["chap-outer", { "hadith-accent": isHadith }]}>
  {chunked ? (
    <div class="wrap-matn reading-pad" data-cite-book={entry.data.title} data-cite-author={author}>
      <div class="reader-head">
        <a class="eyebrow u87c136d pill-link" href={isMatn("book", entry.data) ? "/matn" : "/books"}>{topicLabel}</a>
        <div class="ornament" aria-hidden="true">۞</div>
        <h1 class="reader-title ue7e55f7" >{entry.data.title}</h1>
        <div class="reader-byline">{entry.data.person ? <a href={hrefFor("person", entry.data.person)}>{author}</a> : author}</div>
        <button type="button" class="toggle-btn" style="margin-top: 12px;" data-action="download:toggle" data-dl-kind="book" data-dl-id={entry.id} data-dl-title={entry.data.title} aria-pressed="false">
          <span class="toggle-dot"></span><span data-dl-label>تنزيل للقراءة دون اتصال</span>
        </button>
        {origin && (
          <div class="reader-origin">
            {origin.relation}: <a href={origin.href}>{origin.title}</a>
          </div>
        )}
        {entry.data.transcript_status && (
          <div style="margin-top: 0.5rem;">
            <span class={`pill ${entry.data.transcript_status === 'قيد المراجعة' ? 'tag-accent' : ''}`}>{entry.data.transcript_status}</span>
          </div>
        )}
      </div>
      {audios.length > 0 && <AudioPlayer sources={audios} title={entry.data.title} subtitle={author} />}
      <div class="rule-short"></div>
      {/* populated client-side from localStorage (marks.ts) if you've read a chapter before */}
      <div class="book-info-card book-resume-card" data-book-resume={entry.id} hidden>
        <div class="toc-label">تابع القراءة</div>
        <a class="book-resume-link" data-book-resume-link></a>
        <div class="bar"><span data-book-resume-bar></span></div>
      </div>
      {/* bookPageCount is computed from `body`, which chunked books don't carry
          (their pages live in the on-demand chapter routes) — gate on the toc's
          own firstPage markers instead */}
      {toc.some((c: any) => c.firstPage != null) && <BookPageJump bookHref={hrefFor("book", entry.id)} volumes={volumes} />}
      {/* light TOC: links to the on-demand chapter pages; no body in this HTML */}
      <nav class="toc-box has-current" aria-label="فهرس الفصول">
        <div class="toc-label">فصول الكتاب · {toArabicDigits(groupToc(toc).length)} فصل</div>
        {groupToc(toc).map((g) => (
          g.slices.length > 0 ? (
            <details class="toc-group">
              <summary class="toc-group-summary">
                <a href={g.href}>{g.title}</a>
                <span class="toc-group-arrow" aria-hidden="true">›</span>
              </summary>
              <div class="toc-sub">
                {g.slices.map((s) => <a href={s.href} class="toc-sub-link">{s.title}</a>)}
              </div>
            </details>
          ) : (
            <a href={g.href}>{g.title}</a>
          )
        ))}
      </nav>
      <div class="ornament ud38b410" >۞</div>
    </div>
  ) : (
    <div class="chap-grid">
      <div class="reading-pad" data-cite-book={entry.data.title} data-cite-author={author}>
        <div class="reader-head">
          <a class="eyebrow u87c136d pill-link" href={isMatn("book", entry.data) ? "/matn" : "/books"}>{topicLabel}</a>
          <div class:list={["ornament", { "ornament-green": isHadith }]} aria-hidden="true">۞</div>
          <h1 class="reader-title ue7e55f7" >{entry.data.title}</h1>
          <div class="reader-byline">{entry.data.person ? <a href={hrefFor("person", entry.data.person)}>{author}</a> : author}</div>
          <button type="button" class="toggle-btn" style="margin-top: 12px;" data-action="download:toggle" data-dl-kind="book" data-dl-id={entry.id} data-dl-title={entry.data.title} aria-pressed="false">
            <span class="toggle-dot"></span><span data-dl-label>تنزيل للقراءة دون اتصال</span>
          </button>
          {origin && (
            <div class="reader-origin">
              {origin.relation}: <a href={origin.href}>{origin.title}</a>
            </div>
          )}
          {entry.data.transcript_status && (
            <div style="margin-top: 0.5rem;">
              <span class={`pill ${entry.data.transcript_status === 'قيد المراجعة' ? 'tag-accent' : ''}`}>{entry.data.transcript_status}</span>
            </div>
          )}
        </div>
        {audios.length > 0 && <AudioPlayer sources={audios} title={entry.data.title} subtitle={author} />}
        <div class="rule-short"></div>
        <StudyBar downloadUrl={entry.data.attachments?.[0]?.url} />
        {isMatn("book", entry.data) ? (
          <div class="u49fcd85" data-matn={entry.id} data-unit="فقرة"><Prose body={body ?? ""} pageFootnotes /></div>
        ) : (
          <div class="u49fcd85"><Prose body={body ?? ""} pageFootnotes /></div>
        )}

        {/* All annotations now open in the sidebar/popup panel: phrase notes are
            wrapped inline; whole-paragraph notes attach to their فقرة. The packs
            stay in the DOM (hidden) so the search index/no-JS still see the text. */}
        {anchors.map(([anchor, notes]) => (
          <div class="ann-pack" id={`ann-${anchor}`} data-ann-pack data-phrase={notes.find((n) => n.phrase)?.phrase} hidden>
            {notes.map((nt) => (
              <div class={`ann-entry k-${KIND_SLUG[nt.kind] ?? "sharh"}`} data-kind={nt.kind} data-label={nt.annotator ? `${nt.kind} — ${nt.annotator}` : nt.kind}>
                <div class="ann-entry-body" data-ar><Fragment set:html={markdownToSafeHtml(nt.body)} /></div>
                {nt.sourceHref && <a class="ann-source-link" href={nt.sourceHref}>اقرأ في موضعه{nt.sourceLabel ? `: ${nt.sourceLabel}` : ""} ←</a>}
              </div>
            ))}
          </div>
        ))}

        <div class="ornament ud38b410" >۞</div>
      </div>
      {tocNested?.length > 0 && (
        <ReaderSidebar label={bookPageCount > 0 ? `فهرس العناوين · ${bookPageCount} صفحة` : "فهرس العناوين"}>
          {bookPageCount > 0 && <BookPageJump bookHref={hrefFor("book", entry.id)} volumes={volumes} />}
          <div class="toc-box has-current">
            <div class="toc-label">{bookPageCount > 0 ? `فهرس العناوين · ${bookPageCount} صفحة` : "فهرس العناوين"}</div>
            {tocNested.map((h) => (
              <a href={`#${h.slug}`} style={`padding-inline-start: ${(h.depth - 2) * 1}rem`}>{h.title}</a>
            ))}
          </div>
        </ReaderSidebar>
      )}
    </div>
  )}
  </div>
  {commentaries.length > 0 && (
    <div class="wrap-mid" style="margin-top: 2rem; border-top: 1px solid var(--border, #e0e0e0); padding-top: 1rem;">
      <h2 class="section-title">شروحه وتعليقاته</h2>
      <ul style="list-style: none; padding: 0;">
        {commentaries.map(c => (
          <li style="margin-bottom: 0.5rem;"><a href={c.href}>{c.title}</a> {c.author && <span class="faint">— {c.author}</span>}</li>
        ))}
      </ul>
    </div>
  )}
  <div class="wrap-mid"><RelatedStrip items={related} /></div>
  <Relations items={backlinks} />
  {chunked && (
    <script type="application/json" data-page-map set:html={JSON.stringify(toc.filter((c: any) => c.firstPage != null).map((c: any) => ({ slug: c.slug, firstPage: c.firstPage, juz: c.juz })))} />
    <script>
      // "اقرأ في موضعه" (#pN) lands here first — the hash never reaches the
      // server for a chunked book. Find the chapter whose page range covers N
      // and redirect there, same hash intact.
      //
      // ponytail: walk chapters in source order (NOT sorted by firstPage) and
      // keep the last one whose firstPage <= N — some multi-volume books
      // reset page numbering per volume/juz, so a global sort would scramble
      // volumes together. Source order at least keeps each volume's own
      // pages contiguous. If the URL names a volume (?v=, from BookPageJump),
      // prefer chapters matching it first — that's the disambiguator a bare
      // page number alone can't give.
      (() => {
        const m = location.hash.match(/^#p(\d+)$/);
        if (!m) return;
        const target = parseInt(m[1], 10);
        const wantVol = new URLSearchParams(location.search).get("v");
        const mapEl = document.querySelector('script[data-page-map]');
        if (!mapEl) return;
        const allPages: { slug: string; firstPage: number; juz?: string }[] = JSON.parse(mapEl.textContent || "[]");
        const pages = wantVol && allPages.some((c) => c.juz === wantVol) ? allPages.filter((c) => c.juz === wantVol) : allPages;
        let chapter = pages[0];
        for (const c of pages) { if (c.firstPage <= target) chapter = c; else break; }
        if (chapter) location.replace(`${location.pathname}/${encodeURIComponent(chapter.slug)}${location.search}${location.hash}`);
      })();
    </script>
  )}
</Base>
