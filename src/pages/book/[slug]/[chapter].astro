---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import Prose from "../../../components/Prose.astro";
import { isPub, personNameMap } from "../../../lib/site";
import { analyzeBook } from "../../../lib/chunk";
import { hrefFor } from "../../../lib/display";

export async function getStaticPaths() {
  const books = (await getCollection("book")).filter(isPub);
  const names = await personNameMap();
  const paths: any[] = [];
  for (const entry of books) {
    const a = analyzeBook(entry.body ?? "");
    if (!a.chunked) continue;
    for (const c of a.chapters) {
      paths.push({
        params: { slug: entry.id, chapter: c.slug },
        props: { entry, chapter: c, author: names.get(entry.data.person) },
      });
    }
  }
  return paths;
}

const { entry, chapter, author } = Astro.props;
---
<Base title={`${chapter.title} · ${entry.data.title}`} activeNav="books" searchMeta={{ title: `${entry.data.title} — ${chapter.title}`, type: "book" }}>
  <Breadcrumbs
    width="wrap-matn"
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "المكتبة", href: "/books" },
      { label: entry.data.title, href: hrefFor("book", entry.id) },
      { label: chapter.title },
    ]}
  />
  <div class="wrap-matn reading-pad">
    <div class="reader-head">
      <div class="eyebrow u87c136d" >متن · {author}</div>
      <h1 class="reader-title u97df06b" >{chapter.title}</h1>
      <div class="reader-byline">{entry.data.title}</div>
    </div>
    <div class="rule-short"></div>
    <div class="u49fcd85"><Prose body={chapter.content} /></div>
  </div>
</Base>
