---
// On-demand (migration plan, Phase 1): instead of pre-building ~44k chapter pages,
// the Worker reads the one book from ASSETS, extracts the one chapter, renders, and
// the middleware edge-caches the result. Book body never enters the static build.
export const prerender = false;

import { getEntry } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import StudyBar from "../../../components/StudyBar.astro";
import InlineNoteGroup from "../../../components/InlineNoteGroup.astro";
import ReaderSidebar from "../../../components/ReaderSidebar.astro";
import BookPageJump from "../../../components/BookPageJump.astro";
import TitleFilter from "../../../components/TitleFilter.astro";
import { isPub, loadGraph, personNameMap, notesByAnchor } from "../../../lib/site";
import { markdownToSafeHtml } from "../../../lib/sanitize";
import { parseToc } from "../../../lib/chapters";
import { wirePageFootnotes } from "../../../lib/page-footnotes";
import { loadChapterManifest, loadChapterBody, notFound } from "../../../lib/book-asset";
import { hrefFor, labelFor, isMatn, toArabicDigits } from "../../../lib/display";
import { parseHadithOrdinal } from "../../../lib/hadith";
import hadithIndexData from "../../../data/hadith-index.json";

type HadithNote = { kind: string; label: string; sourceSlug: string; sourceTitle: string; sourceHref: string; body: string; grade?: string };
const hadithIndex = hadithIndexData as Record<string, HadithNote[]>;
const HADITH_KIND_CLASS: Record<string, string> = { شرح: "sharh", تخريج: "takhrij", حكم: "takhrij" };

const { slug, chapter: chapterSlug } = Astro.params as { slug: string; chapter: string };

const entry = await getEntry("book", slug);
if (!entry || !isPub(entry)) return notFound();

const manifestData = await loadChapterManifest(slug);
if (!manifestData) return notFound();
const { chapters: manifest, catalog, volumes = [] } = manifestData;
const chapterMeta = manifest.find((c) => c.slug === chapterSlug);
if (!chapterMeta) return notFound();
const chapterContent = await loadChapterBody(slug, chapterSlug);
if (chapterContent == null) return notFound();
const chapter = { ...chapterMeta, content: chapterContent };

// ponytail: builds the whole knowledge graph per cold request just to read this
// book's annotations + author name. Fine at current scale and the result is
// edge-cached (paid once per chapter). If the per-request build gets slow nearer
// ~10k entities, scope it to getCollection("annotation") filtered to this target.
const graph = await loadGraph();
const names = await personNameMap();
const byAnchor = notesByAnchor("book", entry.id, graph, names);
const author = entry.data.person ? names.get(entry.data.person) : undefined;
const commentaries = graph.commentariesOf(entry.id)
  .filter(isPub)
  .map(c => ({ href: hrefFor("book", c.id), title: c.data.title, author: c.data.person ? names.get(c.data.person as string) : "" }));
// "المقدمة" is pulled out of the reading flow when it's a catalog block (see
// gen-book-chapters.ts) — shown as its own panel above the TOC instead, so it
// no longer competes with real content chapters for a slot in the list.
const allChapters = manifest
  .filter((c) => !(catalog.length > 0 && c.title.trim() === "المقدمة"))
  .map((c) => ({ title: c.title, slug: c.slug, parent: c.parent, parentTitle: c.parentTitle }));

// Oversized chapters are re-split into "صفحات S-E" slices (parent set) — group
// those back under the parent chapter for the TOC instead of listing each slice.
interface TocGroup { href: string; title: string; slug: string; slices: { href: string; title: string; slug: string }[] }
function groupToc(items: typeof allChapters): TocGroup[] {
  const groups: TocGroup[] = [];
  const byKey = new Map<string, TocGroup>();
  for (const c of items) {
    const key = c.parent ?? c.slug;
    const href = hrefFor("book", entry!.id, { chapter: c.slug });
    let g = byKey.get(key);
    if (!g) {
      g = { href, title: c.parentTitle ?? c.title, slug: key, slices: [] };
      byKey.set(key, g);
      groups.push(g);
    }
    if (c.parent) g.slices.push({ href, title: c.title, slug: c.slug });
  }
  return groups;
}
const tocGroups = groupToc(allChapters);
const currentGroupKey = chapterMeta.parent ?? chapterMeta.slug;

// Matn hubs (currently just the Arbaeen — see ADR-0013): each chapter here is
// already scoped to one "## الحديث <ordinal>" heading — surface this hadith's
// notes as inline <details> after the prose, ordered شرح → تخريج → حكم.
const hadithOrdinal = parseHadithOrdinal(chapter.title);
const hadithNotes = hadithOrdinal !== null ? hadithIndex[`${entry.id}:${hadithOrdinal}`] : undefined;
const HADITH_KIND_ORDER = ["شرح", "تخريج", "حكم"];
const isHadith = entry.data.genre === "حديث";

const KIND_SLUG: Record<string, string> = { شرح: "sharh", حاشية: "hashiya", تخريج: "takhrij", إعراب: "iraab" };
const phraseAnchors = Object.entries(byAnchor).filter(([, notes]: any) => notes.some((n: any) => n.phrase));

const bookPageCount = Math.max(0, ...manifest.map((c) => c.lastPage ?? 0));

const chIdx = allChapters.findIndex((c) => c.slug === chapter.slug);
const prev = allChapters[chIdx - 1] ?? null;
const next = allChapters[chIdx + 1] ?? null;

const nestedToc = parseToc(chapter.content);
// group h3s under their preceding h2 so the in-page TOC can collapse each
// section instead of listing every sub-heading flat
interface NestedTocGroup { slug: string; title: string; children: { slug: string; title: string }[] }
const nestedTocGroups: NestedTocGroup[] = [];
for (const h of nestedToc) {
  if (h.depth === 2 || nestedTocGroups.length === 0) {
    nestedTocGroups.push({ slug: h.slug, title: h.title, children: [] });
  } else {
    nestedTocGroups[nestedTocGroups.length - 1].children.push({ slug: h.slug, title: h.title });
  }
}

// 1. Map paragraph anchors to page numbers
const parts = chapter.content.split(/(<hr class="page-sep" data-page="\d+"[^\>]*\/>)/);
let currentPageNum = 1;
for (const part of parts) {
  const m = part.match(/data-page="(\d+)"/);
  if (m) {
    currentPageNum = parseInt(m[1], 10) - 1;
    break;
  }
}

let paraIndex = 0;
const anchorPageMap = new Map<string, number>();
let pageNum = currentPageNum;
for (const part of parts) {
  const m = part.match(/data-page="(\d+)"/);
  if (m) {
    pageNum = parseInt(m[1], 10);
    continue;
  }
  const blocks = part.split(/\n\s*\n/);
  for (const block of blocks) {
    const trimmed = block.trim();
    if (!trimmed) continue;
    if (/^#{1,6}\s/.test(trimmed)) continue;
    if (/^-{3,}$/.test(trimmed)) continue;
    paraIndex++;
    const match = trimmed.match(/\{#([a-zA-Z0-9_-]+)\}/);
    const id = match ? match[1] : `p${paraIndex}`;
    anchorPageMap.set(id, pageNum);
  }
}


// 2. Group DB hashiya annotations by page
const dbHashiyasByPage = new Map<number, string[]>();
for (const [anchor, notes] of Object.entries(byAnchor)) {
  const pNum = anchorPageMap.get(anchor);
  if (pNum !== undefined) {
    const hashiyas = (notes as any[]).filter(n => n.kind === "حاشية");
    if (hashiyas.length > 0) {
      if (!dbHashiyasByPage.has(pNum)) dbHashiyasByPage.set(pNum, []);
      dbHashiyasByPage.get(pNum)!.push(...hashiyas.map(h => h.body));
    }
  }
}

// 3. All footnote handling (GFM [^id] refs/defs, EPUB data-fn sups +
// data-notes arrays, the DB حاشية notes grouped above) lives in the shared
// wirePageFootnotes — same pass the single-page book route uses, so every
// book behaves identically: plain non-clickable markers, always-visible
// per-page footer boxes, page-seps normalized to "ص N" <div>s.
const finalContent = wirePageFootnotes(markdownToSafeHtml(chapter.content), chapter.content, dbHashiyasByPage);
---
<Base title={`${chapter.title} · ${entry.data.title}`} activeNav="books" searchScope={{ in: entry.id, label: entry.data.title }} readingPage>
  <Breadcrumbs
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الكتب", href: "/books" },
      { label: entry.data.title, href: hrefFor("book", entry.id) },
      { label: chapterMeta.parentTitle ?? chapter.title },
    ]}
  />

  <div class:list={["chap-outer", { "hadith-accent": isHadith }]}>
    <div class="chap-grid">
      <!-- main reading column -->
      <div class="reading-pad" data-cite-book={entry.data.title} data-cite-author={author}>
        <div class="reader-head">
          <div class="eyebrow u87c136d"><a class="faint" href={hrefFor("book", entry.id)}>{entry.data.title}</a></div>
          <div class:list={["ornament", { "ornament-green": isHadith }]} aria-hidden="true">۞</div>
          <h1
            class:list={["reader-title", "ue7e55f7"]}
            set:html={chapterMeta.parentTitle ?? (chapter.rawTitle || chapter.title)}
          ></h1>
          {chapterMeta.parentTitle && <div class="reader-subtitle">{chapter.title}</div>}
          <div class="reader-byline">{entry.data.person ? <a href={hrefFor("person", entry.data.person)}>{author}</a> : author}</div>

          {catalog.length > 0 && (
            <details class="book-catalog">
              <summary>عن هذه الطبعة</summary>
              <dl>
                {catalog.map((c) => (
                  <>
                    <dt>{c.label}</dt>
                    <dd>{c.value}</dd>
                  </>
                ))}
              </dl>
            </details>
          )}

          {entry.data.transcript_status && (
            <div style="margin-top: 0.5rem;">
              <span class={`pill ${entry.data.transcript_status === 'قيد المراجعة' ? 'tag-accent' : ''}`}>{entry.data.transcript_status}</span>
            </div>
          )}
        </div>

        <div class="rule-short"></div>

        {isMatn("book", entry.data) ? (
          <>
            <StudyBar downloadUrl={entry.data.attachments?.[0]?.url} />
            <div class="u49fcd85 prose" data-matn={`${entry.id}--${chapter.slug}`} data-unit="فقرة" data-ar set:html={finalContent}></div>
          </>
        ) : (
          <>
            <StudyBar downloadUrl={entry.data.attachments?.[0]?.url} />
            <div class="u49fcd85 prose" data-ar set:html={finalContent}></div>
          </>
        )}

        {phraseAnchors.map(([anchor, notes]: any) => (
          <div class="ann-pack" id={`ann-${anchor}`} data-ann-pack data-phrase={notes.find((n: any) => n.phrase)?.phrase} hidden>
            {notes.map((nt: any) => (
              <div class={`ann-entry k-${KIND_SLUG[nt.kind] ?? "sharh"}`} data-kind={nt.kind} data-label={nt.annotator ? `${nt.kind} — ${nt.annotator}` : nt.kind}>
                <div class="ann-entry-body" data-ar><Fragment set:html={markdownToSafeHtml(nt.body)} /></div>
                {nt.sourceHref && <a class="ann-source-link" href={nt.sourceHref}>اقرأ في موضعه{nt.sourceLabel ? `: ${nt.sourceLabel}` : ""} ←</a>}
              </div>
            ))}
          </div>
        ))}

        <InlineNoteGroup
          notes={hadithNotes?.map((nt) => ({ kind: nt.kind, body: nt.body, sourceLabel: nt.sourceTitle, sourceHref: nt.sourceHref })) ?? []}
          kindOrder={HADITH_KIND_ORDER}
          kindClass={HADITH_KIND_CLASS}
        />

        <!-- prev / next navigation — 2-col cards (mockup) -->
        <nav class="prevnext" aria-label="تنقل بين الفصول">
          {prev ? (
            <a href={hrefFor("book", entry.id, { chapter: prev.slug })}>
              <span class="pn-kicker">→ السابق</span>
              <span class="pn-title">{prev.title}</span>
            </a>
          ) : <span class="pn-end">أولُ فصول الكتاب</span>}
          {next ? (
            <a href={hrefFor("book", entry.id, { chapter: next.slug })}>
              <span class="pn-kicker">التالي ←</span>
              <span class="pn-title">{next.title}</span>
            </a>
          ) : <span class="pn-end">آخرُ فصول الكتاب</span>}
        </nav>
      </div>

      <!-- sidebar TOC (hidden on mobile via CSS) -->
      <ReaderSidebar label={bookPageCount > 0 ? `فصول الكتاب · ${tocGroups.length} فصل · ${bookPageCount} صفحة` : `فصول الكتاب · ${tocGroups.length} فصل`}>
        {bookPageCount > 0 && <BookPageJump bookHref={hrefFor("book", entry.id)} volumes={volumes} />}
        <div class="book-info-card">
          <div class="book-info-title">{entry.data.title}</div>
          {author && <div class="book-info-author">تأليف <strong>{author}</strong></div>}
          {entry.data.edition && <div class="book-info-edition">{entry.data.edition}</div>}
          <div
            class="book-info-progress"
            data-book-progress={entry.id}
            data-book-progress-title={chapter.title}
            data-book-progress-idx={chIdx + 1}
            data-book-progress-total={allChapters.length}
          >
            <div class="faint" style="font-size: 11.5px;">تقدّمك في الكتاب: {chapter.title} — {chIdx + 1} من {allChapters.length}</div>
            <div class="bar"><span style={`width: ${Math.round(((chIdx + 1) / allChapters.length) * 100)}%`}></span></div>
          </div>
        </div>
        {commentaries.length > 0 && (
          <details class="sharh-picker">
            <summary>
              <span>الشروح والتعليقات</span>
              <span class="faint masail-count">{toArabicDigits(commentaries.length)}</span>
            </summary>
            <div class="sharh-picker-body">
              <TitleFilter placeholder="ابحث في الشروح…" />
              <div class="sharh-list">
                {commentaries.map(c => (
                  <a href={c.href} data-title={c.title}>
                    <span>{c.title}</span>
                    {c.author && <span class="faint">{c.author}</span>}
                  </a>
                ))}
              </div>
            </div>
          </details>
        )}
        {catalog.length > 0 && (
          <details class="book-catalog">
            <summary>عن هذه الطبعة</summary>
            <dl>
              {catalog.map((c) => (
                <>
                  <dt>{c.label}</dt>
                  <dd>{c.value}</dd>
                </>
              ))}
            </dl>
          </details>
        )}
        <div class="toc-box has-current">
          <div class="toc-label">فصول {entry.data.title}{bookPageCount > 0 ? ` · ${bookPageCount} صفحة` : ""}</div>
          {tocGroups.map((g) => (
            <>
              {g.slices.length > 0 ? (
                <details class="toc-group" open={g.slug === currentGroupKey}>
                  <summary class="toc-group-summary">
                    <a href={g.href} class:list={[{ 'toc-current': g.slug === currentGroupKey }]}>{g.title}</a>
                    <span class="toc-group-arrow" aria-hidden="true">›</span>
                  </summary>
                  <div class="toc-sub">
                    {g.slices.map((s) => (
                      <a href={s.href} class:list={["toc-sub-link", { 'toc-current': s.slug === chapter.slug }]}>{s.title}</a>
                    ))}
                  </div>
                </details>
              ) : (
                <a href={g.href} class:list={[{ 'toc-current': g.slug === currentGroupKey }]}>{g.title}</a>
              )}
              {g.slug === currentGroupKey && nestedTocGroups.length > 0 && (
                <div class="toc-nested" style="margin-bottom: 0.5rem; font-size: 0.85em;">
                  {nestedTocGroups.map((h2) => (
                    h2.children.length > 0 ? (
                      <details class="toc-nested-group" open>
                        <summary>
                          <a href={`#${h2.slug}`} class="toc-nested-link toc-nested-h2">{h2.title}</a>
                          <span class="toc-nested-arrow" aria-hidden="true">›</span>
                        </summary>
                        {h2.children.map((h3) => (
                          <a href={`#${h3.slug}`} class="toc-nested-link toc-nested-h3">{h3.title}</a>
                        ))}
                      </details>
                    ) : (
                      <a href={`#${h2.slug}`} class="toc-nested-link toc-nested-h2">{h2.title}</a>
                    )
                  ))}
                </div>
              )}
            </>
          ))}
        </div>
      </ReaderSidebar>
    </div>
  </div>
</Base>
