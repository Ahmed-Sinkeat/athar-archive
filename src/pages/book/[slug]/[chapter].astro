---
// On-demand (migration plan, Phase 1): instead of pre-building ~44k chapter pages,
// the Worker reads the one book from ASSETS, extracts the one chapter, renders, and
// the middleware edge-caches the result. Book body never enters the static build.
export const prerender = false;

import { getEntry } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import StudyBar from "../../../components/StudyBar.astro";
import { isPub, loadGraph, personNameMap, notesByAnchor } from "../../../lib/site";
import { markdownToSafeHtml } from "../../../lib/sanitize";
import { analyzeBook } from "../../../lib/chunk";
import { parseToc } from "../../../lib/chapters";
import { loadContentBody, notFound } from "../../../lib/book-asset";
import { hrefFor, labelFor, isMatn } from "../../../lib/display";

const { slug, chapter: chapterSlug } = Astro.params as { slug: string; chapter: string };

const entry = await getEntry("book", slug);
if (!entry || !isPub(entry)) return notFound();

const body = await loadContentBody("book", slug);
if (!body) return notFound();

const a = analyzeBook(body);
const chapter = a.chunked ? a.chapters.find((c) => c.slug === chapterSlug) : undefined;
if (!chapter) return notFound();

// ponytail: builds the whole knowledge graph per cold request just to read this
// book's annotations + author name. Fine at current scale and the result is
// edge-cached (paid once per chapter). If the per-request build gets slow nearer
// ~10k entities, scope it to getCollection("annotation") filtered to this target.
const graph = await loadGraph();
const names = await personNameMap();
const byAnchor = notesByAnchor("book", entry.id, graph, names);
const author = names.get(entry.data.person);
const allChapters = a.chapters.map((c) => ({ title: c.title, slug: c.slug }));

const KIND_SLUG: Record<string, string> = { شرح: "sharh", حاشية: "hashiya", تخريج: "takhrij", إعراب: "iraab" };
const phraseAnchors = Object.entries(byAnchor).filter(([, notes]: any) => notes.some((n: any) => n.phrase));

const chIdx = allChapters.findIndex((c) => c.slug === chapter.slug);
const prev = allChapters[chIdx - 1] ?? null;
const next = allChapters[chIdx + 1] ?? null;

const nestedToc = parseToc(chapter.content);

// 1. Map paragraph anchors to page numbers
const parts = chapter.content.split(/(<hr class="page-sep" data-page="\d+"[^\>]*\/>)/);
let currentPageNum = 1;
for (const part of parts) {
  const m = part.match(/data-page="(\d+)"/);
  if (m) {
    currentPageNum = parseInt(m[1], 10) - 1;
    break;
  }
}

let paraIndex = 0;
const anchorPageMap = new Map<string, number>();
let pageNum = currentPageNum;
for (const part of parts) {
  const m = part.match(/data-page="(\d+)"/);
  if (m) {
    pageNum = parseInt(m[1], 10);
    continue;
  }
  const blocks = part.split(/\n\s*\n/);
  for (const block of blocks) {
    const trimmed = block.trim();
    if (!trimmed) continue;
    if (/^#{1,6}\s/.test(trimmed)) continue;
    if (/^-{3,}$/.test(trimmed)) continue;
    paraIndex++;
    const match = trimmed.match(/\{#([a-zA-Z0-9_-]+)\}/);
    const id = match ? match[1] : `p${paraIndex}`;
    anchorPageMap.set(id, pageNum);
  }
}

// 2. Group DB hashiya annotations by page
const dbHashiyasByPage = new Map<number, string[]>();
for (const [anchor, notes] of Object.entries(byAnchor)) {
  const pNum = anchorPageMap.get(anchor);
  if (pNum !== undefined) {
    const hashiyas = (notes as any[]).filter(n => n.kind === "حاشية");
    if (hashiyas.length > 0) {
      if (!dbHashiyasByPage.has(pNum)) dbHashiyasByPage.set(pNum, []);
      dbHashiyasByPage.get(pNum)!.push(...hashiyas.map(h => h.body));
    }
  }
}

// 3. Compile markdown to HTML first so that raw HTML tags inside are not broken by remark-parse.
const html = markdownToSafeHtml(chapter.content);

// 4. Inject DB hashiyas into page separators in the HTML content
const processedHtml = html.replace(/<hr\s+([^>]*class="page-sep"[^>]*)>/g, (match, attrs) => {
  const pageMatch = attrs.match(/data-page="(\d+)"/) || attrs.match(/data-page='(\d+)'/);
  if (!pageMatch) return match;
  const pNum = parseInt(pageMatch[1], 10);
  
  let notes: string[] = [];
  const notesMatch = attrs.match(/data-notes="([^"]+)"/) || attrs.match(/data-notes='([^']+)'/);
  if (notesMatch) {
    try {
      notes = JSON.parse(notesMatch[1].replace(/&#39;/g, "'").replace(/&quot;/g, '"'));
    } catch (e) {
      // ignore
    }
  }
  const dbNotes = dbHashiyasByPage.get(pNum) ?? [];
  const allNotes = [...notes, ...dbNotes];
  
  const cleanAttrs = attrs
    .replace(/data-notes="[^"]+"/g, "")
    .replace(/data-notes='[^']+'/g, "")
    .replace(/\s+/g, " ")
    .trim();
    
  if (allNotes.length > 0) {
    const na = `data-notes='${JSON.stringify(allNotes).replace(/'/g, "&#39;")}'`;
    return `<hr ${cleanAttrs} ${na} />`;
  }
  return `<hr ${cleanAttrs} />`;
});

// 5. Embed note text directly on inline <sup data-fn> refs so client needs no DOM search.
//    Parses the notes we just injected into page-seps, then stamps data-note on each sup.
const finalContent = (() => {
  const pnMap = new Map<number, string>();
  processedHtml.replace(
    /<hr\s+([^>]*class="page-sep"[^>]*)>/g,
    (_, attrs: string) => {
      const pageMatch = attrs.match(/data-page="(\d+)"/) || attrs.match(/data-page='(\d+)'/);
      const notesMatch = attrs.match(/data-notes="([^"]*)"/) || attrs.match(/data-notes='([^']*)'/);
      if (pageMatch && notesMatch) {
        const pStr = pageMatch[1];
        try {
          const ns = JSON.parse(notesMatch[1].replace(/&#39;/g, "'").replace(/&quot;/g, '"')) as string[];
          if (ns.length) pnMap.set(parseInt(pStr, 10), ns.join("\n\n"));
        } catch {}
      }
      return _;
    }
  );
  if (!pnMap.size) return processedHtml;
  return processedHtml.replace(/<sup\s+([^>]+)>(\d+)<\/sup>/g, (match, attrs, fnContent) => {
    const fnMatch = attrs.match(/data-fn="(\d+)"/) || attrs.match(/data-fn='(\d+)'/);
    const sepMatch = attrs.match(/data-sep-page="(\d+)"/) || attrs.match(/data-sep-page='(\d+)'/);
    if (!fnMatch || !sepMatch) return match;
    const fn = fnMatch[1];
    const sepPage = sepMatch[1];
    const note = pnMap.get(parseInt(sepPage, 10));
    if (!note) return match;
    const attr = note.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/'/g, "&#39;").replace(/\r/g, "").replace(/\n/g, "&#10;");
    return `<sup data-fn="${fn}" data-sep-page="${sepPage}" data-note="${attr}">${fnContent}</sup>`;
  });
})();
---
<Base title={`${chapter.title} · ${entry.data.title}`} activeNav="books" searchScope={{ in: entry.id, label: entry.data.title }}>
  <Breadcrumbs
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "الكتب", href: "/books" },
      { label: entry.data.title, href: hrefFor("book", entry.id) },
      { label: chapter.title },
    ]}
  />

  <div class="chap-outer">
    <div class="chap-grid">
      <!-- main reading column -->
      <div class="reading-pad">
        <!-- mobile TOC (hidden on desktop via CSS) -->
        <details class="chap-mobile-toc">
          <summary>فصول الكتاب · {(allChapters as any[]).length} فصل</summary>
          <ul class="chap-mobile-list">
            {(allChapters as any[]).map((c: any) => (
              <li><a href={hrefFor("book", entry.id, { chapter: c.slug })} class:list={[{ 'is-current': c.slug === chapter.slug }]}>{c.title}</a></li>
            ))}
          </ul>
        </details>

        <div class="reader-head">
          <div class="eyebrow u87c136d"><a class="faint" href={hrefFor("book", entry.id)}>{entry.data.title}</a></div>
          <h1 class="reader-title ue7e55f7" >{chapter.title}</h1>
          <div class="reader-byline">{author}</div>
          {entry.data.transcript_status && (
            <div style="margin-top: 0.5rem;">
              <span class={`pill ${entry.data.transcript_status === 'قيد المراجعة' ? 'tag-accent' : ''}`}>{entry.data.transcript_status}</span>
            </div>
          )}
        </div>
        
        {entry.data.transcript_status && (
          <div class="wrap-mid" style="margin-top: 1rem; text-align: center;">
            <button type="button" class="btn" data-action="transcript:send-review" data-book={entry.data.title}>أرسل ملاحظات المراجعة عبر البريد</button>
          </div>
        )}

        <div class="rule-short"></div>

        {isMatn("book", entry.data) ? (
          <>
            <StudyBar prose downloadUrl={entry.data.attachments?.[0]?.url} />
            <div class="u49fcd85 prose" data-matn={`${entry.id}--${chapter.slug}`} data-unit="فقرة" data-ar set:html={finalContent}></div>
          </>
        ) : (
          <>
            <StudyBar prose downloadUrl={entry.data.attachments?.[0]?.url} />
            <div class="u49fcd85 prose" data-ar set:html={finalContent}></div>
          </>
        )}

        {phraseAnchors.map(([anchor, notes]: any) => (
          <div class="ann-pack" id={`ann-${anchor}`} data-ann-pack data-phrase={notes.find((n: any) => n.phrase)?.phrase} hidden>
            {notes.map((nt: any) => (
              <div class={`ann-entry k-${KIND_SLUG[nt.kind] ?? "sharh"}`} data-kind={nt.kind} data-label={nt.annotator ? `${nt.kind} — ${nt.annotator}` : nt.kind}>
                <div class="ann-entry-body" data-ar><Fragment set:html={markdownToSafeHtml(nt.body)} /></div>
                {nt.sourceHref && <a class="ann-source-link" href={nt.sourceHref}>اقرأ في موضعه{nt.sourceLabel ? `: ${nt.sourceLabel}` : ""} ←</a>}
              </div>
            ))}
          </div>
        ))}

        <!-- prev / next navigation -->
        <div class="prevnext">
          {prev
            ? <a href={hrefFor("book", entry.id, { chapter: prev.slug })}>→ {prev.title}</a>
            : <span></span>}
          {next && <a class="next" href={hrefFor("book", entry.id, { chapter: next.slug })}>{next.title} ←</a>}
        </div>
      </div>

      <!-- sidebar TOC (hidden on mobile via CSS) -->
      <aside class="toc-side chap-toc-aside">
        <div class="toc-box has-current">
          <div class="toc-label">فصول {entry.data.title}</div>
          {(allChapters as any[]).map((c: any) => (
            <>
              <a href={hrefFor("book", entry.id, { chapter: c.slug })} class:list={[{ 'toc-current': c.slug === chapter.slug }]}>{c.title}</a>
              {c.slug === chapter.slug && nestedToc.length > 0 && (
                <div class="toc-nested" style="margin-bottom: 0.5rem; font-size: 0.85em;">
                  {nestedToc.map((h) => (
                    <a href={`#${h.slug}`} style={`padding-inline-start: ${(h.depth - 1) * 0.75}rem; padding-top: 0.25rem; padding-bottom: 0.25rem; display: block;`}>{h.title}</a>
                  ))}
                </div>
              )}
            </>
          ))}
        </div>
      </aside>
    </div>
  </div>
</Base>
