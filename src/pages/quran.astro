---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { collectionLd } from "../lib/structured-data";
---
<Base title="القرآن وعلومه" description="التفاسيرُ وعلومُ القرآنِ والقراءات." activeNav="quran" jsonLd={collectionLd({ title: "القرآن وعلومه", path: "/quran", crumbs: [{ name: "الرئيسية", path: "/" }, { name: "القرآن", path: "/quran" }] })}>
  <Breadcrumbs items={[{ label: "الرئيسية", href: "/" }, { label: "القرآن وعلومه" }]} />
  <div class="wrap-mid">
    <h1 class="page-title">القرآن وعلومه</h1>

    <div class="card-grid quran-cards">
      <a class="card" href="/quran/mushaf">
        <div class="card-title">المصحف الشريف</div>
        <p class="card-sub">قراءة وتصفح سور القرآن الكريم بالرسم العثماني، مع ربط الآيات بالمتون والمنظومات والآثار المسندة.</p>
        <span class="card-cta">افتح المصحف ←</span>
      </a>

      <a class="card" href="/tafsir">
        <div class="card-title">كتب علوم القرآن</div>
        <p class="card-sub">تتضمن هذه المجموعة التفاسير، وأحكام القرآن، وعلوم القراءات، وغيرها من المصنفات المتعلقة بكتاب الله.</p>
        <span class="card-cta">تصفح الكتب ←</span>
      </a>
    </div>
  </div>
</Base>

<style>
  /* only 2 cards on this page — cap the shared auto-fill grid to 2 columns
     instead of letting it stretch to 4 across wrap-mid's width */
  .quran-cards { grid-template-columns: repeat(2, 1fr); max-width: 760px; margin-top: 2.5rem; }
  @media (max-width: 640px) { .quran-cards { grid-template-columns: 1fr; } }
</style>

