---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import Verse from "../../../components/Verse.astro";
import StudyBar from "../../../components/StudyBar.astro";
import ReaderSidebar from "../../../components/ReaderSidebar.astro";
import { isPub, loadGraph, personNameMap, notesByAnchor } from "../../../lib/site";
import { analyzePoem } from "../../../lib/chunk";
import { readBody } from "../../../lib/read-body";
import { hrefFor, toArabicDigits } from "../../../lib/display";
import { markdownToSafeHtml } from "../../../lib/sanitize";

export async function getStaticPaths() {
  const poems = (await getCollection("poem")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  const paths: any[] = [];
  for (const entry of poems) {
    const body = await readBody(entry);
    const a = analyzePoem(body);
    if (!a.chunked) continue;
    const byAnchor = notesByAnchor("poem", entry.id, graph, names);
    const tocChapters = a.chapters.map((c) => ({ title: c.title, slug: c.slug, verses: c.verses.length }));
    for (const c of a.chapters) {
      paths.push({
        params: { slug: entry.id, chapter: c.slug },
        props: { entry, chapter: c, byAnchor, author: names.get(entry.data.person), allChapters: tocChapters },
      });
    }
  }
  return paths;
}

const { entry, chapter, byAnchor, author, allChapters } = Astro.props;
const chIdx = (allChapters as any[]).findIndex((c: any) => c.slug === chapter.slug);
const prev = (allChapters as any[])[chIdx - 1] ?? null;
const next = (allChapters as any[])[chIdx + 1] ?? null;
---
<Base title={`${chapter.title} · ${entry.data.title}`} activeNav="poems" searchScope={{ in: entry.id, label: entry.data.title }} readingPage>
  <Breadcrumbs
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "المنظومات", href: "/poems" },
      { label: entry.data.title, href: hrefFor("poem", entry.id) },
      { label: chapter.title },
    ]}
  />

  <div class="chap-outer">
    <div class="chap-grid">
      <!-- main reading column -->
      <div class="reading-pad" data-cite-book={entry.data.title} data-cite-author={author} data-cite-kind="poem">
        <div class="reader-head">
          <div class="eyebrow u87c136d">منظومة · {author}</div>
          <h1 class="reader-title ubd7542b">{chapter.title}</h1>
          <div class="reader-byline">{entry.data.title}{chapter.verses.length > 0 && ` · ${toArabicDigits(chapter.verses.length)} بيت`}</div>
        </div>
        <div class="rule-short"></div>
        <StudyBar />
        {chapter.prose && <div class="u49fcd85 poem-chapter-prose" set:html={markdownToSafeHtml(chapter.prose)} />}
        {chapter.verses.length > 0 && (
          <div class="verses" data-matn={entry.id} data-unit="بيت">
            {(chapter.verses as any[]).map((v: any) => (
              <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />
            ))}
          </div>
        )}

        <!-- prev / next navigation — 2-col cards (mockup) -->
        <nav class="prevnext" aria-label="تنقل بين الأجزاء">
          {next ? (
            <a href={hrefFor("poem", entry.id, { chapter: next.slug })}>
              <span class="pn-kicker">التالي ←</span>
              <span class="pn-title">{next.title}</span>
            </a>
          ) : <span class="pn-end">آخرُ الأجزاء</span>}
          {prev ? (
            <a href={hrefFor("poem", entry.id, { chapter: prev.slug })}>
              <span class="pn-kicker">→ السابق</span>
              <span class="pn-title">{prev.title}</span>
            </a>
          ) : <span class="pn-end">أولُ الأجزاء</span>}
        </nav>
      </div>

      <ReaderSidebar label={`أبواب المنظومة · ${(allChapters as any[]).length} باب`}>
        <div class="toc-box has-current">
          <div class="toc-label">أبواب {entry.data.title}</div>
          {(allChapters as any[]).map((c: any) => (
            <a href={hrefFor("poem", entry.id, { chapter: c.slug })} class:list={[{ 'toc-current': c.slug === chapter.slug }]}>{c.title}</a>
          ))}
        </div>
      </ReaderSidebar>
    </div>
  </div>
</Base>
