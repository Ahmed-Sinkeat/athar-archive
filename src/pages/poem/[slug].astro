---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Verse from "../../components/Verse.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import Attachments from "../../components/Attachments.astro";
import { isPub, loadGraph, personNameMap } from "../../lib/site";
import { analyzePoem } from "../../lib/chunk";
import { hrefFor, toArabicDigits } from "../../lib/display";
import { poemLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const poems = (await getCollection("poem")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  return poems.map((entry) => {
    const byAnchor: Record<string, { kind: string; body: string }[]> = {};
    for (const a of graph.annotationsForTarget("poem", entry.id)) {
      if (a.data.status !== "published") continue;
      (byAnchor[a.data.anchor] ??= []).push({ kind: a.data.kind, body: a.body ?? "" });
    }
    const au = graph.audioForSource("poem", entry.id).find((x) => x.data.status === "published");
    const audio = au ? { url: au.data.url, format: au.data.format, duration: au.data.duration ?? null, sizeBytes: au.data.size_bytes ?? null } : null;
    return { params: { slug: entry.id }, props: { entry, byAnchor, audio, author: names.get(entry.data.person) } };
  });
}

const { entry, byAnchor, audio, author } = Astro.props;
const a = analyzePoem(entry.body ?? "");
const path = `/poem/${entry.id}`;
const jsonLd = poemLd({
  title: entry.data.title, authorId: entry.data.person, authorName: author,
  description: entry.data.description, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "المكتبة", path: "/books" }, { name: entry.data.title, path }],
});
const chapterNums = new Set(a.chapters.flatMap((c) => c.verses.map((v) => v.n)));
const preamble = a.verses.filter((v) => !chapterNums.has(v.n));
---
<Base title={entry.data.title} description={entry.data.description} activeNav="books" ogType="article" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "poem" }}>
  <Breadcrumbs
    width="wrap-read"
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "المكتبة", href: "/books" },
      { label: entry.data.title },
    ]}
  />
  <div class="wrap-read reading-pad">
    <div class="reader-head">
      <div class="eyebrow u87c136d" >منظومة</div>
      <h1 class="reader-title">{entry.data.title}</h1>
      <div class="reader-byline">نظمُ {author}</div>
      <div class="meta-pills">
        <span class="pill">{toArabicDigits(a.verseCount)} بيت</span>
        {a.chunked && <span class="pill">{toArabicDigits(a.chapters.length)} باب</span>}
      </div>
    </div>

    {Object.keys(byAnchor).length > 0 && (
      <div class="hint">
        <span class="ico">۞</span>
        <span class="u97445a8">الأبياتُ المُعلَّمةُ بخطٍّ منقَّطٍ تحتها شرحٌ وتخريج — <b>انقر عليها</b> لإظهاره.</span>
      </div>
    )}

    {audio && <div class="u49fcd85"><AudioPlayer url={audio.url} format={audio.format} duration={audio.duration} sizeBytes={audio.sizeBytes} label="استماعٌ إلى المنظومة" /></div>}

    <div class="rule-short"></div>

    {a.chunked ? (
      <div class="card-grid u654c43f" >
        {a.chapters.map((c) => (
          <a class="card u6f3d7fe" href={hrefFor("poem", entry.id, { chapter: c.slug })} >
            <div class="card-title ub9199e2" >{c.title}</div>
            <div class="faint uade9c31" >{toArabicDigits(c.verses.length)} بيت</div>
          </a>
        ))}
      </div>
    ) : (
      <div class="verses">
        {preamble.map((v) => <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />)}
        {a.chapters.map((c) => (
          <>
            <div class="chapter-band"><span>{c.title}</span></div>
            {c.verses.map((v) => <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />)}
          </>
        ))}
      </div>
    )}

    <Attachments items={entry.data.attachments} />

    <div class="ornament ud38b410" >۞</div>
  </div>
</Base>
