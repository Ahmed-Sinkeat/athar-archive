---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Verse from "../../components/Verse.astro";
import StudyBar from "../../components/StudyBar.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import RelatedStrip from "../../components/RelatedStrip.astro";
import { isPub, loadGraph, personNameMap, personEraMap, notesByAnchor, subjectTitlesFor, relatedTo } from "../../lib/site";
import { analyzePoem } from "../../lib/chunk";
import { hrefFor, toArabicDigits, eraLabel, eraHref } from "../../lib/display";
import { poemLd } from "../../lib/structured-data";

export async function getStaticPaths() {
  const poems = (await getCollection("poem")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  const eras = await personEraMap();
  return poems.map((entry) => {
    const byAnchor = notesByAnchor("poem", entry.id, graph, names);
    const audios = graph.audioForSource("poem", entry.id)
      .filter((x) => x.data.status === "published")
      .map((au) => ({ url: au.data.url, format: au.data.format, duration: au.data.duration ?? null, sizeBytes: au.data.size_bytes ?? null, label: au.data.title }));
    return { params: { slug: entry.id }, props: { entry, byAnchor, audios, author: names.get(entry.data.person), era: eras.get(entry.data.person), subjects: subjectTitlesFor(entry.data.topics, graph), related: relatedTo(entry, graph, names) } };
  });
}

const { entry, byAnchor, audios, author, era, subjects, related } = Astro.props;
const a = analyzePoem(entry.body ?? "");
const path = `/poem/${entry.id}`;
const jsonLd = poemLd({
  title: entry.data.title, authorId: entry.data.person, authorName: author,
  description: entry.data.description, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الشعر", path: "/poems" }, { name: entry.data.title, path }],
});
const chapterNums = new Set(a.chapters.flatMap((c) => c.verses.map((v) => v.n)));
const preamble = a.verses.filter((v) => !chapterNums.has(v.n));
---
<Base title={entry.data.title} description={entry.data.description} activeNav="poems" ogType="article" jsonLd={jsonLd} searchMeta={{ title: entry.data.title, type: "poem", id: entry.id, person: author, era, matn: true, subjects }} searchScope={{ in: entry.id, label: entry.data.title }}>
  <Breadcrumbs
    width="wrap-read"
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "المنظومات", href: "/poems" },
      { label: entry.data.title },
    ]}
  />
  <div class="wrap-read reading-pad">
    <div class="reader-head">
      <a class="eyebrow u87c136d pill-link" href="/poems">منظومة</a>
      <h1 class="reader-title">{entry.data.title}</h1>
      <div class="reader-byline">نظمُ {author}</div>
      <div class="meta-pills">
        <a class="badge-matn pill-link" href="/matn">متن</a>
        {era && <a class="pill tag-verdigris pill-link" href={eraHref(era)}>{eraLabel(era)}</a>}
        <span class="pill">{toArabicDigits(a.verseCount)} بيت</span>
        {a.chunked && <span class="pill">{toArabicDigits(a.chapters.length)} باب</span>}
      </div>
    </div>

    {Object.keys(byAnchor).length > 0 && (
      <div class="hint">
        <span class="ico">۞</span>
        <span class="u97445a8">الكلماتُ المُعلَّمةُ لها شرحٌ وتخريج — <b>انقرْ عليها</b> (أو اضغطْ مطوّلاً في الجوّال) لاختيار الشرح.</span>
      </div>
    )}

    {audios.length > 0 && <div class="u49fcd85"><AudioPlayer sources={audios} label="استماعٌ إلى المنظومة" /></div>}

    <div class="rule-short"></div>

    {a.chunked ? (
      <div class="card-grid u654c43f" >
        {a.chapters.map((c) => (
          <a class="card u6f3d7fe" href={hrefFor("poem", entry.id, { chapter: c.slug })} >
            <div class="card-title ub9199e2" >{c.title}</div>
            <div class="faint uade9c31" >{toArabicDigits(c.verses.length)} بيت</div>
          </a>
        ))}
      </div>
    ) : (
      <>
        <StudyBar />
        <div class="verses" data-matn={entry.id} data-unit="بيت">
          {preamble.map((v) => <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />)}
          {a.chapters.map((c) => (
            <>
              <div class="chapter-band"><span>{c.title}</span></div>
              {c.verses.map((v) => <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />)}
            </>
          ))}
        </div>
      </>
    )}

    <div class="ornament ud38b410" >۞</div>
  </div>
  <div class="wrap-mid"><RelatedStrip items={related} /></div>
</Base>
