---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Verse from "../../components/Verse.astro";
import StudyBar from "../../components/StudyBar.astro";
import ReaderSidebar from "../../components/ReaderSidebar.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import InlineSearch from "../../components/InlineSearch.astro";
import RelatedStrip from "../../components/RelatedStrip.astro";
import Relations from "../../components/Relations.astro";
import { isPub, loadGraph, personNameMap, personEraMap, notesByAnchor, relatedTo, backlinksList } from "../../lib/site";
import { analyzePoem } from "../../lib/chunk";
import { readBody } from "../../lib/read-body";
import { hrefFor, toArabicDigits, eraLabel, eraHref } from "../../lib/display";
import { MATLA_TITLE } from "../../lib/chapters";
import { poemLd } from "../../lib/structured-data";
import { markdownToSafeHtml } from "../../lib/sanitize";

export async function getStaticPaths() {
  const poems = (await getCollection("poem")).filter(isPub);
  const graph = await loadGraph();
  const names = await personNameMap();
  const eras = await personEraMap();
  const paths = [];
  for (const entry of poems) {
    const body = await readBody(entry);
    const a = analyzePoem(body);
    const byAnchor = notesByAnchor("poem", entry.id, graph, names);
    const audios = graph.audioForSource("poem", entry.id)
      .filter((x) => x.data.status === "published")
      .map((au) => ({
        url: au.data.url as string,
        format: au.data.format as "opus" | "mp3" | undefined,
        duration: (au.data.duration as string | null) ?? null,
        sizeBytes: (au.data.size_bytes as number | null) ?? null,
        label: au.data.title as string,
      }));
    const commentaries = graph.commentariesOf(entry.id)
      .filter(isPub)
      .map(c => ({ href: hrefFor("book", c.id), title: c.data.title, author: c.data.person ? names.get(c.data.person as string) : "" }));
    paths.push({ params: { slug: entry.id }, props: { entry, a, byAnchor, audios, commentaries, author: names.get(entry.data.person), era: eras.get(entry.data.person), related: relatedTo(entry, graph, names), backlinks: backlinksList(entry, graph, names) } });
  }
  return paths;
}

const { entry, a, byAnchor, audios, commentaries, author, era, related, backlinks } = Astro.props;
const path = `/poem/${entry.id}`;
// fallback only when a poem has no real description at all — never overrides one
const pageDescription = (entry.data.description as string | undefined) ||
  `${entry.data.title}${author ? ` — ${author}` : ""}، النص الكامل على أهل الأثر.`;
const jsonLd = poemLd({
  title: entry.data.title, authorId: entry.data.person, authorName: author,
  description: pageDescription, path,
  crumbs: [{ name: "الرئيسية", path: "/" }, { name: "الشعر", path: "/poems" }, { name: entry.data.title, path }],
});
const chapterNums = new Set(a.chapters.flatMap((c) => c.verses.map((v) => v.n)));
const preamble = a.verses.filter((v) => !chapterNums.has(v.n));
// single-page poems with inline باب headings (e.g. العقيدة السفارينية) get the
// same sidebar TOC book/[slug].astro's non-chunked branch has — chunked poems
// don't need it, their chapter picker IS the TOC (card grid above)
const hasToc = !a.chunked && a.chapters.some((c) => c.title);

// per-bayt audio timestamps (سمة "تتبّع الصوت") — only exists for poems an
// editor has manually timed; absent for the rest, feature just no-ops there
const timingFiles = import.meta.glob<{ default: { v: number; t: number }[] }>(
  "../../content/poem-timing/*.json", { eager: true },
);
const timing = timingFiles[`../../content/poem-timing/${entry.id}.json`]?.default;
---
<Base title={entry.data.title} description={pageDescription} activeNav="poems" ogType="article" jsonLd={jsonLd} searchScope={{ in: entry.id, label: entry.data.title }} readingPage>
  <Breadcrumbs
    width="wrap-read"
    items={[
      { label: "الرئيسية", href: "/" },
      { label: "المنظومات", href: "/poems" },
      { label: entry.data.title },
    ]}
  />
  <div class:list={["wrap-read", { "reading-pad": !hasToc }]} data-cite-book={entry.data.title} data-cite-author={author} data-cite-kind="poem">
    <div class="reader-head">
      <a class="eyebrow u87c136d pill-link" href="/poems">منظومة</a>
      <h1 class="reader-title">{entry.data.title}</h1>
      <div class="reader-byline">{entry.data.person ? <a href={hrefFor("person", entry.data.person)}>{author}</a> : author}</div>
      <button type="button" class="toggle-btn" style="margin-top: 12px;" data-action="download:toggle" data-dl-kind="poem" data-dl-id={entry.id} data-dl-title={entry.data.title} aria-pressed="false">
        <span class="toggle-dot"></span><span data-dl-label>تنزيل للقراءة دون اتصال</span>
      </button>
      {!a.chunked && (
        <button type="button" class="toggle-btn" style="margin-top: 8px;" data-action="toggle:tasmi" aria-pressed="false" title="إخفاء الأعجاز حتى تنقر عليها">
          <span class="toggle-dot"></span><span>وضع التسميع</span>
        </button>
      )}
      {!a.chunked && (
        <div style="margin-top: 8px; display: flex; align-items: center; gap: 8px;">
          <button type="button" class="toggle-btn" data-voice-toggle aria-pressed="false" title="تجريبي: يضيء كل بيت عند إلقائه — يعمل حاليًا في Chrome فقط">
            <span class="toggle-dot"></span><span>تتبّع بالصوت</span>
          </button>
          <span class="faint" data-voice-status style="font-size: 12px;"></span>
        </div>
      )}
      <div class="meta-pills">
        <a class="badge-matn pill-link" href="/matn">متن</a>
        {era && <a class="pill tag-verdigris pill-link" href={eraHref(era)}>{eraLabel(era)}</a>}
        <span class="pill">{toArabicDigits(a.verseCount)} بيت</span>
        {a.chunked && <span class="pill">{toArabicDigits(a.chapters.length)} باب</span>}
      </div>
    </div>

    {Object.keys(byAnchor).length > 0 && (
      <div class="hint">
        <span class="ico">۞</span>
        <span class="u97445a8">في هذه المنظومةِ شرحٌ وتخريج — <b>انقرْ على البيت</b> لعرضِ الشرحِ واختيارِ مصدره.</span>
      </div>
    )}

    {audios.length > 0 && <AudioPlayer sources={audios} title={entry.data.title} subtitle={author} loopByVerse={!!timing?.length} />}

    <InlineSearch placeholder={`ابحث في ${entry.data.title}…`} params={{ book: entry.id }} />

    <div class="rule-short"></div>

    {a.frontMatter && (
      <details class="poem-frontmatter">
        <summary>عن هذه الطبعة والنسخ المعتمدة</summary>
        <div class="prose poem-chapter-prose" data-ar set:html={markdownToSafeHtml(a.frontMatter)} />
      </details>
    )}

    {a.chunked ? (
      <div class="card-grid u654c43f" >
        {a.chapters.map((c) => (
          <a class="card u6f3d7fe" href={hrefFor("poem", entry.id, { chapter: c.slug })} >
            <div class="card-title ub9199e2" >{c.title || MATLA_TITLE}</div>
            {c.verses.length > 0 && <div class="faint uade9c31" >{toArabicDigits(c.verses.length)} بيت</div>}
          </a>
        ))}
      </div>
    ) : hasToc ? (
      <div class="chap-grid">
        <div class="reading-pad">
          <StudyBar />
          <div class="verses" data-matn={entry.id} data-unit="بيت" data-timing={timing ? JSON.stringify(timing) : undefined}>
            {preamble.map((v) => <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />)}
            {a.chapters.map((c) => (
              <>
                {c.title && <div class="chapter-band" id={c.slug}><span>{c.title}</span></div>}
                {c.prose && <div class="u49fcd85 poem-chapter-prose" set:html={markdownToSafeHtml(c.prose)} />}
                {c.verses.map((v) => <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />)}
              </>
            ))}
          </div>
          <div class="ornament ud38b410" >۞</div>
        </div>
        <ReaderSidebar label="فهرس الأبواب">
          <div class="toc-box has-current">
            <div class="toc-label">فهرس الأبواب</div>
            {a.chapters.filter((c) => c.title).map((c) => <a href={`#${c.slug}`}>{c.title}</a>)}
          </div>
        </ReaderSidebar>
      </div>
    ) : (
      <>
        <StudyBar />
        <div class="verses" data-matn={entry.id} data-unit="بيت" data-timing={timing ? JSON.stringify(timing) : undefined}>
          {preamble.map((v) => <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />)}
          {a.chapters.map((c) => (
            <>
              {c.title && <div class="chapter-band"><span>{c.title}</span></div>}
              {c.prose && <div class="u49fcd85 poem-chapter-prose" set:html={markdownToSafeHtml(c.prose)} />}
              {c.verses.map((v) => <Verse n={v.n} sadr={v.sadr} ajz={v.ajz} anchor={v.anchor} notes={byAnchor[v.anchor]} />)}
            </>
          ))}
        </div>
      </>
    )}

    {!hasToc && <div class="ornament ud38b410" >۞</div>}
  </div>
  {commentaries.length > 0 && (
    <div class="wrap-mid" style="margin-top: 2rem; border-top: 1px solid var(--border, #e0e0e0); padding-top: 1rem;">
      <h2 class="section-title">شروحه</h2>
      <ul style="list-style: none; padding: 0;">
        {commentaries.map(c => (
          <li style="margin-bottom: 0.5rem;"><a href={c.href}>{c.title}</a> {c.author && <span class="faint">— {c.author}</span>}</li>
        ))}
      </ul>
    </div>
  )}
  <div class="wrap-mid"><RelatedStrip items={related} /></div>
  <Relations items={backlinks} />
</Base>
